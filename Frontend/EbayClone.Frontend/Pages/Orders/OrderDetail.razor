    private async Task SubmitCancelOrder()
    {
        if (string.IsNullOrWhiteSpace(cancelReason))
        {
            cancelError = "Vui lòng chọn lý do hủy.";
            return;
        }

        try
        {
            isUpdating = true;
            cancelError = null;

            var request = new UpdateOrderStatusRequest
            {
                NewStatus = "CANCELLED",
                RowVersion = order!.RowVersion,
                CancelReason = cancelReason,
                CancelRequestedBy = "SELLER",
                CancelNotes = string.IsNullOrWhiteSpace(cancelNotes) ? null : cancelNotes.Trim()
            };

            await OrderService.UpdateOrderStatusAsync(OrderId, request);
            showCancelModal = false;
            await LoadOrder();
        }
        catch (Exception ex)
        {
            cancelError = ex.Message;
        }
        finally
        {
            isUpdating = false;
        }
    }

