@page "/orders/{OrderId:guid}"
@using EbayClone.Frontend.Services
@using EbayClone.Shared.DTOs.Orders
@inject OrderService OrderService
@inject NavigationManager NavigationManager

<div class="seller-hub-container">
    <div class="seller-hub-header mb-4">
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-link p-0 text-primary text-decoration-none" @onclick='() => NavigationManager.NavigateTo("/orders")' style="font-size: 14px;">
                <i class="bi bi-chevron-left"></i> Back to orders
            </button>
        </div>
        <div class="d-flex justify-content-between align-items-end mt-2">
            <div>
                <h1 class="seller-hub-title mb-1">Order #@order?.OrderNumber</h1>
                <div class="text-muted small">Placed on @order?.CreatedAt.ToString("MMM dd, yyyy HH:mm")</div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn-ebay-secondary btn-sm"><i class="bi bi-printer me-1"></i> Print label</button>
                <button class="btn-ebay-secondary btn-sm"><i class="bi bi-envelope me-1"></i> Contact buyer</button>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center p-5 text-muted">Loading order details...</div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else if (order != null)
    {
        <div class="row">
            <div class="col-lg-8">
                <!-- SẢN PHẨM -->
                <div class="summary-card mb-4" style="border-radius: 4px;">
                    <h2 class="order-section-title">Order items</h2>
                    <table class="seller-hub-table">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th style="width: 120px;">Price</th>
                                <th style="width: 100px;">Quantity</th>
                                <th style="width: 120px; text-align: right;">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var item in order.Items)
                            {
                                <tr>
                                    <td>
                                        <div class="product-cell">
                                            @if (!string.IsNullOrEmpty(item.Variant?.ImageUrl))
                                            {
                                                <img src="@item.Variant.ImageUrl" class="product-img" alt="Product" />
                                            }
                                            else
                                            {
                                                <div class="product-img bg-light"></div>
                                            }
                                            <div class="product-info">
                                                <h4>@item.ProductNameSnapshot</h4>
                                                <span class="sku">SKU: @item.Variant?.SkuCode</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="price-text">@item.PriceAtPurchase.ToString("N0") ₫</td>
                                    <td>x @item.Quantity</td>
                                    <td class="price-text text-end">@((item.PriceAtPurchase * item.Quantity).ToString("N0")) ₫</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- LỊCH SỬ (TIMELINE) -->
                <div class="summary-card mb-4" style="border-radius: 4px;">
                    <h2 class="order-section-title">Order history</h2>
                    <ul class="timeline-ebay">
                        <li class="timeline-item-ebay active">
                            <div><strong>Order placed</strong></div>
                            <div class="transaction-date">@order.CreatedAt.ToString("MMM dd, yyyy HH:mm")</div>
                        </li>
                        @if (order.PaidAt.HasValue)
                        {
                        <li class="timeline-item-ebay active">
                            <div><strong>Payment received</strong></div>
                            <div class="transaction-date">@order.PaidAt.Value.ToString("MMM dd, yyyy HH:mm")</div>
                        </li>
                        }
                        @if (order.ShippedAt.HasValue)
                        {
                        <li class="timeline-item-ebay active">
                            <div><strong>Order shipped</strong> (@order.ShippingCarrier - @order.TrackingCode)</div>
                            <div class="transaction-date">@order.ShippedAt.Value.ToString("MMM dd, yyyy HH:mm")</div>
                        </li>
                        }
                        @if (order.CompletedAt.HasValue)
                        {
                        <li class="timeline-item-ebay active">
                            <div><strong>Order completed</strong></div>
                            <div class="transaction-date">@order.CompletedAt.Value.ToString("MMM dd, yyyy HH:mm")</div>
                        </li>
                        }
                    </ul>
                </div>
            </div>

            <div class="col-lg-4">
                <!-- XỬ LÝ -->
                <div class="summary-card mb-4" style="border-top: 3px solid var(--seller-hub-blue);">
                    <h2 class="order-section-title">Workflow actions</h2>
                    <div class="row mb-4">
                        <div class="col-6">
                            <span class="text-muted d-block small mb-1">Order status:</span>
                            <span class="status-badge status-sold py-1 px-3">@order.Status</span>
                        </div>
                        <div class="col-6">
                            <span class="text-muted d-block small mb-1">Payment status:</span>
                            <span class="status-badge @(order.PaymentStatus == "PAID" ? "status-active" : "status-draft") py-1 px-3">@order.PaymentStatus</span>
                        </div>
                    </div>
                    
                    <div class="d-grid gap-2">
                        @if (order.Status == "PENDING_PAYMENT")
                        {
                            <button class="btn-ebay-primary" @onclick='() => UpdateStatus("READY_TO_SHIP")' disabled="@isUpdating">
                                Mark as paid
                            </button>
                            <button class="btn-ebay-secondary" @onclick='() => UpdateStatus("CANCELLED")' disabled="@isUpdating">
                                Cancel order
                            </button>
                        }
                        else if (order.Status == "READY_TO_SHIP")
                        {
                            <button class="btn-ebay-primary" @onclick='() => UpdateStatus("PROCESSING")' disabled="@isUpdating">
                                Print shipping label
                            </button>
                        }
                        else if (order.Status == "PROCESSING")
                        {
                            <button class="btn-ebay-primary" @onclick='() => UpdateStatus("SHIPPED")' disabled="@isUpdating">
                                Dispatch order
                            </button>
                        }
                        else if (order.Status == "SHIPPED")
                        {
                            <button class="btn-ebay-primary" @onclick='() => UpdateStatus("DELIVERED")' disabled="@isUpdating">
                                Confirm delivery
                            </button>
                        }
                        else if (order.Status == "DELIVERED")
                        {
                            <div class="alert alert-success mt-2 py-2 text-center small">Order completed!</div>
                        }
                        else if (order.Status == "CANCELLED")
                        {
                            <div class="alert alert-secondary mt-2 py-2 text-center small">Order cancelled.</div>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(statusErrorMessage))
                    {
                        <div class="mt-2 text-danger small">@statusErrorMessage</div>
                    }
                </div>

                <!-- TỔNG KẾT TIỀN -->
                <div class="summary-card mb-4">
                    <h2 class="order-section-title">Order totals</h2>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Subtotal (@order.Items.Count items)</span>
                        <span>@((order.TotalAmount - order.ShippingFee).ToString("N0")) ₫</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Shipping & handling</span>
                        <span>@order.ShippingFee.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 text-success">
                        <span class="text-muted">Tax</span>
                        <span>0 ₫</span>
                    </div>
                    <div class="d-flex justify-content-between pt-3 border-top">
                        <span class="fw-bold fs-5">Order total</span>
                        <span class="price-text" style="font-size: 20px;">@order.TotalAmount.ToString("N0") ₫</span>
                    </div>
                    
                    @if (order.Status == "DELIVERED" || order.Status == "COMPLETED")
                    {
                        <div class="mt-4 p-3 bg-light rounded-3" style="border: 1px dashed #ced4da;">
                            <div class="fw-600 mb-2 small text-uppercase" style="letter-spacing: 0.5px;">Estimated earnings</div>
                            <div class="d-flex justify-content-between mb-1 small">
                                <span class="text-muted">Platform fee (eBay clone):</span>
                                <span class="text-danger">-@order.PlatformFee.ToString("N0") ₫</span>
                            </div>
                            <div class="d-flex justify-content-between fw-bold pt-2 mt-1 border-top text-primary">
                                <span>Net profit:</span>
                                <span>@((order.TotalAmount - order.PlatformFee).ToString("N0")) ₫</span>
                            </div>
                        </div>
                    }
                </div>

                <!-- NGƯỜI NHẬN -->
                <div class="summary-card mb-4">
                    <h2 class="order-section-title">Shipping details</h2>
                    <div class="d-flex align-items-start gap-3 mb-3">
                        <div class="bg-light rounded-circle p-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="bi bi-geo-alt text-primary fs-5"></i>
                        </div>
                        <div>
                            <div class="fw-bold mb-1">Shipping address</div>
                            <div class="text-muted small" style="line-height: 1.5;">@FormatReceiverInfo(order.ReceiverInfo)</div>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(order.ShippingCarrier))
                    {
                        <div class="pt-3 border-top mt-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted small">Carrier:</span>
                                <span class="fw-600 small">@order.ShippingCarrier</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted small">Tracking:</span>
                                <span class="fw-600 small text-primary">@order.TrackingCode</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid OrderId { get; set; }

    private OrderDto? order;
    private bool isLoading = true;
    private string? errorMessage;
    private string? statusErrorMessage;
    private bool isUpdating = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrder();
    }

    private async Task LoadOrder()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            order = await OrderService.GetOrderByIdAsync(OrderId);
            if (order == null)
            {
                errorMessage = "Không tìm thấy đơn hàng.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task UpdateStatus(string newStatus)
    {
        try
        {
            isUpdating = true;
            statusErrorMessage = null;
            
            var request = new UpdateOrderStatusRequest 
            { 
                NewStatus = newStatus,
                ShippingCarrier = newStatus == "SHIPPED" ? "GiaoHangNhanh" : null,
                TrackingCode = newStatus == "SHIPPED" ? "GHN" + DateTime.Now.Ticks.ToString().Substring(10) : null
            };

            await OrderService.UpdateOrderStatusAsync(OrderId, request);
            await LoadOrder(); // Refresh the data to trace state change
        }
        catch (Exception ex)
        {
            statusErrorMessage = $"Lỗi cập nhật: {ex.Message}";
        }
        finally
        {
            isUpdating = false;
        }
    }

    private string FormatReceiverInfo(string? jsonInfo)
    {
        if (string.IsNullOrEmpty(jsonInfo)) return "Chưa có thông tin";
        try
        {
            var info = System.Text.Json.JsonDocument.Parse(jsonInfo);
            var root = info.RootElement;
            var name = root.TryGetProperty("FullName", out var n) ? n.GetString() : "";
            var phone = root.TryGetProperty("Phone", out var p) ? p.GetString() : "";
            var addr = root.TryGetProperty("Address", out var a) ? a.GetString() : "";
            return $"{name} - {phone} - {addr}".Trim('-', ' ');
        }
        catch
        {
            return jsonInfo; // Fallback if not valid JSON
        }
    }
}
