@page "/orders/{OrderId:guid}"
@using EbayClone.Frontend.Services
@using EbayClone.Shared.DTOs.Orders
@inject OrderService OrderService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime

<div class="seller-hub-container">
    <div class="seller-hub-header mb-4">
        <div class="d-flex align-items-center gap-3">
            <button class="btn btn-link p-0 text-primary text-decoration-none" @onclick='() => NavigationManager.NavigateTo("/orders")' style="font-size: 14px;">
                <i class="bi bi-chevron-left"></i> Back to orders
            </button>
        </div>
        <div class="d-flex justify-content-between align-items-end mt-2">
            <div>
                <h1 class="seller-hub-title mb-1">Order #@order?.OrderNumber</h1>
                <div class="text-muted small">Placed on @order?.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                    @if (!string.IsNullOrEmpty(order?.BuyerName))
                    {
                        <span class="ms-2">· <i class="bi bi-person-fill"></i> @order.BuyerName</span>
                    }
                </div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn-ebay-secondary btn-sm" @onclick="PrintLabel"><i class="bi bi-printer me-1"></i> Print label</button>
                <button class="btn-ebay-secondary btn-sm" @onclick='() => statusErrorMessage = "💬 Message system chưa triển khai — sẽ xây dựng ở sprint sau."'><i class="bi bi-envelope me-1"></i> Contact buyer</button>
            </div>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center p-5 text-muted">Loading order details...</div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else if (order != null)
    {
        <div class="row">
            <div class="col-lg-8">
                <!-- SẢN PHẨM -->
                <div class="summary-card mb-4" style="border-radius: 4px;">
                    <h2 class="order-section-title">Order items</h2>
                    <table class="seller-hub-table">
                        <thead>
                            <tr>
                                <th>Item</th>
                                <th style="width: 120px;">Price</th>
                                <th style="width: 100px;">Quantity</th>
                                <th style="width: 120px; text-align: right;">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach(var item in order.Items)
                            {
                                <tr>
                                    <td>
                                        <div class="product-cell">
                                            @if (!string.IsNullOrEmpty(item.Variant?.ImageUrl))
                                            {
                                                <img src="@item.Variant.ImageUrl" class="product-img" alt="Product" />
                                            }
                                            else
                                            {
                                                <div class="product-img bg-light"></div>
                                            }
                                            <div class="product-info">
                                                <h4>@item.ProductNameSnapshot</h4>
                                                <span class="sku">SKU: @item.Variant?.SkuCode</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="price-text">@item.PriceAtPurchase.ToString("N0") ₫</td>
                                    <td>x @item.Quantity</td>
                                    <td class="price-text text-end">@((item.PriceAtPurchase * item.Quantity).ToString("N0")) ₫</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- LỊCH SỬ (TIMELINE) -->
                <div class="summary-card mb-4" style="border-radius: 4px;">
                    <h2 class="order-section-title">Order history</h2>
                    <ul class="timeline-ebay">
                        <li class="timeline-item-ebay active">
                            <div><strong>Order placed</strong></div>
                            <div class="transaction-date">@order.CreatedAt.ToString("MMM dd, yyyy HH:mm")</div>
                        </li>
                        @if (order.PaidAt.HasValue)
                        {
                        <li class="timeline-item-ebay active">
                            <div><strong>Payment received</strong></div>
                            <div class="transaction-date">@order.PaidAt.Value.ToString("MMM dd, yyyy HH:mm")</div>
                        </li>
                        }
                        @if (order.ShippedAt.HasValue)
                        {
                        <li class="timeline-item-ebay active">
                            <div><strong>Order shipped</strong> (@order.ShippingCarrier - @order.TrackingCode)</div>
                            <div class="transaction-date">@order.ShippedAt.Value.ToString("MMM dd, yyyy HH:mm")</div>
                        </li>
                        }
                        @if (order.DeliveredAt.HasValue)
                        {
                        <li class="timeline-item-ebay active">
                            <div><strong>Delivered</strong></div>
                            <div class="transaction-date">@order.DeliveredAt.Value.ToString("MMM dd, yyyy HH:mm")</div>
                        </li>
                        }
                        @if (order.CancelledAt.HasValue)
                        {
                        <li class="timeline-item-ebay" style="border-left-color: #e53238;">
                            <div><strong style="color: #e53238;">Cancelled</strong> — @(order.CancelReason ?? "N/A")</div>
                            <div class="transaction-date">@order.CancelledAt.Value.ToString("MMM dd, yyyy HH:mm")</div>
                        </li>
                        }
                        @if (order.CompletedAt.HasValue)
                        {
                        <li class="timeline-item-ebay active">
                            <div><strong>Order completed</strong> — Funds released</div>
                            <div class="transaction-date">@order.CompletedAt.Value.ToString("MMM dd, yyyy HH:mm")</div>
                        </li>
                        }
                    </ul>
                </div>
            </div>

            <div class="col-lg-4">
                <!-- XỬ LÝ -->
                <div class="summary-card mb-4" style="border-top: 3px solid var(--seller-hub-blue);">
                    <h2 class="order-section-title">Workflow actions</h2>
                    <div class="row mb-4">
                        <div class="col-6">
                            <span class="text-muted d-block small mb-1">Order status:</span>
                            <span class="status-badge status-sold py-1 px-3">@order.Status</span>
                        </div>
                        <div class="col-6">
                            <span class="text-muted d-block small mb-1">Payment status:</span>
                            <span class="status-badge @(order.PaymentStatus == "PAID" ? "status-active" : "status-draft") py-1 px-3">@order.PaymentStatus</span>
                        </div>
                    </div>
                    
                    <div class="d-grid gap-2">
                        @if (order.Status == "PENDING_PAYMENT")
                        {
                            <button class="btn-ebay-primary" @onclick='() => UpdateStatus("PAID")' disabled="@isUpdating">
                                <i class="bi bi-credit-card me-1"></i> Mark as paid
                            </button>
                            <button class="btn-ebay-secondary" @onclick="OpenCancelModal" disabled="@isUpdating">
                                <i class="bi bi-x-circle me-1"></i> Cancel order
                            </button>
                        }
                        else if (order.Status == "PAID")
                        {
                            <button class="btn-ebay-primary" @onclick="OpenShipModal" disabled="@isUpdating">
                                <i class="bi bi-truck me-1"></i> Ship order
                            </button>
                            <button class="btn-ebay-secondary" @onclick="OpenCancelModal" disabled="@isUpdating">
                                <i class="bi bi-x-circle me-1"></i> Cancel order
                            </button>
                            @if (order.ShipByDate.HasValue)
                            {
                                <div class="alert alert-warning py-2 text-center small mt-1 mb-0">
                                    <i class="bi bi-clock"></i> Ship by: @order.ShipByDate.Value.ToString("MMM dd, yyyy")
                                </div>
                            }
                        }
                        else if (order.Status == "SHIPPED")
                        {
                            <div class="alert alert-info mt-2 py-2 text-center small">
                                <i class="bi bi-truck me-1"></i> In transit — Awaiting carrier confirmation
                                @if (!string.IsNullOrEmpty(order.TrackingCode))
                                {
                                    <div class="mt-1" style="font-size: 11px;">Tracking: <strong>@order.ShippingCarrier</strong> — @order.TrackingCode</div>
                                }
                            </div>
                        }
                        else if (order.Status == "DELIVERED")
                        {
                            <div class="alert alert-success mt-2 py-2 text-center small">
                                <i class="bi bi-check-circle-fill me-1"></i> Delivered!
                                @if (order.ReturnDeadline.HasValue)
                                {
                                    <div class="mt-1" style="font-size: 11px;">Return window ends: @order.ReturnDeadline.Value.ToString("MMM dd, yyyy")</div>
                                }
                            </div>
                        }
                        else if (order.Status == "CANCELLED")
                        {
                            <div class="alert alert-secondary mt-2 py-2 small">
                                <i class="bi bi-x-circle-fill me-1"></i> Cancelled
                                @if (!string.IsNullOrEmpty(order.CancelReason))
                                {
                                    <div class="mt-1" style="font-size: 11px;">Reason: @order.CancelReason</div>
                                }
                            </div>
                        }
                        else if (order.Status == "RETURN_REQUESTED")
                        {
                            <div class="alert alert-warning mt-2 py-2 text-center small">
                                <i class="bi bi-arrow-return-left me-1"></i> Return requested
                            </div>
                        }
                        else if (order.Status == "REFUNDED" || order.Status == "PARTIALLY_REFUNDED")
                        {
                            <div class="alert alert-info mt-2 py-2 text-center small">
                                <i class="bi bi-cash-stack me-1"></i> @order.Status
                            </div>
                        }
                        else if (order.Status == "DISPUTE_OPENED")
                        {
                            <div class="alert alert-danger mt-2 py-2 text-center small">
                                <i class="bi bi-exclamation-triangle me-1"></i> Dispute opened
                            </div>
                        }
                        else if (order.Status == "COMPLETED")
                        {
                            <div class="alert alert-success mt-2 py-2 text-center small">
                                <i class="bi bi-trophy me-1"></i> Completed — Funds released
                            </div>
                        }
                    </div>
                    @if (!string.IsNullOrEmpty(statusErrorMessage))
                    {
                        <div class="mt-2 text-danger small">@statusErrorMessage</div>
                    }

                    @* === CANCEL REQUEST ALERT (buyer đã request) === *@
                    @if (cancelRequestInfo?.HasPendingRequest == true)
                    {
                        <div class="alert alert-warning mt-3 py-2" style="border-left: 4px solid #f5a623;">
                            <div class="d-flex align-items-center mb-2">
                                <i class="bi bi-bell-fill me-2 text-warning"></i>
                                <strong>Buyer yêu cầu hủy đơn</strong>
                            </div>
                            <div class="small">
                                <div><strong>Lý do:</strong> @cancelRequestInfo.Reason</div>
                                <div><strong>Thời gian:</strong> @cancelRequestInfo.RequestedAt?.ToString("MMM dd, HH:mm")</div>
                                <div class="text-danger"><strong>Deadline phản hồi:</strong> @cancelRequestInfo.ResponseDeadline?.ToString("MMM dd, HH:mm")</div>
                            </div>
                            <div class="d-flex gap-2 mt-2">
                                <button class="btn btn-success btn-sm flex-fill" disabled="@isUpdating" @onclick="AcceptCancelRequest">
                                    <i class="bi bi-check-circle me-1"></i> Accept (Cancel + Refund)
                                </button>
                                <button class="btn btn-outline-secondary btn-sm flex-fill" disabled="@isUpdating" @onclick="DeclineCancelRequest">
                                    <i class="bi bi-x-circle me-1"></i> Decline
                                </button>
                            </div>
                        </div>
                    }
                </div>

                @* === 🟨 BUYER MOCK TEST PANEL === *@
                @if (order.Status == "PAID" || order.Status == "PENDING_PAYMENT" || order.Status == "SHIPPED" || order.Status == "DELIVERED")
                {
                    <div class="summary-card mb-4" style="border: 2px dashed #f5a623; background: #fffdf5;">
                        <h2 class="order-section-title" style="color: #f5a623;"><i class="bi bi-person-fill"></i> 🟨 Mock Actions (Test only)</h2>
                        <p class="small text-muted mb-2">Giả lập hành vi buyer/hệ thống (chỉ dùng cho test)</p>
                        <div class="d-grid gap-2">
                            @if (order.Status == "PAID" || order.Status == "PENDING_PAYMENT")
                            {
                                <button class="btn btn-outline-warning btn-sm w-100" 
                                        disabled="@(isUpdating || cancelRequestInfo?.HasPendingRequest == true)"
                                        @onclick="BuyerMockCancelRequest">
                                    <i class="bi bi-x-circle me-1"></i> 🟨 Buyer: Request Cancel
                                </button>
                                @if (cancelRequestInfo?.HasPendingRequest == true)
                                {
                                    <div class="text-muted small mt-1 text-center"><i class="bi bi-clock"></i> Đang chờ seller phản hồi...</div>
                                }
                            }
                            @if (order.Status == "SHIPPED")
                            {
                                <button class="btn btn-outline-success btn-sm w-100" disabled="@isUpdating"
                                        @onclick='() => UpdateStatus("DELIVERED")'>
                                    <i class="bi bi-box-seam me-1"></i> ⚙️ System: Carrier Confirm Delivery
                                </button>
                                <div class="text-muted small text-center" style="font-size: 11px;">Giả lập: carrier xác nhận đã giao thành công</div>
                            }
                            @if (order.Status == "DELIVERED")
                            {
                                <button class="btn btn-outline-primary btn-sm w-100" disabled="@isUpdating"
                                        @onclick="MockReleaseFunds">
                                    <i class="bi bi-trophy me-1"></i> ⚙️ System: Auto-Complete (Release Funds)
                                </button>
                                <div class="text-muted small text-center" style="font-size: 11px;">Giả lập: hết return window → giải ngân → COMPLETED</div>
                            }
                        </div>
                    </div>
                }

                <!-- TỔNG KẾT TIỀN -->
                <div class="summary-card mb-4">
                    <h2 class="order-section-title">Order totals</h2>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Subtotal (@order.Items.Count items)</span>
                        <span>@((order.TotalAmount - order.ShippingFee).ToString("N0")) ₫</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Shipping & handling</span>
                        <span>@order.ShippingFee.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 text-success">
                        <span class="text-muted">Tax</span>
                        <span>0 ₫</span>
                    </div>
                    <div class="d-flex justify-content-between pt-3 border-top">
                        <span class="fw-bold fs-5">Order total</span>
                        <span class="price-text" style="font-size: 20px;">@order.TotalAmount.ToString("N0") ₫</span>
                    </div>
                    
                    @if (order.Status == "DELIVERED" || order.Status == "COMPLETED")
                    {
                        <div class="mt-4 p-3 bg-light rounded-3" style="border: 1px dashed #ced4da;">
                            <div class="fw-600 mb-2 small text-uppercase" style="letter-spacing: 0.5px;">Estimated earnings</div>
                            <div class="d-flex justify-content-between mb-1 small">
                                <span class="text-muted">Platform fee (eBay clone):</span>
                                <span class="text-danger">-@order.PlatformFee.ToString("N0") ₫</span>
                            </div>
                            <div class="d-flex justify-content-between fw-bold pt-2 mt-1 border-top text-primary">
                                <span>Net profit:</span>
                                <span>@((order.TotalAmount - order.PlatformFee).ToString("N0")) ₫</span>
                            </div>
                        </div>
                    }
                </div>

                <!-- NGƯỜI NHẬN -->
                <div class="summary-card mb-4">
                    <h2 class="order-section-title">Shipping details</h2>
                    <div class="d-flex align-items-start gap-3 mb-3">
                        <div class="bg-light rounded-circle p-3 d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
                            <i class="bi bi-geo-alt text-primary fs-5"></i>
                        </div>
                        <div>
                            <div class="fw-bold mb-1">Shipping address</div>
                            <div class="text-muted small" style="line-height: 1.5;">@FormatReceiverInfo(order.ReceiverInfo)</div>
                        </div>
                    </div>
                    
                    @if (!string.IsNullOrEmpty(order.ShippingCarrier))
                    {
                        <div class="pt-3 border-top mt-3">
                            <div class="d-flex justify-content-between mb-2">
                                <span class="text-muted small">Carrier:</span>
                                <span class="fw-600 small">@order.ShippingCarrier</span>
                            </div>
                            <div class="d-flex justify-content-between">
                                <span class="text-muted small">Tracking:</span>
                                <span class="fw-600 small text-primary">@order.TrackingCode</span>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@* ==================== MODAL: SHIP ORDER ==================== *@
@if (showShipModal)
{
    <div class="modal-overlay" @onclick="CloseShipModal">
        <div class="modal-content" @onclick:stopPropagation="true" style="max-width: 460px;">
            <div class="modal-header" style="background: #3665f3; color: white; padding: 14px 20px; border-radius: 8px 8px 0 0;">
                <h5 style="margin: 0; font-weight: 600;"><i class="bi bi-truck"></i> Ship Order</h5>
                <button type="button" class="btn-close btn-close-white" @onclick="CloseShipModal"></button>
            </div>
            <div style="padding: 20px;">
                <div style="margin-bottom: 14px;">
                    <label class="form-label fw-bold">Shipping carrier <span class="text-danger">*</span></label>
                    <select class="form-select" @bind="shipCarrier">
                        <option value="">-- Chọn hãng vận chuyển --</option>
                        <option value="GiaoHangNhanh">Giao Hàng Nhanh (GHN)</option>
                        <option value="GiaoHangTietKiem">Giao Hàng Tiết Kiệm (GHTK)</option>
                        <option value="JT_Express">J&T Express</option>
                        <option value="Viettel_Post">Viettel Post</option>
                        <option value="VNPost">VN Post</option>
                        <option value="Ninja_Van">Ninja Van</option>
                        <option value="SPX_Express">Shopee Express (SPX)</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div style="margin-bottom: 16px;">
                    <label class="form-label fw-bold">Tracking number <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" placeholder="VD: GHN123456789" @bind="shipTrackingCode" />
                </div>
                @if (!string.IsNullOrEmpty(shipError))
                {
                    <div class="alert alert-danger py-2 small">@shipError</div>
                }
                <button class="btn-ebay-primary w-100" style="padding: 10px; font-weight: 600;" disabled="@isUpdating" @onclick="SubmitShipOrder">
                    @if (isUpdating)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    <i class="bi bi-send me-1"></i> Confirm Shipment
                </button>
            </div>
        </div>
    </div>
}

@* ==================== MODAL: CANCEL ORDER ==================== *@
@if (showCancelModal)
{
    <div class="modal-overlay" @onclick="CloseCancelModal">
        <div class="modal-content" @onclick:stopPropagation="true" style="max-width: 460px;">
            <div class="modal-header" style="background: #e53238; color: white; padding: 14px 20px; border-radius: 8px 8px 0 0;">
                <h5 style="margin: 0; font-weight: 600;"><i class="bi bi-x-circle"></i> Cancel Order</h5>
                <button type="button" class="btn-close btn-close-white" @onclick="CloseCancelModal"></button>
            </div>
            <div style="padding: 20px;">
                <div class="alert alert-warning py-2 small mb-3">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    <strong>Lưu ý:</strong> Cancel OUT_OF_STOCK sẽ bị tính defect.
                </div>
                <div style="margin-bottom: 14px;">
                    <label class="form-label fw-bold">Lý do hủy <span class="text-danger">*</span></label>
                    <select class="form-select" @bind="cancelReason">
                        <option value="">-- Chọn lý do --</option>
                        <option value="BUYER_ASKED">Buyer yêu cầu hủy</option>
                        <option value="OUT_OF_STOCK">Hết hàng</option>
                        <option value="BUYER_HASNT_PAID">Buyer chưa thanh toán</option>
                        <option value="ADDRESS_ISSUE">Địa chỉ có vấn đề</option>
                        <option value="SELLER_CANT_SHIP">Seller không thể giao hàng</option>
                        <option value="OTHER">Lý do khác</option>
                    </select>
                </div>
                <div style="margin-bottom: 16px;">
                    <label class="form-label fw-bold">Ghi chú (tùy chọn)</label>
                    <textarea class="form-control" rows="3" placeholder="Ghi chú thêm..." @bind="cancelNotes"></textarea>
                </div>
                @if (!string.IsNullOrEmpty(cancelError))
                {
                    <div class="alert alert-danger py-2 small">@cancelError</div>
                }
                <button class="btn-ebay-primary w-100" style="padding: 10px; font-weight: 600; background: #e53238; border-color: #e53238;" disabled="@isUpdating" @onclick="SubmitCancelOrder">
                    @if (isUpdating)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                    }
                    <i class="bi bi-x-circle me-1"></i> Confirm Cancellation
                </button>
            </div>
        </div>
    </div>
}

<style>
    .modal-overlay {
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0,0,0,0.5); display: flex; align-items: center; justify-content: center;
        z-index: 1050; animation: fadeIn 0.2s;
    }
    .modal-content {
        background: white; border-radius: 8px; width: 90%; box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        max-height: 85vh; overflow-y: auto;
    }
    @@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
</style>

@code {
    [Parameter]
    public Guid OrderId { get; set; }

    private OrderDto? order;
    private bool isLoading = true;
    private string? errorMessage;
    private string? statusErrorMessage;
    private bool isUpdating = false;
    private CancelRequestInfo? cancelRequestInfo;

    // Ship Modal
    private bool showShipModal;
    private string shipCarrier = "";
    private string shipTrackingCode = "";
    private string? shipError;

    // Cancel Modal
    private bool showCancelModal;
    private string cancelReason = "";
    private string cancelNotes = "";
    private string? cancelError;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrder();
        await LoadCancelRequest();
    }

    private async Task LoadCancelRequest()
    {
        try
        {
            if (order != null && (order.Status == "PAID" || order.Status == "PENDING_PAYMENT"))
            {
                cancelRequestInfo = await OrderService.GetCancelRequestAsync(OrderId);
            }
            else
            {
                cancelRequestInfo = null;
            }
        }
        catch { cancelRequestInfo = null; }
    }

    private async Task LoadOrder()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            order = await OrderService.GetOrderByIdAsync(OrderId);
            if (order == null)
            {
                errorMessage = "Không tìm thấy đơn hàng.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    // ==================== SHIP MODAL ====================

    private void OpenShipModal()
    {
        shipCarrier = "";
        shipTrackingCode = "";
        shipError = null;
        showShipModal = true;
    }

    private void CloseShipModal() => showShipModal = false;

    private async Task SubmitShipOrder()
    {
        if (string.IsNullOrWhiteSpace(shipCarrier))
        {
            shipError = "Vui lòng chọn hãng vận chuyển.";
            return;
        }
        if (string.IsNullOrWhiteSpace(shipTrackingCode))
        {
            shipError = "Vui lòng nhập mã vận đơn.";
            return;
        }

        try
        {
            isUpdating = true;
            shipError = null;

            var request = new UpdateOrderStatusRequest
            {
                NewStatus = "SHIPPED",
                RowVersion = order!.RowVersion,
                ShippingCarrier = shipCarrier,
                TrackingCode = shipTrackingCode.Trim()
            };

            await OrderService.UpdateOrderStatusAsync(OrderId, request);
            showShipModal = false;
