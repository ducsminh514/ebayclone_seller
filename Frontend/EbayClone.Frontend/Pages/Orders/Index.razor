@page "/orders"
@using EbayClone.Frontend.Services
@using EbayClone.Shared.DTOs.Orders
@inject OrderService OrderService
@inject NavigationManager NavigationManager

<div class="seller-hub-container">
    <div class="seller-hub-header">
        <h1 class="seller-hub-title">Manage orders</h1>
    </div>
    
    @* Tabs for Order Status *@
    <div class="nav-ebay-tabs">
        <button class="nav-link @(currentTab == "ALL" ? "active" : "")" @onclick='() => ChangeTab("ALL")'>All</button>
        <button class="nav-link @(currentTab == "PENDING_PAYMENT" ? "active" : "")" @onclick='() => ChangeTab("PENDING_PAYMENT")'>Awaiting payment</button>
        <button class="nav-link @(currentTab == "READY_TO_SHIP" ? "active" : "")" @onclick='() => ChangeTab("READY_TO_SHIP")'>Awaiting shipment</button>
        <button class="nav-link @(currentTab == "SHIPPED" ? "active" : "")" @onclick='() => ChangeTab("SHIPPED")'>Paid and shipped</button>
        <button class="nav-link @(currentTab == "DELIVERED" ? "active" : "")" @onclick='() => ChangeTab("DELIVERED")'>Completed</button>
    </div>

    @* Search & Filter Section *@
    <div class="search-container">
        <div class="search-title">
            <i class="bi bi-search"></i> Search orders
        </div>
        <div class="filter-grid">
            <div class="filter-item">
                <label>Order number or Buyer ID</label>
                <input type="text" class="ebay-input" placeholder="Search orders..." @bind="searchQuery" @bind:event="oninput" />
            </div>
            <div class="filter-item">
                <label>Period</label>
                <select class="ebay-select">
                    <option>Last 90 days</option>
                    <option>This month</option>
                </select>
            </div>
        </div>
        <div class="action-bar" style="margin-top: 20px;">
            <button class="btn-ebay-primary" @onclick="SearchData">Search</button>
            <a href="javascript:void(0)" style="font-size: 13px; color: var(--seller-hub-link); margin-left: 15px;">Advanced search</a>
            <span style="border-left: 1px solid #ccc; margin: 0 10px; height: 15px;"></span>
            <a href="javascript:void(0)" style="font-size: 13px; color: var(--seller-hub-link);" @onclick="ClearSearch">Clear all</a>
        </div>
    </div>

    @* Table Content *@
    <div class="seller-hub-table-wrapper">
        @if (isLoading)
        {
            <div class="p-5 text-center text-muted">
                <div class="spinner-border text-primary" role="status"></div>
                <div class="mt-2">Loading orders...</div>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger m-3">@errorMessage</div>
        }
        else if (orders == null || !orders.Any())
        {
            <div class="p-5 text-center text-muted">
                <i class="bi bi-inbox" style="font-size: 48px;"></i>
                <p class="mt-3">No orders found matching your criteria.</p>
            </div>
        }
        else
        {
            <table class="seller-hub-table">
                <thead>
                    <tr>
                        <th style="width: 150px;">Order number</th>
                        <th style="width: 150px;">Date</th>
                        <th style="width: 120px;">Total</th>
                        <th>Payment status</th>
                        <th>Order status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in orders)
                    {
                        <tr>
                            <td class="fw-bold"><a href="/orders/@o.Id">#@o.OrderNumber</a></td>
                            <td>@o.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                            <td class="price-text">@o.TotalAmount.ToString("N0") ₫</td>
                            <td>
                                <span class="status-badge @(o.PaymentStatus == "PAID" ? "status-active" : "status-draft")">
                                    @o.PaymentStatus
                                </span>
                            </td>
                            <td>
                                <span class="status-badge @GetStatusClass(o.Status)">@o.Status</span>
                            </td>
                            <td class="text-end">
                                <button class="btn-ebay-secondary btn-sm" @onclick='() => NavigationManager.NavigateTo($"/orders/{o.Id}")'>
                                    View details
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @* Pagination Controls *@
            <div class="d-flex justify-content-between align-items-center p-3 border-top">
                <div class="text-muted" style="font-size: 13px;">
                    Showing @(((currentPage - 1) * pageSize) + 1) to @(Math.Min(currentPage * pageSize, totalCount)) of @totalCount orders
                </div>
                <div class="d-flex gap-2">
                    <button class="btn-ebay-secondary btn-sm" disabled="@(currentPage <= 1)" @onclick="() => ChangePage(currentPage - 1)">Previous</button>
                    <button class="btn-ebay-secondary btn-sm" disabled="@(currentPage * pageSize >= totalCount)" @onclick="() => ChangePage(currentPage + 1)">Next</button>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private IEnumerable<OrderDto>? orders;
    private int totalCount;
    private int currentPage = 1;
    private int pageSize = 10;
    private bool isLoading = true;
    private string? errorMessage;
    private string currentTab = "ALL";
    private string? searchQuery;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            var result = await OrderService.GetPagedOrdersAsync(currentPage, pageSize, currentTab, searchQuery);
            orders = result.Items;
            totalCount = result.TotalCount;
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ChangeTab(string tab)
    {
        currentTab = tab;
        currentPage = 1; // Reset to first page
        await LoadOrders();
    }

    private async Task ChangePage(int newPage)
    {
        currentPage = newPage;
        await LoadOrders();
    }

    private async Task SearchData()
    {
        currentPage = 1;
        await LoadOrders();
    }

    private async Task ClearSearch()
    {
        searchQuery = null;
        currentPage = 1;
        await LoadOrders();
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "DELIVERED" => "status-active",
            "SHIPPED" => "status-sold",
            "CANCELLED" => "status-draft",
            _ => "status-sold"
        };
    }
}
