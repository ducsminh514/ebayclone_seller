@page "/orders"
@using EbayClone.Domain.Entities
@using EbayClone.Frontend.Services
@using EbayClone.Application.DTOs.Orders
@inject OrderService OrderService
@inject NavigationManager NavigationManager

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="ebay-page-title mb-0">Quản Lý Đơn Hàng (Orders)</h2>
    </div>
    
    <div class="ebay-card p-0 overflow-hidden">
        <div class="bg-white border-bottom">
            <ul class="nav nav-tabs card-header-tabs" style="cursor: pointer;">
                <li class="nav-item"><a class="nav-link @GetTabClass("ALL")" @onclick='() => ChangeTab("ALL")'>TẤT CẢ</a></li>
                <li class="nav-item"><a class="nav-link @GetTabClass("PENDING_PAYMENT")" @onclick='() => ChangeTab("PENDING_PAYMENT")'>CHỜ THANH TOÁN</a></li>
                <li class="nav-item"><a class="nav-link @GetTabClass("READY_TO_SHIP")" @onclick='() => ChangeTab("READY_TO_SHIP")'>CHỜ LẤY HÀNG</a></li>
                <li class="nav-item"><a class="nav-link @GetTabClass("SHIPPED")" @onclick='() => ChangeTab("SHIPPED")'>ĐANG GIAO</a></li>
                <li class="nav-item"><a class="nav-link @GetTabClass("DELIVERED")" @onclick='() => ChangeTab("DELIVERED")'>ĐÃ GIAO</a></li>
            </ul>
        </div>
        <div class="card-body p-0">
            @if (isLoading)
            {
                <div class="p-4 text-center text-muted">Đang tải danh sách đơn hàng...</div>
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger m-3">@errorMessage</div>
            }
            else if (!filteredOrders.Any())
            {
                <div class="p-5 text-center text-muted">
                    <h5>Không tìm thấy đơn hàng nào.</h5>
                </div>
            }
            else
            {
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-secondary" style="font-size: 13px; text-transform: uppercase;">
                        <tr>
                            <th class="py-3 px-4 border-0">Mã Đơn</th>
                            <th class="py-3 px-4 border-0">Ngày Đặt</th>
                            <th class="py-3 px-4 border-0">Tổng Tiền</th>
                            <th class="py-3 px-4 border-0">Thanh Toán</th>
                            <th class="py-3 px-4 border-0">Trạng Thái</th>
                            <th class="py-3 px-4 border-0 text-end">Hành Động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in filteredOrders)
                        {
                            <tr class="border-bottom">
                                <td class="py-3 px-4 fw-bold" style="color: var(--primary-color);">#@o.OrderNumber</td>
                                <td class="py-3 px-4">@o.CreatedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="py-3 px-4 fw-bold">@o.TotalAmount.ToString("N0") ₫</td>
                                <td class="py-3 px-4">
                                    <span class="badge rounded-pill @(o.PaymentStatus == "PAID" ? "bg-success" : "bg-warning text-dark")">
                                        @o.PaymentStatus
                                    </span>
                                </td>
                                <td class="py-3 px-4">
                                    <span class="badge bg-primary rounded-pill">@o.Status</span>
                                </td>
                                <td class="py-3 px-4 text-end">
                                    <button class="btn btn-sm btn-outline-primary px-3" @onclick='() => NavigationManager.NavigateTo($"/orders/{o.Id}")'>
                                        Xem Chi Tiết & Xử Lý
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@code {
    private IEnumerable<OrderDto>? allOrders;
    private IEnumerable<OrderDto> filteredOrders = Array.Empty<OrderDto>();
    private bool isLoading = true;
    private string? errorMessage;
    private string currentTab = "ALL";

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            allOrders = await OrderService.GetMyOrdersAsync();
            FilterData();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ChangeTab(string tab)
    {
        currentTab = tab;
        FilterData();
    }

    private void FilterData()
    {
        if (allOrders == null) return;
        
        if (currentTab == "ALL")
        {
            filteredOrders = allOrders;
        }
        else
        {
            filteredOrders = allOrders.Where(o => o.Status == currentTab);
        }
    }

    private string GetTabClass(string tab)
    {
        return currentTab == tab ? "active fw-bold" : "text-muted";
    }
}
