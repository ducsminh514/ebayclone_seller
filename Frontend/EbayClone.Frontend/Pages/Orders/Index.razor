@page "/orders"
@using EbayClone.Domain.Entities
@using EbayClone.Frontend.Services
@using EbayClone.Application.DTOs.Orders
@inject OrderService OrderService
@inject NavigationManager NavigationManager

<div class="seller-hub-container">
    <div class="seller-hub-header">
        <h1 class="seller-hub-title">Manage orders</h1>
    </div>
    
    @* Tabs for Order Status *@
    <div class="nav-ebay-tabs">
        <button class="nav-link @(currentTab == "ALL" ? "active" : "")" @onclick='() => ChangeTab("ALL")'>All (@(allOrders?.Count() ?? 0))</button>
        <button class="nav-link @(currentTab == "PENDING_PAYMENT" ? "active" : "")" @onclick='() => ChangeTab("PENDING_PAYMENT")'>Awaiting payment (@(allOrders?.Count(o => o.Status == "PENDING_PAYMENT") ?? 0))</button>
        <button class="nav-link @(currentTab == "READY_TO_SHIP" ? "active" : "")" @onclick='() => ChangeTab("READY_TO_SHIP")'>Awaiting shipment (@(allOrders?.Count(o => o.Status == "READY_TO_SHIP") ?? 0))</button>
        <button class="nav-link @(currentTab == "SHIPPED" ? "active" : "")" @onclick='() => ChangeTab("SHIPPED")'>Paid and shipped (@(allOrders?.Count(o => o.Status == "SHIPPED") ?? 0))</button>
        <button class="nav-link @(currentTab == "DELIVERED" ? "active" : "")" @onclick='() => ChangeTab("DELIVERED")'>Completed (@(allOrders?.Count(o => o.Status == "DELIVERED") ?? 0))</button>
    </div>

    @* Search & Filter Section *@
    <div class="search-container">
        <div class="search-title">
            <i class="bi bi-search"></i> Search orders
        </div>
        <div class="filter-grid">
            <div class="filter-item">
                <label>Order number or Buyer ID</label>
                <input type="text" class="ebay-input" placeholder="Search orders..." @bind="searchQuery" @bind:event="oninput" />
            </div>
            <div class="filter-item">
                <label>Period</label>
                <select class="ebay-select">
                    <option>Last 90 days</option>
                    <option>This month</option>
                </select>
            </div>
        </div>
        <div class="action-bar" style="margin-top: 20px;">
            <button class="btn-ebay-primary" @onclick="FilterData">Search</button>
            <a href="javascript:void(0)" style="font-size: 13px; color: var(--seller-hub-link); margin-left: 15px;">Advanced search</a>
            <span style="border-left: 1px solid #ccc; margin: 0 10px; height: 15px;"></span>
            <a href="javascript:void(0)" style="font-size: 13px; color: var(--seller-hub-link);" @onclick='() => { searchQuery = null; FilterData(); }'>Clear all</a>
        </div>
    </div>

    @* Table Content *@
    <div class="seller-hub-table-wrapper">
        @if (isLoading)
        {
            <div class="p-5 text-center text-muted">
                <div class="spinner-border text-primary" role="status"></div>
                <div class="mt-2">Loading orders...</div>
            </div>
        }
        else if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert alert-danger m-3">@errorMessage</div>
        }
        else if (!filteredOrders.Any())
        {
            <div class="p-5 text-center text-muted">
                <i class="bi bi-inbox" style="font-size: 48px;"></i>
                <p class="mt-3">No orders found matching your criteria.</p>
            </div>
        }
        else
        {
            <table class="seller-hub-table">
                <thead>
                    <tr>
                        <th style="width: 150px;">Order number</th>
                        <th style="width: 150px;">Date</th>
                        <th style="width: 120px;">Total</th>
                        <th>Payment status</th>
                        <th>Order status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var o in filteredOrders)
                    {
                        <tr>
                            <td class="fw-bold"><a href="/orders/@o.Id">#@o.OrderNumber</a></td>
                            <td>@o.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                            <td class="price-text">@o.TotalAmount.ToString("N0") ₫</td>
                            <td>
                                <span class="status-badge @(o.PaymentStatus == "PAID" ? "status-active" : "status-draft")">
                                    @o.PaymentStatus
                                </span>
                            </td>
                            <td>
                                <span class="status-badge @GetStatusClass(o.Status)">@o.Status</span>
                            </td>
                            <td class="text-end">
                                <button class="btn-ebay-secondary btn-sm" @onclick='() => NavigationManager.NavigateTo($"/orders/{o.Id}")'>
                                    View details
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private IEnumerable<OrderDto>? allOrders;
    private IEnumerable<OrderDto> filteredOrders = Array.Empty<OrderDto>();
    private bool isLoading = true;
    private string? errorMessage;
    private string currentTab = "ALL";
    private string? searchQuery;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            allOrders = await OrderService.GetMyOrdersAsync();
            FilterData();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ChangeTab(string tab)
    {
        currentTab = tab;
        FilterData();
    }

    private void FilterData()
    {
        if (allOrders == null) return;
        
        var query = allOrders.AsEnumerable();

        if (currentTab != "ALL")
        {
            query = query.Where(o => o.Status == currentTab);
        }

        if (!string.IsNullOrEmpty(searchQuery))
        {
            query = query.Where(o => o.OrderNumber.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) || 
                                   (o.Id.ToString().Contains(searchQuery, StringComparison.OrdinalIgnoreCase)));
        }

        filteredOrders = query.ToList();
    }

    private string GetStatusClass(string status)
    {
        return status switch
        {
            "DELIVERED" => "status-active",
            "SHIPPED" => "status-sold",
            "CANCELLED" => "status-draft",
            _ => "status-sold"
        };
    }
}
