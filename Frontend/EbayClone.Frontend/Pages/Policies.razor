@page "/policies"
@inject EbayClone.Frontend.Services.PolicyService PolicyService
@using EbayClone.Application.DTOs.Policies

<PageTitle>Business Policies - Ebay Seller Hub</PageTitle>

<div class="seller-hub-container">
    <div class="seller-hub-header mb-4">
        <h1 class="seller-hub-title">Business policies</h1>
        <p class="text-muted mt-2">Business policies are your payment, shipping, and return terms. By setting these up, you can list items faster and manage your terms across hundreds of listings at once.</p>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-4">
            <i class="bi bi-x-circle-fill me-2"></i> @errorMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success mb-4">
            <i class="bi bi-check-circle-fill me-2"></i> @successMessage
        </div>
    }

    <div class="policy-form-grid row g-4">
        <!-- Form Shipping Policy -->
        <div class="col-lg-6">
            <div class="summary-card h-100 p-4">
                <div class="d-flex align-items-center mb-4">
                    <div class="summary-card-icon me-3">
                        <i class="bi bi-truck" style="font-size: 24px; color: #0053a0;"></i>
                    </div>
                    <h2 class="order-section-title mb-0">Create shipping policy</h2>
                </div>
                <EditForm Model="shippingModel" OnValidSubmit="HandleCreateShippingPolicy">
                    <DataAnnotationsValidator />
                    
                    <div class="mb-3">
                        <label class="fw-600 mb-1 small text-dark">Policy name <span class="text-danger">*</span></label>
                        <InputText @bind-Value="shippingModel.Name" class="ebay-input" placeholder="e.g. Standard Shipping" />
                        <ValidationMessage For="@(() => shippingModel.Name)" />
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="fw-600 mb-1 small text-dark">Handling time (Days) *</label>
                            <InputNumber @bind-Value="shippingModel.HandlingTimeDays" class="ebay-input" />
                        </div>
                        <div class="col-6">
                            <label class="fw-600 mb-1 small text-dark">Shipping cost (₫) *</label>
                            <InputNumber @bind-Value="shippingModel.Cost" class="ebay-input" />
                        </div>
                    </div>

                    <div class="mb-4">
                        <div class="form-check">
                            <InputCheckbox @bind-Value="shippingModel.IsDefault" id="isDefaultPolicy" class="form-check-input" />
                            <label for="isDefaultPolicy" class="form-check-label cursor-pointer fw-500 small">Set as default shipping policy</label>
                        </div>
                    </div>

                    <button type="submit" class="btn-ebay-primary w-100 py-2" disabled="@isSubmittingShipping">
                        @(isSubmittingShipping ? "Saving..." : "Save shipping policy")
                    </button>
                </EditForm>
            </div>
        </div>

        <!-- Form Return Policy -->
        <div class="col-lg-6">
            <div class="summary-card h-100 p-4">
                <div class="d-flex align-items-center mb-4">
                    <div class="summary-card-icon me-3">
                        <i class="bi bi-arrow-counterclockwise" style="font-size: 24px; color: #0053a0;"></i>
                    </div>
                    <h2 class="order-section-title mb-0">Create return policy</h2>
                </div>
                <EditForm Model="returnModel" OnValidSubmit="HandleCreateReturnPolicy">
                    <DataAnnotationsValidator />
                    
                    <div class="mb-3">
                        <label class="fw-600 mb-1 small text-dark">Policy name <span class="text-danger">*</span></label>
                        <InputText @bind-Value="returnModel.Name" class="ebay-input" placeholder="e.g. 30-Day Returns" />
                        <ValidationMessage For="@(() => returnModel.Name)" />
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="fw-600 mb-1 small text-dark">Return window (Days) *</label>
                            <InputNumber @bind-Value="returnModel.ReturnDays" class="ebay-input" placeholder="0 = No returns" />
                        </div>
                        <div class="col-6">
                            <label class="fw-600 mb-1 small text-dark">Paid by *</label>
                            <InputSelect @bind-Value="returnModel.ShippingPaidBy" class="ebay-input bg-white">
                                <option value="">Select option</option>
                                <option value="BUYER">Buyer</option>
                                <option value="SELLER">Seller (Free)</option>
                            </InputSelect>
                        </div>
                    </div>

                    <div style="height: 42px;"></div> <!-- Spacer to match layout height -->

                    <button type="submit" class="btn-ebay-primary w-100 py-2" disabled="@isSubmittingReturn">
                        @(isSubmittingReturn ? "Saving..." : "Save return policy")
                    </button>
                </EditForm>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <h2 class="order-section-title">Shipping policies</h2>
        <div class="seller-hub-table-wrapper mb-5">
            <table class="seller-hub-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Handling time</th>
                        <th>Cost</th>
                        <th style="width: 100px;">Default</th>
                    </tr>
                </thead>
                <tbody>
                    @if (shippingPolicies == null)
                    {
                        <tr><td colspan="4" class="text-center p-4">Loading...</td></tr>
                    }
                    else if (!shippingPolicies.Any())
                    {
                        <tr><td colspan="4" class="text-center p-4 text-muted">No shipping policies found.</td></tr>
                    }
                    else
                    {
                        @foreach (var policy in shippingPolicies)
                        {
                            <tr>
                                <td class="fw-500">@policy.Name</td>
                                <td>@policy.HandlingTimeDays days</td>
                                <td class="price-text">@policy.Cost.ToString("N0") ₫</td>
                                <td>
                                    @if (policy.IsDefault)
                                    {
                                        <span class="status-badge status-active">Default</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <h2 class="order-section-title">Return policies</h2>
        <div class="seller-hub-table-wrapper">
            <table class="seller-hub-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Return window</th>
                        <th>Shipping paid by</th>
                    </tr>
                </thead>
                <tbody>
                    @if (returnPolicies == null)
                    {
                        <tr><td colspan="3" class="text-center p-4">Loading...</td></tr>
                    }
                    else if (!returnPolicies.Any())
                    {
                        <tr><td colspan="3" class="text-center p-4 text-muted">No return policies found.</td></tr>
                    }
                    else
                    {
                        @foreach (var policy in returnPolicies)
                        {
                            <tr>
                                <td class="fw-500">@policy.Name</td>
                                <td>@(policy.ReturnDays == 0 ? "No returns" : $"{policy.ReturnDays} days")</td>
                                <td><span class="status-badge @(policy.ShippingPaidBy == "SELLER" ? "status-active" : "status-draft")">@policy.ShippingPaidBy</span></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    private CreateShippingPolicyRequest shippingModel = new() { HandlingTimeDays = 2, Cost = 0, IsDefault = true };
    private CreateReturnPolicyRequest returnModel = new() { ReturnDays = 30 };
    
    private IEnumerable<ShippingPolicyDto>? shippingPolicies;
    private IEnumerable<ReturnPolicyDto>? returnPolicies;

    private bool isSubmittingShipping = false;
    private bool isSubmittingReturn = false;
    
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadPoliciesAsync();
    }

    private async Task LoadPoliciesAsync()
    {
        try
        {
            shippingPolicies = await PolicyService.GetShippingPoliciesAsync();
            returnPolicies = await PolicyService.GetReturnPoliciesAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            shippingPolicies ??= Array.Empty<ShippingPolicyDto>();
            returnPolicies ??= Array.Empty<ReturnPolicyDto>();
        }
    }

    private async Task HandleCreateShippingPolicy()
    {
        isSubmittingShipping = true;
        ClearMessages();

        try
        {
            var msg = await PolicyService.CreateShippingPolicyAsync(shippingModel);
            successMessage = msg;
            shippingModel = new() { HandlingTimeDays = 2, Cost = 0, IsDefault = false }; // Reset
            await LoadPoliciesAsync(); // Mới thêm: Refresh List Data sau khi tạo Create Update Delete
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmittingShipping = false;
        }
    }

    private async Task HandleCreateReturnPolicy()
    {
        isSubmittingReturn = true;
        ClearMessages();

        try
        {
            var msg = await PolicyService.CreateReturnPolicyAsync(returnModel);
            successMessage = msg;
            returnModel = new() { ReturnDays = 30 }; // Reset
            await LoadPoliciesAsync(); // Refresh Return List
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmittingReturn = false;
        }
    }

    private void ClearMessages()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }
}
