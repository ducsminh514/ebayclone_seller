@page "/settings"
@inject EbayClone.Frontend.Services.PolicyService PolicyService
@using EbayClone.Application.DTOs.Policies

<PageTitle>Business Policies - Ebay Seller Hub</PageTitle>

<div class="ebay-page-title" style="display: flex; justify-content: space-between; align-items: center;">
    <span>Business Policies</span>
</div>

<p style="color: var(--text-secondary); margin-bottom: 24px;">Business policies are your payment, pricing, and return terms. By setting these up, you can list items faster and manage your terms across hundreds of listings at once.</p>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div style="background-color: #fee; color: var(--danger-color); padding: 12px 16px; border-radius: 4px; border: 1px solid var(--danger-color); margin-bottom: 24px; font-weight: 500;">
        <i class="oi oi-circle-x" style="margin-right: 8px;"></i> @errorMessage
    </div>
}

@if (!string.IsNullOrEmpty(successMessage))
{
    <div style="background-color: #e6ffed; color: var(--success-color); padding: 12px 16px; border-radius: 4px; border: 1px solid var(--success-color); margin-bottom: 24px; font-weight: 500;">
        <i class="oi oi-circle-check" style="margin-right: 8px;"></i> @successMessage
    </div>
}

<div style="display: flex; gap: 32px;">
    <!-- Form Shipping Policy -->
    <div class="ebay-card" style="flex: 1;">
        <h3 style="margin-top: 0; margin-bottom: 16px;">Create Shipping Policy</h3>
        <EditForm Model="shippingModel" OnValidSubmit="HandleCreateShippingPolicy">
            <DataAnnotationsValidator />
            
            <div style="margin-bottom: 16px;">
                <label style="display: block; font-weight: 600; margin-bottom: 8px;">Policy Name <span style="color: var(--danger-color);">*</span></label>
                <InputText @bind-Value="shippingModel.Name" placeholder="e.g. Standard Shipping" style="width: 100%; padding: 10px; border: 1px solid var(--border-color); border-radius: var(--border-radius-sm); outline: none;" />
                <ValidationMessage For="@(() => shippingModel.Name)" />
            </div>

            <div style="margin-bottom: 16px;">
                <label style="display: block; font-weight: 600; margin-bottom: 8px;">Handling Time (Days) <span style="color: var(--danger-color);">*</span></label>
                <InputNumber @bind-Value="shippingModel.HandlingTimeDays" style="width: 100%; padding: 10px; border: 1px solid var(--border-color); border-radius: var(--border-radius-sm); outline: none;" />
                <ValidationMessage For="@(() => shippingModel.HandlingTimeDays)" />
            </div>

            <div style="margin-bottom: 16px;">
                <label style="display: block; font-weight: 600; margin-bottom: 8px;">Shipping Cost ($) <span style="color: var(--danger-color);">*</span></label>
                <InputNumber @bind-Value="shippingModel.Cost" style="width: 100%; padding: 10px; border: 1px solid var(--border-color); border-radius: var(--border-radius-sm); outline: none;" />
                <ValidationMessage For="@(() => shippingModel.Cost)" />
            </div>

            <div style="margin-bottom: 24px; display: flex; align-items: center;">
                <InputCheckbox @bind-Value="shippingModel.IsDefault" id="isDefaultPolicy" style="margin-right: 8px;" />
                <label for="isDefaultPolicy" style="font-weight: 500; cursor: pointer;">Set as default shipping policy</label>
            </div>

            <button type="submit" disabled="@isSubmittingShipping" style="width: 100%; padding: 10px; background-color: var(--primary-color); color: white; border: none; border-radius: 20px; font-weight: 600; cursor: pointer; opacity: @(isSubmittingShipping ? 0.7 : 1);">
                @(isSubmittingShipping ? "Creating..." : "Save Policy")
            </button>
        </EditForm>
    </div>

    <!-- Form Return Policy -->
    <div class="ebay-card" style="flex: 1;">
        <h3 style="margin-top: 0; margin-bottom: 16px;">Create Return Policy</h3>
        <EditForm Model="returnModel" OnValidSubmit="HandleCreateReturnPolicy">
            <DataAnnotationsValidator />
            
            <div style="margin-bottom: 16px;">
                <label style="display: block; font-weight: 600; margin-bottom: 8px;">Policy Name <span style="color: var(--danger-color);">*</span></label>
                <InputText @bind-Value="returnModel.Name" placeholder="e.g. 30-Day Returns" style="width: 100%; padding: 10px; border: 1px solid var(--border-color); border-radius: var(--border-radius-sm); outline: none;" />
                <ValidationMessage For="@(() => returnModel.Name)" />
            </div>

            <div style="margin-bottom: 16px;">
                <label style="display: block; font-weight: 600; margin-bottom: 8px;">Return Window (Days) <span style="color: var(--danger-color);">*</span></label>
                <InputNumber @bind-Value="returnModel.ReturnDays" placeholder="0 = No Returns allowed" style="width: 100%; padding: 10px; border: 1px solid var(--border-color); border-radius: var(--border-radius-sm); outline: none;" />
                <ValidationMessage For="@(() => returnModel.ReturnDays)" />
            </div>

            <div style="margin-bottom: 24px;">
                <label style="display: block; font-weight: 600; margin-bottom: 8px;">Return shipping paid by <span style="color: var(--danger-color);">*</span></label>
                <InputSelect @bind-Value="returnModel.ShippingPaidBy" style="width: 100%; padding: 10px; border: 1px solid var(--border-color); border-radius: var(--border-radius-sm); outline: none; background-color: white;">
                    <option value="">Select an option</option>
                    <option value="BUYER">Buyer</option>
                    <option value="SELLER">Seller (Free Returns)</option>
                </InputSelect>
                <ValidationMessage For="@(() => returnModel.ShippingPaidBy)" />
            </div>

            <button type="submit" disabled="@isSubmittingReturn" style="width: 100%; padding: 10px; background-color: var(--primary-color); color: white; border: none; border-radius: 20px; font-weight: 600; cursor: pointer; opacity: @(isSubmittingReturn ? 0.7 : 1);">
                @(isSubmittingReturn ? "Creating..." : "Save Policy")
            </button>
        </EditForm>
    </div>
</div>

@code {
    private CreateShippingPolicyRequest shippingModel = new() { HandlingTimeDays = 2, Cost = 0, IsDefault = true };
    private CreateReturnPolicyRequest returnModel = new() { ReturnDays = 30 };
    
    private bool isSubmittingShipping = false;
    private bool isSubmittingReturn = false;
    
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private async Task HandleCreateShippingPolicy()
    {
        isSubmittingShipping = true;
        ClearMessages();

        try
        {
            var msg = await PolicyService.CreateShippingPolicyAsync(shippingModel);
            successMessage = msg;
            shippingModel = new() { HandlingTimeDays = 2, Cost = 0, IsDefault = false }; // Reset
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmittingShipping = false;
        }
    }

    private async Task HandleCreateReturnPolicy()
    {
        isSubmittingReturn = true;
        ClearMessages();

        try
        {
            var msg = await PolicyService.CreateReturnPolicyAsync(returnModel);
            successMessage = msg;
            returnModel = new() { ReturnDays = 30 }; // Reset
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmittingReturn = false;
        }
    }

    private void ClearMessages()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;
    }
}
