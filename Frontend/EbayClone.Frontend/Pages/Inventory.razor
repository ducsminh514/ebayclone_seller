@page "/inventory"
@using EbayClone.Domain.Entities
@using EbayClone.Frontend.Services
@inject ProductService ProductService
@inject NavigationManager NavigationManager

<div class="seller-hub-container">
    <div class="seller-hub-header mb-4">
        <div>
            <h1 class="seller-hub-title mb-1">Inventory Management</h1>
            <p class="text-muted mb-0">Track and update stock levels for each SKU.</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="p-4 text-center text-muted">
            <span class="spinner-border spinner-border-sm me-2"></span> Đang tải dữ liệu tồn kho...
        </div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else if (products == null || !products.Any())
    {
        <div class="ebay-card p-5 text-center text-muted">
            <h5>Chưa có sản phẩm nào trong kho.</h5>
            <p>Hãy tạo sản phẩm và thêm biến thể để quản lý tồn kho.</p>
        </div>
    }
    else
    {
        <!-- Summary Cards -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="summary-card p-3 text-center mb-0" style="border-top: 3px solid #0053a0;">
                    <div class="value" style="font-size: 28px;">@totalProducts</div>
                    <div class="footer text-uppercase fw-600" style="font-size: 10px;">Total Products</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="summary-card p-3 text-center mb-0" style="border-top: 3px solid #1a7d32;">
                    <div class="value" style="font-size: 28px; color: #1a7d32;">@totalSkus</div>
                    <div class="footer text-uppercase fw-600" style="font-size: 10px;">Total SKUs</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="summary-card p-3 text-center mb-0" style="border-top: 3px solid #ff8500;">
                    <div class="value" style="font-size: 28px; color: #ff8500;">@lowStockSkus</div>
                    <div class="footer text-uppercase fw-600" style="font-size: 10px;">Low Stock (&lt;5)</div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="summary-card p-3 text-center mb-0" style="border-top: 3px solid #dd1e31;">
                    <div class="value" style="font-size: 28px; color: #dd1e31;">@outOfStockSkus</div>
                    <div class="footer text-uppercase fw-600" style="font-size: 10px;">Out of Stock</div>
                </div>
            </div>
        </div>

        <!-- Product Table with Expand -->
        <div class="summary-card p-0 overflow-hidden mb-5">
            <table class="seller-hub-table table-hover">
                <thead>
                    <tr>
                        <th style="width: 40px;"></th>
                        <th>Product</th>
                        <th>Brand</th>
                        <th class="text-center">SKUs</th>
                        <th class="text-center">Available</th>
                        <th class="text-center">Stock status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in products)
                    {
                        var totalAvailable = p.Variants?.Sum(v => Math.Max(0, v.Quantity - v.ReservedQuantity)) ?? 0;
                        var skuCount = p.Variants?.Count ?? 0;
                        var isExpanded = expandedProductIds.Contains(p.Id);
                        var lowStock = p.Variants?.Count(v => { var a = v.Quantity - v.ReservedQuantity; return a > 0 && a < 5; }) ?? 0;
                        var outStock = p.Variants?.Count(v => (v.Quantity - v.ReservedQuantity) <= 0) ?? 0;
 
                        <!-- Product Row -->
                        <tr style="cursor: pointer;" @onclick="() => ToggleExpand(p.Id)">
                            <td class="text-center">
                                <i class="bi bi-chevron-right" style="font-size: 12px; transition: transform 0.2s; display: inline-block; transform: rotate(@(isExpanded ? "90deg" : "0deg"));"></i>
                            </td>
                            <td><span class="fw-600 text-primary">@p.Name</span></td>
                            <td class="text-muted">@(p.Brand ?? "-")</td>
                            <td class="text-center">
                                <span class="badge bg-light text-dark border">@skuCount</span>
                            </td>
                            <td class="text-center">
                                <span class="fw-bold @(totalAvailable > 0 ? "text-success" : "text-danger")">@totalAvailable</span>
                            </td>
                            <td class="text-center">
                                @if (outStock == skuCount && skuCount > 0)
                                {
                                    <span class="status-badge status-draft">Out of stock</span>
                                }
                                else if (outStock > 0 || lowStock > 0)
                                {
                                    <span class="status-badge" style="background: #fff8e1; color: #f57c00;">Low stock alert</span>
                                }
                                else
                                {
                                    <span class="status-badge status-active">Stable</span>
                                }
                            </td>
                            <td class="text-end" @onclick:stopPropagation="true">
                                <button class="btn-ebay-secondary btn-sm px-3" @onclick='() => NavigationManager.NavigateTo($"/inventory/{p.Id}")'>
                                    Details
                                </button>
                            </td>
                        </tr>
 
                        <!-- Expanded Quick View -->
                        @if (isExpanded && p.Variants != null && p.Variants.Any())
                        {
                            <tr>
                                <td colspan="7" class="p-0 border-0" style="background: #fcfdfe;">
                                    <div class="px-5 py-3 border-top border-bottom">
                                        <div class="row g-3">
                                            @foreach (var v in p.Variants)
                                            {
                                                var available = v.Quantity - v.ReservedQuantity;
                                                var barColor = available <= 0 ? "#dd1e31" : available < 5 ? "#ff8500" : "#1a7d32";
                                                var barPercent = v.Quantity > 0 ? (int)Math.Round((double)available / v.Quantity * 100) : 0;
 
                                                <div class="col-md-6 col-lg-4">
                                                    <div class="summary-card p-3 mb-0" style="border-left: 3px solid @barColor; border-radius: 4px;">
                                                        <!-- SKU Header -->
                                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                                            <span class="fw-600 small">@v.SkuCode</span>
                                                            @if (available <= 0)
                                                            {
                                                                <span class="status-badge status-draft py-0" style="font-size: 10px;">OUT</span>
                                                            }
                                                            else if (available < 5)
                                                            {
                                                                <span class="status-badge py-0" style="font-size: 10px; background: #fff8e1; color: #f57c00;">LOW</span>
                                                            }
                                                            else
                                                            {
                                                                <span class="status-badge status-active py-0" style="font-size: 10px;">OK</span>
                                                            }
                                                        </div>
 
                                                        @if (!string.IsNullOrEmpty(v.Attributes))
                                                        {
                                                            <div class="text-muted mb-2 small" style="opacity: 0.8;">@v.Attributes</div>
                                                        }
 
                                                        <!-- Stock Numbers -->
                                                        <div class="d-flex justify-content-between mb-2">
                                                            <div class="text-center">
                                                                <div class="fw-bold" style="font-size: 14px;">@v.Quantity</div>
                                                                <div class="text-muted" style="font-size: 9px; text-transform: uppercase;">Total</div>
                                                            </div>
                                                            <div class="text-center px-3 border-start border-end">
                                                                <div class="fw-bold text-warning" style="font-size: 14px;">@v.ReservedQuantity</div>
                                                                <div class="text-muted" style="font-size: 9px; text-transform: uppercase;">Reserved</div>
                                                            </div>
                                                            <div class="text-center">
                                                                <div class="fw-bold" style="font-size: 14px; color: @barColor;">@available</div>
                                                                <div class="text-muted" style="font-size: 9px; text-transform: uppercase;">Avail</div>
                                                            </div>
                                                        </div>
 
                                                        <!-- Mini Progress Bar -->
                                                        <div class="progress mb-2" style="height: 3px; border-radius: 0;">
                                                            <div class="progress-bar" style="width: @barPercent%; background-color: @barColor;"></div>
                                                        </div>
 
                                                        <!-- Inline Restock -->
                                                        <div class="d-flex gap-2 align-items-center pt-2 mt-1 border-top">
                                                            <input type="number" class="ebay-input-sm flex-fill" placeholder="+Qty" min="1"
                                                                   style="height: 28px; font-size: 12px;"
                                                                   value="@(inlineRestockQty.ContainsKey(v.Id) && inlineRestockQty[v.Id] > 0 ? inlineRestockQty[v.Id] : "")"
                                                                   @onclick:stopPropagation="true"
                                                                   @onchange="@((ChangeEventArgs e) => OnInlineQtyChanged(v.Id, e.Value?.ToString()))" />
                                                            <button class="btn btn-sm @(isRestockingVariantId == v.Id ? "btn-secondary" : "btn-success") py-0 px-2" 
                                                                    style="height: 28px; font-size: 11px;"
                                                                    disabled="@(isRestockingVariantId == v.Id)"
                                                                    @onclick:stopPropagation="true"
                                                                    @onclick="() => InlineRestock(v.Id)">
                                                                @if (isRestockingVariantId == v.Id) { <span class="spinner-border spinner-border-sm" style="width:10px; height:10px;"></span> }
                                                                else { <span>Restock</span> }
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private IEnumerable<Product>? products;
    private bool isLoading = true;
    private string? errorMessage;

    // Expand state
    private HashSet<Guid> expandedProductIds = new();

    // Inline Restock
    private Dictionary<Guid, int> inlineRestockQty = new();
    private Guid? isRestockingVariantId = null;

    // Computed Summary
    private int totalProducts => products?.Count() ?? 0;
    private int totalSkus => products?.Sum(p => p.Variants?.Count ?? 0) ?? 0;
    private int lowStockSkus => products?.Sum(p => p.Variants?.Count(v =>
    {
        var avail = v.Quantity - v.ReservedQuantity;
        return avail > 0 && avail < 5;
    }) ?? 0) ?? 0;
    private int outOfStockSkus => products?.Sum(p => p.Variants?.Count(v => (v.Quantity - v.ReservedQuantity) <= 0) ?? 0) ?? 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            products = await ProductService.GetMyProductsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ToggleExpand(Guid productId)
    {
        if (expandedProductIds.Contains(productId))
            expandedProductIds.Remove(productId);
        else
            expandedProductIds.Add(productId);
    }

    private void OnInlineQtyChanged(Guid variantId, string? val)
    {
        if (int.TryParse(val, out int num) && num > 0)
            inlineRestockQty[variantId] = num;
        else
            inlineRestockQty.Remove(variantId);
    }

    private async Task InlineRestock(Guid variantId)
    {
        if (!inlineRestockQty.ContainsKey(variantId) || inlineRestockQty[variantId] <= 0)
            return;

        isRestockingVariantId = variantId;
        StateHasChanged();

        try
        {
            await ProductService.RestockVariantAsync(variantId, inlineRestockQty[variantId]);
            products = await ProductService.GetMyProductsAsync();
            inlineRestockQty.Remove(variantId);
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi nhập kho: {ex.Message}";
        }
        finally
        {
            isRestockingVariantId = null;
        }
    }
}
