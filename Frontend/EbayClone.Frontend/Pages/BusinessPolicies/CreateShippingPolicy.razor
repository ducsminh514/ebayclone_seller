@page "/bp/shp/create"
@layout PolicyCreationLayout
@using EbayClone.Shared.DTOs.Policies
@using EbayClone.Frontend.Services
@using EbayClone.Frontend.Pages.BusinessPolicies.Components
@using MudBlazor
@using System.ComponentModel.DataAnnotations
@inject PolicyService PolicyService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject IDialogService DialogService

<EditForm Model="@_model" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    
    <!-- Top Section: Header -->
    <MudGrid Justify="Justify.SpaceBetween" Class="mb-6 align-center">
        <MudItem>
            <MudText Typo="Typo.h4" Style="font-family: 'Times New Roman', serif; font-weight: bold;">Create shipping policy</MudText>
        </MudItem>
        <MudItem>
            <MudLink Href="#" Underline="Underline.Hover" Style="color: #111820; text-decoration: underline; font-size: 13px;">How to set up shipping policy?</MudLink>
        </MudItem>
    </MudGrid>

    <div style="max-width: 800px;">
        <!-- Policy Name -->
        <MudText Typo="Typo.body2" Class="mb-1 fw-bold" Style="font-weight: 600; color: #111820;">Policy name</MudText>
        <MudTextField @bind-Value="_model.Name" Immediate="true" Variant="Variant.Filled" Underline="false" MaxLength="64" Style="border-radius: 8px; border: 1px solid #c7c7c7; background-color: #F7F7F7;" Class="mb-1" />
        <MudGrid Justify="Justify.SpaceBetween" Class="mt-n1 mb-4">
            <MudItem><MudText Typo="Typo.caption" Style="color: #707070;">Example: Free domestic shipping</MudText></MudItem>
            <MudItem><MudText Typo="Typo.caption" Style="color: #707070;">@(_model.Name?.Length ?? 0)/64</MudText></MudItem>
        </MudGrid>
        <ValidationMessage For="@(() => _model.Name)" />

        <!-- Description -->
        <MudText Typo="Typo.body2" Class="mb-1 mt-6 fw-bold" Style="font-weight: 600; color: #111820;">Policy description (optional)</MudText>
        <MudTextField @bind-Value="_model.Description" Immediate="true" Variant="Variant.Filled" Underline="false" Lines="4" MaxLength="250" Style="border-radius: 8px; border: 1px solid #c7c7c7; background-color: #F7F7F7;" Class="mb-1" />
        <MudGrid Justify="Justify.SpaceBetween" Class="mt-n1 mb-8">
            <MudItem><MudText Typo="Typo.caption" Style="color: #707070;">Additional text to help you identify the content of this policy</MudText></MudItem>
            <MudItem><MudText Typo="Typo.caption" Style="color: #707070;">@(_model.Description?.Length ?? 0)/250</MudText></MudItem>
        </MudGrid>

        <MudCheckBox @bind-Value="_model.IsDefault" Label="Set as default shipping policy" Color="Color.Primary" Class="mb-8" />

        <!-- DOMESTIC SHIPPING SECTION -->
        <MudText Typo="Typo.subtitle1" Class="fw-bolder mt-8 mb-4" Style="font-weight: 900; letter-spacing: 0.5px;">DOMESTIC SHIPPING</MudText>
        
        <div class="mb-6">
            <MudText Typo="Typo.body2" Class="mb-1" Style="color: #111820; font-weight: 600;">Cost type</MudText>
            <MudSelect @bind-Value="_model.DomesticCostType" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 400px; border-radius: 8px; background-color: white;">
                <MudSelectItem Value="@("Flat")">Flat: Same cost to all buyers</MudSelectItem>
                <MudSelectItem Value="@("Calculated")">Calculated: Cost varies by buyer location</MudSelectItem>
                <MudSelectItem Value="@("NoShipping")">No shipping: Local pickup only</MudSelectItem>
            </MudSelect>
        </div>

        @if (_model.DomesticCostType != "NoShipping")
        {
            <div class="mb-6">
                <MudText Typo="Typo.body2" Class="mb-2" Style="color: #111820; font-weight: 600;">Services</MudText>
                @if (_model.DomesticServices.Any())
                {
                    @foreach (var svc in _model.DomesticServices)
                    {
                        <div class="pa-4 mb-3" style="border: 1px solid #efefef; border-radius: 8px; background-color: white;">
                            <MudGrid AlignItems="AlignItems.Center">
                                <MudItem xs="6">
                                    <MudText Typo="Typo.body2" Style="font-weight: bold;">@svc.ServiceName</MudText>
                                </MudItem>
                                <MudItem xs="2">
                                    <MudTextField @bind-Value="svc.Cost" Label="Cost" Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentText="$" />
                                </MudItem>
                                <MudItem xs="3">
                                    <MudTextField @bind-Value="svc.AdditionalItemCost" Label="Each add'l" Variant="Variant.Outlined" Margin="Margin.Dense" Adornment="Adornment.Start" AdornmentText="$" />
                                </MudItem>
                                <MudItem xs="1" Class="d-flex justify-end">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" OnClick="@(() => _model.DomesticServices.Remove(svc))" Size="Size.Small" />
                                </MudItem>
                                <MudItem xs="12" Class="mt-n2">
                                    <MudCheckBox @bind-Value="svc.IsFreeShipping" Label="Free shipping" Color="Color.Primary" Dense="true" />
                                </MudItem>
                            </MudGrid>
                        </div>
                    }
                }
                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Outlined" Color="Color.Primary" OnClick="OpenDomesticServicesModal" Style="text-transform: none; border-radius: 999px;">Add services</MudButton>
            </div>

            <div class="mb-10" style="max-width: 400px;">
                <MudText Typo="Typo.body2" Class="mb-1" Style="color: #111820; font-weight: 600;">Handling time</MudText>
                <MudSelect @bind-Value="_model.HandlingTimeDays" Variant="Variant.Outlined" Margin="Margin.Dense" Style="border-radius: 8px; background-color: white;">
                    <MudSelectItem Value="0">Same business day</MudSelectItem>
                    <MudSelectItem Value="1">1 business day</MudSelectItem>
                    <MudSelectItem Value="2">2 business days</MudSelectItem>
                    <MudSelectItem Value="3">3 business days</MudSelectItem>
                    <MudSelectItem Value="5">5 business days</MudSelectItem>
                    <MudSelectItem Value="10">10 business days</MudSelectItem>
                </MudSelect>
            </div>
        }

        <!-- INTERNATIONAL SHIPPING SECTION -->
        <MudText Typo="Typo.subtitle1" Class="fw-bolder mt-8 mb-4" Style="font-weight: 900; letter-spacing: 0.5px;">INTERNATIONAL SHIPPING</MudText>
        
        <MudPaper Elevation="0" Outlined="true" Class="pa-6 rounded-lg mb-6" Style="background-color: white;">
            <MudGrid AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
                <MudItem>
                    <MudText Typo="Typo.body1" Style="font-weight: bold;">International shipping</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">Allow returns for items purchased internationally.</MudText>
                </MudItem>
                <MudItem>
                    <MudSwitch @bind-Value="_model.IsInternationalShippingAllowed" Color="Color.Primary" Size="Size.Large" />
                </MudItem>
            </MudGrid>

            @if (_model.IsInternationalShippingAllowed)
            {
                <div class="mt-6">
                    <MudText Typo="Typo.body2" Class="mb-1" Style="color: #111820; font-weight: 600;">Cost type</MudText>
                    <MudSelect @bind-Value="_model.InternationalCostType" Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 400px; border-radius: 8px;">
                        <MudSelectItem Value="@("Flat")">Flat: Same cost to all buyers</MudSelectItem>
                        <MudSelectItem Value="@("Calculated")">Calculated: Cost varies by buyer location</MudSelectItem>
                    </MudSelect>

                    <MudText Typo="Typo.body2" Class="mt-6 mb-2" Style="color: #111820; font-weight: 600;">Services</MudText>
                    @foreach (var svc in _model.InternationalServices)
                    {
                        <div class="pa-4 mb-3" style="border: 1px solid #efefef; border-radius: 8px;">
                            <MudGrid AlignItems="AlignItems.Center">
                                <MudItem xs="5">
                                    <MudText Typo="Typo.body2" Style="font-weight: bold;">@svc.ServiceName</MudText>
                                </MudItem>
                                <MudItem xs="2">
                                    <MudTextField @bind-Value="svc.Cost" Label="Cost" Variant="Variant.Outlined" Margin="Margin.Dense" />
                                </MudItem>
                                <MudItem xs="4">
                                    <MudSelect T="string" Label="Ship to" Variant="Variant.Outlined" Margin="Margin.Dense" MultiSelection="true" SelectedValues="@svc.ShipToLocations" SelectedValuesChanged="@((vals) => svc.ShipToLocations = vals.ToList())">
                                        <MudSelectItem Value="@("Worldwide")">Worldwide</MudSelectItem>
                                        <MudSelectItem Value="@("Canada")">Canada</MudSelectItem>
                                        <MudSelectItem Value="@("Europe")">Europe</MudSelectItem>
                                        <MudSelectItem Value="@("Asia")">Asia</MudSelectItem>
                                        <MudSelectItem Value="@("Australia")">Australia</MudSelectItem>
                                    </MudSelect>
                                </MudItem>
                                <MudItem xs="1">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" OnClick="@(() => _model.InternationalServices.Remove(svc))" Size="Size.Small" />
                                </MudItem>
                            </MudGrid>
                        </div>
                    }
                    <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Outlined" Color="Color.Primary" OnClick="OpenInternationalServicesModal" Style="text-transform: none; border-radius: 999px;">Add services</MudButton>
                </div>
            }
        </MudPaper>

        <!-- PREFERENCES SECTION -->
        <MudText Typo="Typo.subtitle1" Class="fw-bolder mt-8 mb-4" Style="font-weight: 900; letter-spacing: 0.5px;">PREFERENCES</MudText>
        
        <div class="mb-10">
            <MudText Typo="Typo.body2" Class="mb-1" Style="color: #111820; font-weight: 600;">Excluded locations (optional)</MudText>
            <div @onclick="OpenExcludedLocationsModal" style="cursor: pointer; border: 1px solid #c7c7c7; border-radius: 8px; padding: 12px 16px; background-color: white;" class="d-flex align-center justify-space-between">
                <MudText Typo="Typo.body2">
                    @(_model.ExcludedLocations.Any() ? string.Join(", ", _model.ExcludedLocations.Take(3)) + (_model.ExcludedLocations.Count > 3 ? "..." : "") : "None")
                </MudText>
                <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" />
            </div>
        </div>
    </div>

    <!-- Phập mông trống -->
    <div style="height: 150px;"></div>

    <!-- Sticky Footer -->
    <div style="position: fixed; bottom: 0; left: 0; right: 0; background-color: white; border-top: 1px solid #efefef; padding: 16px 24px; z-index: 100;">
        <MudContainer MaxWidth="MaxWidth.Medium" Class="px-0">
            <MudStack Row="true" Spacing="4" Justify="Justify.FlexStart">
                <MudButton Href="/bp/manage" Variant="Variant.Outlined" Color="Color.Primary" Style="border-radius: 999px; text-transform: none; font-weight: bold; border-color: #3665F3; color: #3665F3;" Class="px-6 py-2">Cancel</MudButton>
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Style="border-radius: 999px; text-transform: none; font-weight: bold; background-color: #3665F3; color: white;" Class="px-8 py-2">Save</MudButton>
            </MudStack>
            
            <MudText Typo="Typo.caption" Style="color: #707070; display: block; margin-top: 16px;">
                Copyright © 1995-2026 eBay Inc. All Rights Reserved. <MudLink Href="#" Style="color: #3665F3; text-decoration: underline;">Accessibility</MudLink>, <MudLink Href="#" Style="color: #3665F3; text-decoration: underline;">User Agreement</MudLink>
            </MudText>
        </MudContainer>
    </div>
</EditForm>

@code {
    private ShippingPolicyViewModel _model = new();
    private IEnumerable<string> _dummyShipTo = new List<string> { "Worldwide" };

    private async Task OpenDomesticServicesModal()
    {
        var parameters = new DialogParameters { ["InitialSelectedServices"] = _model.DomesticServices };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ShippingServiceModal>("", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled && result.Data is List<ShippingServiceDto> list)
        {
            _model.DomesticServices = list;
            StateHasChanged();
        }
    }

    private async Task OpenInternationalServicesModal()
    {
        var parameters = new DialogParameters { ["IsInternational"] = true, ["InitialSelectedServices"] = _model.InternationalServices.Cast<ShippingServiceDto>().ToList() };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ShippingServiceModal>("", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled && result.Data is List<ShippingServiceDto> list)
        {
            _model.InternationalServices = list.Cast<InternationalShippingServiceDto>().ToList();
            StateHasChanged();
        }
    }

    private async Task OpenExcludedLocationsModal()
    {
        var parameters = new DialogParameters { ["InitialExcludedLocations"] = _model.ExcludedLocations };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true };
        var dialog = await DialogService.ShowAsync<ExcludedLocationsModal>("", parameters, options);
        var result = await dialog.Result;
        if (!result.Canceled && result.Data is List<string> list)
        {
            _model.ExcludedLocations = list;
        }
    }

    private async Task HandleValidSubmit()
    {
        try 
        {
            var request = new CreateShippingPolicyRequest
            {
                Name = _model.Name,
                Description = _model.Description,
                HandlingTimeDays = _model.HandlingTimeDays,
                IsDefault = _model.IsDefault,
                DomesticCostType = _model.DomesticCostType,
                DomesticServices = _model.DomesticServices,
                IsInternationalShippingAllowed = _model.IsInternationalShippingAllowed,
                InternationalCostType = _model.InternationalCostType,
                InternationalServices = _model.InternationalServices,
                ExcludedLocations = _model.ExcludedLocations
            };

            var message = await PolicyService.CreateShippingPolicyAsync(request);
            Snackbar.Add(message, Severity.Success);
            NavigationManager.NavigateTo("/bp/manage");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    public class ShippingPolicyViewModel
    {
        [Required(ErrorMessage = "Policy name is required")]
        [StringLength(64)]
        public string Name { get; set; } = string.Empty;

        [StringLength(250)]
        public string Description { get; set; } = string.Empty;

        public bool IsDefault { get; set; }
        public int HandlingTimeDays { get; set; } = 2;
        public string DomesticCostType { get; set; } = "Flat";
        public List<ShippingServiceDto> DomesticServices { get; set; } = new();
        
        public bool IsInternationalShippingAllowed { get; set; }
        public string InternationalCostType { get; set; } = "Flat";
        public List<InternationalShippingServiceDto> InternationalServices { get; set; } = new();

        public List<string> ExcludedLocations { get; set; } = new();
    }
}
