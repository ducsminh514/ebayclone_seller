@using MudBlazor
@using EbayClone.Shared.DTOs.Policies

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">Add shipping services</MudText>
    </TitleContent>
    <DialogContent>
        <div style="max-height: 500px; overflow-y: auto; padding-right: 8px;">
            <MudText Typo="Typo.subtitle2" Class="mb-4" Style="font-weight: bold; color: #111820;">Domestic services</MudText>

            @foreach (var group in _displayGroups)
            {
                <MudText Typo="Typo.body2" Class="mt-4 mb-2" Style="font-weight: 600; color: #707070; text-transform: uppercase; letter-spacing: 0.5px;">@group.GroupName</MudText>
                <MudList T="string" Clickable="true">
                    @foreach (var service in group.Services)
                    {
                        <MudListItem Style="border-bottom: 1px solid #efefef; padding: 12px 0;">
                            <div class="d-flex align-center justify-space-between w-100">
                                <div class="d-flex align-center">
                                    <MudCheckBox T="bool" Value="@IsSelected(service.ServiceId)" ValueChanged="@((bool val) => ToggleService(service))" Color="Color.Primary" Dense="true" Class="mr-3" />
                                    <div @onclick="@(() => ToggleService(service))" style="cursor: pointer; flex-grow: 1;">
                                        <MudText Typo="Typo.body2" Style="font-weight: 500;">@service.ServiceName</MudText>
                                    </div>
                                </div>
                            </div>
                        </MudListItem>
                    }
                </MudList>
            }
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Variant="Variant.Text" Style="text-transform: none; font-weight: bold; color: #3665F3;">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Style="border-radius: 999px; text-transform: none; font-weight: bold; background-color: #3665F3;" Class="px-8">Add</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public List<ShippingServiceDto> InitialSelectedServices { get; set; } = new();
    [Parameter] public bool IsInternational { get; set; } = false;

    private List<ShippingServiceDto> _selectedServices = new();
    private List<ServiceGroup> _displayGroups = new();

    protected override void OnInitialized()
    {
        _selectedServices = InitialSelectedServices.ToList();
        _displayGroups = IsInternational ? _internationalServiceGroups : _domesticServiceGroups;
    }

    private bool IsSelected(string serviceId) => _selectedServices.Any(s => s.ServiceId == serviceId);

    private void ToggleService(ServiceItem item)
    {
        if (IsSelected(item.ServiceId))
        {
            _selectedServices.RemoveAll(s => s.ServiceId == item.ServiceId);
        }
        else
        {
            if (IsInternational)
            {
                _selectedServices.Add(new InternationalShippingServiceDto
                {
                    ServiceId = item.ServiceId,
                    ServiceName = item.ServiceName,
                    Cost = 0,
                    AdditionalItemCost = 0,
                    IsFreeShipping = false,
                    ShipToLocations = new List<string> { "Worldwide" }
                });
            }
            else
            {
                _selectedServices.Add(new ShippingServiceDto
                {
                    ServiceId = item.ServiceId,
                    ServiceName = item.ServiceName,
                    Cost = 0,
                    AdditionalItemCost = 0,
                    IsFreeShipping = false
                });
            }
        }
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit() => MudDialog.Close(DialogResult.Ok(_selectedServices));

    private class ServiceGroup
    {
        public string GroupName { get; set; } = string.Empty;
        public List<ServiceItem> Services { get; set; } = new();
    }

    private class ServiceItem
    {
        public string ServiceId { get; set; } = string.Empty;
        public string ServiceName { get; set; } = string.Empty;
    }

    private List<ServiceGroup> _domesticServiceGroups = new()
    {
        new ServiceGroup
        {
            GroupName = "Economy Services",
            Services = new()
            {
                new() { ServiceId = "usps_ground_adv", ServiceName = "USPS Ground Advantage (2-5 business days)" },
                new() { ServiceId = "economy_shipping", ServiceName = "Economy Shipping (1-10 business days)" }
            }
        },
        new ServiceGroup
        {
            GroupName = "Standard Services",
            Services = new()
            {
                new() { ServiceId = "usps_priority", ServiceName = "USPS Priority Mail (1-3 business days)" },
                new() { ServiceId = "ups_ground", ServiceName = "UPS Ground (1-5 business days)" },
                new() { ServiceId = "fedex_ground", ServiceName = "FedEx Ground (1-5 business days)" }
            }
        },
        new ServiceGroup
        {
            GroupName = "Expedited Services",
            Services = new()
            {
                new() { ServiceId = "usps_priority_exp", ServiceName = "USPS Priority Mail Express (1-2 business days)" },
                new() { ServiceId = "ups_next_day", ServiceName = "UPS Next Day Air (1 business day)" }
            }
        }
    };

    private List<ServiceGroup> _internationalServiceGroups = new()
    {
        new ServiceGroup
        {
            GroupName = "International Economy Services",
            Services = new()
            {
                new() { ServiceId = "intl_economy", ServiceName = "Economy International Shipping (11-23 business days)" },
                new() { ServiceId = "ebay_intl_standard", ServiceName = "eBay International Standard Delivery (8-15 business days)" }
            }
        },
        new ServiceGroup
        {
            GroupName = "International Standard Services",
            Services = new()
            {
                new() { ServiceId = "intl_standard", ServiceName = "Standard International Shipping (7-14 business days)" },
                new() { ServiceId = "usps_intl_priority", ServiceName = "USPS Priority Mail International (6-10 business days)" }
            }
        },
        new ServiceGroup
        {
            GroupName = "International Expedited Services",
            Services = new()
            {
                new() { ServiceId = "intl_expedited", ServiceName = "Expedited International Shipping (3-7 business days)" },
                new() { ServiceId = "usps_intl_exp", ServiceName = "USPS Priority Mail Express International (3-5 business days)" }
            }
        }
    };
}
