@page "/buyer-test/shop"
@using EbayClone.Shared.DTOs.Products
@using EbayClone.Shared.DTOs.Orders
@using EbayClone.Frontend.Services
@inject BuyerService BuyerService
@inject VoucherService VoucherService

<div class="container mt-4">
    <div class="alert alert-info">
        <strong>Lưu ý:</strong> Đây là trang giả lập Luồng Khách Mua Hàng (Buyer) để test chức năng Giữ Kho (Reserve Stock) và Phục vụ cho Seller ở trang Quản Lý Đơn Hàng.
    </div>

    <h2 class="ebay-page-title mb-4">Cửa Hàng (Sản phẩm đang bán)</h2>

    @if (isLoading)
    {
        <div class="text-center p-5"><span class="spinner-border"></span> Đang tải sản phẩm...</div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else if (!products.Any())
    {
        <div class="alert alert-warning">Chưa có sản phẩm nào đang được đổi Status sang ACTIVE. Vui lòng vào trang Inventory của Seller để đăng/Publish ít nhất 1 sản phẩm.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var prod in products)
            {
                <div class="col">
                    <div class="card h-100 ebay-card">
                        @if (!string.IsNullOrEmpty(prod.PrimaryImageUrl))
                        {
                            <img src="@prod.PrimaryImageUrl" class="card-img-top" alt="..." style="height: 200px; object-fit: cover;">
                        }
                        else
                        {
                            <div class="bg-light text-center d-flex align-items-center justify-content-center" style="height: 200px;">No Image</div>
                        }
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@prod.Name</h5>
                            <p class="card-text text-muted small">Brand: @prod.Brand</p>
                            
                            @if (prod.Variants != null && prod.Variants.Any())
                            {
                                var variant = prod.Variants.First(); // Lấy variant đầu tiên để test
                                var availableStock = variant.Quantity;
                                
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="fs-5 text-primary fw-bold">@variant.Price.ToString("N0") đ</span>
                                    @if(availableStock > 0)
                                    {
                                        <span class="badge bg-success">Còn hàng (@availableStock)</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Hết hàng</span>
                                    }
                                </div>
                                <div class="small text-muted mb-3">
                                    (Tổng tồn: @variant.Quantity)
                                </div>

                                <!-- Voucher Input -->
                                <div class="input-group input-group-sm mb-2">
                                    <input class="form-control" @bind="voucherCode" placeholder="Mã giảm giá (tùy chọn)"
                                           @oninput="OnVoucherCodeInput" />
                                </div>
                                @if (voucherDiscount > 0)
                                {
                                    <div class="alert alert-success py-1 px-2 mb-2" style="font-size:0.85em">
                                        ✅ Giảm <strong>@voucherDiscount.ToString("N0")đ</strong> — Thanh toán: @((variant.Price - voucherDiscount).ToString("N0"))đ
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(voucherError))
                                {
                                    <div class="alert alert-danger py-1 px-2 mb-2" style="font-size:0.85em">@voucherError</div>
                                }

                                <button class="btn btn-primary w-100"
                                        disabled="@(availableStock <= 0 || isProcessing)"
                                        @onclick="() => BuyNow(variant.Id, prod.ShopId)">
                                    @if(isProcessing && processingVariantId == variant.Id)
                                    {
                                        <span class="spinner-border spinner-border-sm"></span> <span>Đang xử lý...</span>
                                    }
                                    else
                                    {
                                        <span>Mua ngay 1 cái</span>
                                    }
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    
    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div class="alert alert-success mt-4">
            @successMessage
            <a href="/orders" class="btn btn-sm btn-success ms-3">Về trang Quản Lý Đơn Hàng <i class="bi bi-arrow-right"></i></a>
        </div>
    }
</div>

@code {
    private IEnumerable<ProductDto> products = Array.Empty<ProductDto>();
    private bool isLoading = true;
    private bool isProcessing = false;
    private Guid? processingVariantId = null;
    private string? errorMessage;
    private string? successMessage;
    private string voucherCode = "";
    private decimal voucherDiscount = 0;
    private string? voucherError;

    private void OnVoucherCodeInput(ChangeEventArgs e)
    {
        voucherCode = e.Value?.ToString() ?? "";
        voucherDiscount = 0;
        voucherError = null;
        // Reset discount khi user sửa mã
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        try
        {
            isLoading = true;
            errorMessage = null;
            products = await BuyerService.GetPublicProductsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task BuyNow(Guid variantId, Guid shopId)
    {
        try
        {
            isProcessing = true;
            processingVariantId = variantId;
            errorMessage = null;
            successMessage = null;
            voucherError = null;

            var request = new CreateBuyerTestOrderRequest
            {
                IdempotencyKey = Guid.NewGuid().ToString(), // tạo key mới mỗi lần
                VariantId = variantId,
                Quantity = 1,
                ReceiverInfo = System.Text.Json.JsonSerializer.Serialize(new {
                    FullName = "Nguyễn Văn A",
                    Phone = "0123456789",
                    Address = "Quận 1, TP HCM"
                }),
                VoucherCode = string.IsNullOrWhiteSpace(voucherCode) ? null : voucherCode.Trim().ToUpperInvariant()
            };

            await BuyerService.CheckoutAsync(request);
            successMessage = "Mua hàng thành công! Đơn hàng đã được tạo với trạng thái PENDING_PAYMENT. Bạn có thể duyệt tiếp bên luồng Seller.";
            voucherCode = "";
            voucherDiscount = 0;
            
            await LoadProducts(); // Load lại để thấy Quantity giảm do DeductStock
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi mua hàng: {ex.Message}";
            // Nổ lỗi nguyên tử nếu Concurrency có vấn đề hoặc hết hàng
        }
        finally
        {
            isProcessing = false;
            processingVariantId = null;
        }
    }
}
