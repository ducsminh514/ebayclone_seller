@page "/onboarding"
@using EbayClone.Shared.DTOs.Shops
@using EbayClone.Frontend.Services
@inject NavigationManager NavigationManager
@inject ShopService ShopService
@inject AuthService AuthService
@inject ISnackbar Snackbar
@using MudBlazor

<PageTitle>Ebay Seller Onboarding</PageTitle>

<div style="max-width: 900px; margin: 40px auto; padding: 0 16px;">
    @if (isInitialLoading)
    {
        <div class="d-flex flex-column align-center justify-center" style="height: 400px;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.body1" Class="mt-4">Loading your onboarding status...</MudText>
        </div>
    }
    else
    {
        <div style="text-align: center; margin-bottom: 32px;">
            <h1 style="font-size: 32px; font-weight: 800; color: var(--text-primary);">Set up your seller account</h1>
            <p style="color: var(--text-secondary); font-size: 16px;">Complete these steps to start listing and getting paid on eBay.</p>
        </div>

        @* Bọc toàn bộ nội dung động trong @key để force Blazor re-create DOM khi step thay đổi *@
        <div @key="@($"step-{_activeStepIndex}")">

        @* ===== STEP INDICATOR ===== *@
        <div class="d-flex justify-center gap-2 mb-8">
            @{ var steps = new[] { "Shop Info", "Identity", "Payments", "Go Live" }; }
            @for (int i = 0; i < steps.Length; i++)
            {
                var idx = i;
                <div class="d-flex align-center gap-1">
                    <MudAvatar Size="Size.Small"
                        Style="@(idx < _activeStepIndex ? "background:#137A20;color:white;" : idx == _activeStepIndex ? "background:#0654BA;color:white;" : "background:#E5E5E5;color:#707070;")">
                        @if (idx < _activeStepIndex) { <MudIcon Icon="@Icons.Material.Filled.Check" Size="Size.Small" /> } else { @(idx + 1) }
                    </MudAvatar>
                    <MudText Typo="Typo.body2" Style="@(idx == _activeStepIndex ? "font-weight:700;color:#0654BA;" : "color:#707070;")">@steps[idx]</MudText>
                    @if (idx < 3) { <MudIcon Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small" Style="color:#ccc;" /> }
                </div>
            }
        </div>

        <MudPaper Elevation="1" Class="pa-8" Style="border-radius:16px;">
            @* ===== STEP 0: SHOP INFO ===== *@
            @if (_activeStepIndex == 0)
            {
                <MudText Typo="Typo.h5" Class="mb-4">Tell us about your business</MudText>
                <EditForm Model="shopModel" OnValidSubmit="ProcessShopInfo">
                    <DataAnnotationsValidator />
                    <MudGrid>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="shopModel.Name" For="@(() => shopModel.Name)" Label="Shop Name" Required="true" Variant="Variant.Outlined" Placeholder="e.g. Awesome Gadgets Store" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="shopModel.TaxCode" For="@(() => shopModel.TaxCode)" Label="Tax ID / Business License" Variant="Variant.Outlined" Placeholder="Optional for individuals" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="shopModel.Address" For="@(() => shopModel.Address)" Label="Business Address" Required="true" Variant="Variant.Outlined" Placeholder="Street, City, Country" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="shopModel.Description" For="@(() => shopModel.Description)" Label="Shop Description" Variant="Variant.Outlined" Lines="3" Placeholder="Briefly describe what you sell..." />
                        </MudItem>
                    </MudGrid>
                    <div class="mt-8 d-flex justify-end">
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@isSubmitting" Class="rounded-pill px-8 py-2">
                            @if (isSubmitting) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/> }
                            Continue
                        </MudButton>
                    </div>
                </EditForm>
            }

            @* ===== STEP 1: IDENTITY VERIFICATION ===== *@
            else if (_activeStepIndex == 1)
            {
                <div class="text-center">
                    <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Color="Color.Primary" Style="font-size: 64px;" Class="mb-4" />
                    <MudText Typo="Typo.h5" Class="mb-2">Verify your identity</MudText>
                    <MudText Typo="Typo.body1" Class="text-secondary mb-6">We've sent a security code to your phone to ensure it's really you.</MudText>

                    <EditForm Model="otpModel" OnValidSubmit="ProcessIdentity">
                        <DataAnnotationsValidator />
                        <div style="max-width: 300px; margin: 0 auto;">
                            <MudTextField @bind-Value="otpModel.OtpCode" For="@(() => otpModel.OtpCode)" Label="6-digit Code" Variant="Variant.Outlined" MaxLength="6" Placeholder="123456" Style="text-align: center; font-size: 24px; letter-spacing: 4px;" />
                            <MudText Typo="Typo.caption" Color="Color.Info" Class="mt-2 d-block">Mock code: 123456</MudText>
                        </div>

                        <div class="mt-8 d-flex justify-center gap-4">
                            <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="@(() => GoToStep(0))">Back</MudButton>
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@isSubmitting" Class="rounded-pill px-8 py-2">
                                @if (isSubmitting) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/> }
                                Verify Identity
                            </MudButton>
                        </div>
                    </EditForm>
                </div>
            }

            @* ===== STEP 2: PAYMENTS ===== *@
            else if (_activeStepIndex == 2)
            {
                <div class="d-flex justify-space-between align-center mb-6">
                    <MudText Typo="Typo.h5" Style="font-weight: 700;">Add payment method</MudText>
                </div>
                <MudText Typo="Typo.body2" Class="mb-4 text-secondary">eBay needs to know where to send your payouts (money you earn from selling).</MudText>

                <EditForm Model="bankModel" OnValidSubmit="ProcessPayments">
                    <DataAnnotationsValidator />
                    <MudRadioGroup @bind-Value="_paymentType" T="string" Class="d-flex flex-column gap-3">
                        <div class="payment-option @(_paymentType == "Bank" ? "selected" : "")" @onclick='(() => _paymentType = "Bank")'>
                            <div class="d-flex align-center p-4">
                                <MudRadio Value='@("Bank")' Color="Color.Primary" />
                                <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Class="mx-3" />
                                <div>
                                    <MudText Typo="Typo.body1" Style="font-weight: 600;">Bank account (Direct Payouts)</MudText>
                                    <MudText Typo="Typo.caption">Get paid directly to your checking account.</MudText>
                                </div>
                            </div>
                            @if (_paymentType == "Bank")
                            {
                                <div class="bank-form px-12 pb-4">
                                    <MudTextField @bind-Value="bankModel.BankName" For="@(() => bankModel.BankName)" Label="Bank Name" Variant="Variant.Text" Dense="true" />
                                    <MudTextField @bind-Value="bankModel.BankAccountNumber" For="@(() => bankModel.BankAccountNumber)" Label="Account Number" Variant="Variant.Text" Dense="true" Class="mt-2" />
                                    <MudTextField @bind-Value="bankModel.BankAccountHolderName" For="@(() => bankModel.BankAccountHolderName)" Label="Account Holder Name" Variant="Variant.Text" Dense="true" Class="mt-2" />
                                </div>
                            }
                        </div>

                        <div class="payment-option" style="opacity: 0.5; cursor: not-allowed;">
                            <div class="d-flex align-center p-4">
                                <MudRadio Value='@("Card")' Color="Color.Primary" Disabled="true" />
                                <MudIcon Icon="@Icons.Material.Filled.CreditCard" Class="mx-3" />
                                <div>
                                    <MudText Typo="Typo.body1" Style="font-weight: 600;">Credit or debit card</MudText>
                                    <MudText Typo="Typo.caption">Coming soon — Available in future updates.</MudText>
                                </div>
                            </div>
                        </div>
                    </MudRadioGroup>

                    <div class="mt-8 d-flex justify-end gap-3">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(() => GoToStep(1))" Class="rounded-pill">Back</MudButton>
                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@(isSubmitting || string.IsNullOrEmpty(bankModel.BankAccountNumber))" Class="rounded-pill px-8">
                            Continue
                        </MudButton>
                    </div>
                </EditForm>
            }

            @* ===== STEP 3: GO LIVE ===== *@
            else if (_activeStepIndex == 3)
            {
                <div class="text-center">
                    @if (!isBankVerified)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.Timer" Color="Color.Warning" Style="font-size: 64px;" Class="mb-4" />
                        <MudText Typo="Typo.h5" Class="mb-2">Verifying your bank account</MudText>
                        <MudText Typo="Typo.body1" Class="text-secondary mb-6">eBay has sent 2 small amounts to your bank. Check your statement and enter them below to finish. (Mock: Try $0.12 and $0.34)</MudText>

                        @if (_remainingAttempts > 0 && _remainingAttempts < 3)
                        {
                            <MudAlert Severity="Severity.Warning" Class="mb-4" Dense="true">You have @_remainingAttempts attempts remaining. Please check carefully.</MudAlert>
                        }

                        <EditForm Model="microDepositModel" OnValidSubmit="ProcessMicroDeposit">
                            <DataAnnotationsValidator />
                            <div class="d-flex justify-center gap-4 mb-8" style="max-width: 400px; margin: 0 auto;">
                                <MudNumericField @bind-Value="microDepositModel.Amount1" For="@(() => microDepositModel.Amount1)" Label="Amount 1" Variant="Variant.Outlined" Format="N2" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
                                <MudNumericField @bind-Value="microDepositModel.Amount2" For="@(() => microDepositModel.Amount2)" Label="Amount 2" Variant="Variant.Outlined" Format="N2" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
                            </div>

                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@(isSubmitting || _remainingAttempts == 0)" Class="rounded-pill px-10 py-3">
                                Verify and Finish
                            </MudButton>
                        </EditForm>

                        @if (_remainingAttempts == 0)
                        {
                            <MudText Color="Color.Error" Class="mt-4">Too many failed attempts. Please contact eBay support to reset.</MudText>
                        }
                    }
                    else
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size: 80px;" Class="mb-4" />
                        <MudText Typo="Typo.h4" Style="font-weight: 800;" Class="mb-2">Congratulations!</MudText>
                        <MudText Typo="Typo.h6" Class="mb-6">Your eBay seller account is fully set up.</MudText>

                        <div class="summary-box p-4 mb-8" style="background: #F7F7F7; border-radius: 12px; text-align: left;">
                            <div class="d-flex align-center mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.Done" Color="Color.Success" Size="Size.Small" Class="mr-2" />
                                <MudText>Identity Verified</MudText>
                            </div>
                            <div class="d-flex align-center mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.Done" Color="Color.Success" Size="Size.Small" Class="mr-2" />
                                <MudText>Payment Account Linked (Managed Payments)</MudText>
                            </div>
                            <div class="d-flex align-center">
                                <MudIcon Icon="@Icons.Material.Filled.Done" Color="Color.Success" Size="Size.Small" Class="mr-2" />
                                <MudText>Business Policies: Shipping, Return, & Payment Initialized</MudText>
                            </div>
                        </div>

                        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick='(() => NavigationManager.NavigateTo("/"))' Class="rounded-pill px-12 py-3" Style="font-size: 18px;">
                            Go to Dashboard
                        </MudButton>
                    }
                </div>
            }
        </MudPaper>
        </div> @* end @key wrapper *@
    }

    @* DEV ONLY: Nút reset để test lại flow *@
    <div class="d-flex justify-center mt-6">
        <MudButton Variant="Variant.Text" Color="Color.Error" Size="Size.Small" StartIcon="@Icons.Material.Filled.RestartAlt" OnClick="DevResetOnboarding">
            [DEV] Reset Onboarding
        </MudButton>
    </div>
</div>

<style>
    .payment-option {
        border: 1px solid #e0e0e0;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
    }
    .payment-option:hover {
        border-color: var(--mud-palette-primary);
        background-color: #f8f9ff;
    }
    .payment-option.selected {
        border-color: var(--mud-palette-primary);
        border-width: 2px;
        background-color: #f8f9ff;
    }
    .rounded-pill {
        border-radius: 50px !important;
    }
</style>

@code {
    private int _activeStepIndex = 0;
    private CreateShopRequest shopModel = new();
    private VerifyShopOtpRequest otpModel = new();
    private LinkBankAccountRequest bankModel = new();
    private VerifyMicroDepositRequest microDepositModel = new();

    private string _paymentType = "Bank";
    private bool isSubmitting = false;
    private bool isBankVerified = false;
    private bool isInitialLoading = true;
    private int _remainingAttempts = 3;

    private void GoToStep(int step)
    {
        _activeStepIndex = step;
    }

    protected override async Task OnInitializedAsync()
    {
        try {
            var status = await ShopService.GetOnboardingStatusAsync();
            if (status != null) {
                // Shop ĐÃ tồn tại → skip sang step phù hợp
                _remainingAttempts = 3 - status.BankVerificationAttempts;
                if (status.IsVerified) {
                    isBankVerified = true;
                    _activeStepIndex = 3;
                }
                else if (status.BankVerificationStatus == "Pending") {
                    _activeStepIndex = 3;
                }
                else if (status.IsIdentityVerified) {
                    _activeStepIndex = 2;
                }
                else {
                    _activeStepIndex = 1; // Shop đã có nhưng chưa verify → Identity
                }
            }
            // status == null → chưa có shop → step 0
        } catch (Exception) {
            _activeStepIndex = 0;
        } finally {
            isInitialLoading = false;
        }
    }

    private async Task ProcessShopInfo()
    {
        isSubmitting = true;
        try {
            await ShopService.CreateShopAsync(shopModel);
            _activeStepIndex = 1;
        } catch (Exception ex) {
            Snackbar.Add(ex.Message, Severity.Error);
        } finally {
            isSubmitting = false;
        }
    }

    private async Task ProcessIdentity()
    {
        isSubmitting = true;
        try {
            await ShopService.VerifyOtpAsync(otpModel);
            _activeStepIndex = 2;
        } catch (Exception ex) {
            Snackbar.Add(ex.Message, Severity.Error);
        } finally {
            isSubmitting = false;
        }
    }

    private async Task ProcessPayments()
    {
        if (_paymentType != "Bank") {
            Snackbar.Add("Feature not available in demo. Please use Bank Account.", Severity.Info);
            return;
        }

        isSubmitting = true;
        try {
            await ShopService.LinkBankAccountAsync(bankModel);
            _activeStepIndex = 3;
        } catch (Exception ex) {
            Snackbar.Add(ex.Message, Severity.Error);
        } finally {
            isSubmitting = false;
        }
    }

    private async Task ProcessMicroDeposit()
    {
        isSubmitting = true;
        try {
            await ShopService.VerifyMicroDepositAsync(microDepositModel);
            isBankVerified = true;

            await AuthService.RefreshTokenAsync();
            Snackbar.Add("Seller account verified successfully!", Severity.Success);
        } catch (Exception ex) {
            Snackbar.Add(ex.Message, Severity.Error);
            try {
                var status = await ShopService.GetOnboardingStatusAsync();
                if (status != null)
                    _remainingAttempts = 3 - status.BankVerificationAttempts;
            } catch {}
        } finally {
            isSubmitting = false;
        }
    }

    private async Task DevResetOnboarding()
    {
        try {
            await ShopService.DevResetOnboardingAsync();
            Snackbar.Add("Onboarding reset! Đăng xuất và đăng nhập lại để test.", Severity.Success);
            // Reload page
            NavigationManager.NavigateTo("/onboarding", forceLoad: true);
        } catch (Exception ex) {
            Snackbar.Add($"Reset failed: {ex.Message}", Severity.Error);
        }
    }
}
