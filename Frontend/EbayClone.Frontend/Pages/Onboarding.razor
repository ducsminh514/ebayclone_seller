@page "/onboarding"
@inject EbayClone.Frontend.Services.ShopService ShopService
@inject NavigationManager NavigationManager
@using EbayClone.Application.DTOs.Shops

<PageTitle>Start Selling on eBay - Registration</PageTitle>

<div style="max-width: 600px; margin: 48px auto; background: var(--bg-surface); padding: 32px; border-radius: var(--border-radius); box-shadow: var(--box-shadow); border: 1px solid var(--border-color);">
    <h1 style="font-size: 24px; font-weight: 700; margin-top: 0; text-align: center; margin-bottom: 8px;">Start Selling on eBay</h1>
    <p style="color: var(--text-secondary); text-align: center; margin-bottom: 32px;">Please provide your business details to complete the seller onboarding process.</p>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div style="background-color: #fee; color: var(--danger-color); padding: 12px 16px; border-radius: 4px; border: 1px solid var(--danger-color); margin-bottom: 24px; font-weight: 500;">
            <i class="oi oi-circle-x" style="margin-right: 8px;"></i> @errorMessage
        </div>
    }

    @if (!string.IsNullOrEmpty(successMessage))
    {
        <div style="background-color: #e6ffed; color: var(--success-color); padding: 12px 16px; border-radius: 4px; border: 1px solid var(--success-color); margin-bottom: 24px; font-weight: 500;">
            <i class="oi oi-circle-check" style="margin-right: 8px;"></i> @successMessage
        </div>
    }

    <EditForm Model="shopModel" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <div style="margin-bottom: 24px;">
            <label style="display: block; font-weight: 600; margin-bottom: 8px;">Shop Name <span style="color: var(--danger-color);">*</span></label>
            <InputText @bind-Value="shopModel.Name" placeholder="Enter your shop name" style="width: 100%; padding: 12px; border: 1px solid var(--border-color); border-radius: var(--border-radius-sm); outline: none;" />
            <ValidationMessage For="@(() => shopModel.Name)" />
        </div>

        <div style="margin-bottom: 24px;">
            <label style="display: block; font-weight: 600; margin-bottom: 8px;">Tax Code / Business License</label>
            <InputText @bind-Value="shopModel.TaxCode" placeholder="Optional for individuals" style="width: 100%; padding: 12px; border: 1px solid var(--border-color); border-radius: var(--border-radius-sm); outline: none;" />
            <ValidationMessage For="@(() => shopModel.TaxCode)" />
        </div>

        <div style="margin-bottom: 24px;">
            <label style="display: block; font-weight: 600; margin-bottom: 8px;">Business Address <span style="color: var(--danger-color);">*</span></label>
            <InputText @bind-Value="shopModel.Address" placeholder="123 Main St, City, Country" style="width: 100%; padding: 12px; border: 1px solid var(--border-color); border-radius: var(--border-radius-sm); outline: none;" />
            <ValidationMessage For="@(() => shopModel.Address)" />
        </div>

        <div style="margin-bottom: 32px;">
            <label style="display: block; font-weight: 600; margin-bottom: 8px;">Description</label>
            <InputTextArea @bind-Value="shopModel.Description" rows="4" placeholder="Tell buyers a little about your shop..." style="width: 100%; padding: 12px; border: 1px solid var(--border-color); border-radius: var(--border-radius-sm); outline: none; resize: vertical;" />
            <ValidationMessage For="@(() => shopModel.Description)" />
        </div>

        <div style="display: flex; justify-content: flex-end; gap: 16px;">
            <button type="button" @onclick="CancelCreation" style="padding: 12px 24px; background-color: transparent; color: var(--primary-color); border: 1px solid var(--primary-color); border-radius: 24px; font-weight: 600; cursor: pointer;">Cancel</button>
            <button type="submit" disabled="@isSubmitting" style="padding: 12px 24px; background-color: var(--primary-color); color: white; border: none; border-radius: 24px; font-weight: 600; cursor: pointer; opacity: @(isSubmitting ? 0.7 : 1);">
                @(isSubmitting ? "Processing..." : "Submit Registration")
            </button>
        </div>
    </EditForm>
</div>

@code {
    private CreateShopRequest shopModel = new();
    private bool isSubmitting = false;
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;

    private async Task HandleSubmit()
    {
        isSubmitting = true;
        errorMessage = string.Empty;
        successMessage = string.Empty;

        try
        {
            var msg = await ShopService.CreateShopAsync(shopModel);
            successMessage = msg;
            // Tự động chuyển trang sau 2 giây
            await Task.Delay(2000);
            NavigationManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void CancelCreation()
    {
        NavigationManager.NavigateTo("/");
    }
}
