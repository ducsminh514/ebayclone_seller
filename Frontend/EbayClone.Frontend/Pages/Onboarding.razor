@page "/onboarding"
@inject EbayClone.Frontend.Services.ShopService ShopService
@inject EbayClone.Frontend.Services.AuthService AuthService
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@using EbayClone.Shared.DTOs.Shops
@using MudBlazor

<PageTitle>Seller Onboarding - eBay Clone</PageTitle>

<div style="max-width: 900px; margin: 40px auto; padding: 0 16px;">
    @if (isInitialLoading)
    {
        <div class="d-flex flex-column align-center justify-center" style="height: 400px;">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.body1" Class="mt-4">Loading your onboarding status...</MudText>
        </div>
    }
    else
    {
        <div style="text-align: center; margin-bottom: 32px;">
            <h1 style="font-size: 32px; font-weight: 800; color: var(--text-primary);">Set up your seller account</h1>
            <p style="color: var(--text-secondary); font-size: 16px;">Complete these steps to start listing and getting paid on eBay.</p>
        </div>

        <MudStepper @ref="_stepper" @bind-ActiveStepIndex="_activeStepIndex" Color="Color.Primary" Variant="Variant.Filled" HeaderBadgeType="BadgeType.Number" CenterLabels="true" Class="ebay-stepper">
        <!-- STEP 1: SHOP INFORMATION -->
        <MudStep Title="Shop Info">
            <div class="step-content">
                <MudText Typo="Typo.h5" Class="mb-4">Tell us about your business</MudText>
                <EditForm Model="shopModel">
                    <DataAnnotationsValidator />
                    <MudGrid>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="shopModel.Name" Label="Shop Name" Required="true" Variant="Variant.Outlined" Placeholder="e.g. Awesome Gadgets Store" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="shopModel.TaxCode" Label="Tax ID / Business License" Variant="Variant.Outlined" Placeholder="Optional for individuals" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="shopModel.Address" Label="Business Address" Required="true" Variant="Variant.Outlined" Placeholder="Street, City, Country" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="shopModel.Description" Label="Shop Description" Variant="Variant.Outlined" Lines="3" Placeholder="Briefly describe what you sell..." />
                        </MudItem>
                    </MudGrid>
                </EditForm>
                <div class="mt-8 d-flex justify-end">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ProcessShopInfo" Disabled="@isSubmitting" Class="rounded-pill px-8 py-2">
                        @if (isSubmitting) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/> }
                        Continue
                    </MudButton>
                </div>
            </div>
        </MudStep>

        <!-- STEP 2: IDENTITY VERIFICATION -->
        <MudStep Title="Identity">
            <div class="step-content text-center">
                <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" Color="Color.Primary" Style="font-size: 64px;" Class="mb-4" />
                <MudText Typo="Typo.h5" Class="mb-2">Verify your identity</MudText>
                <MudText Typo="Typo.body1" Class="text-secondary mb-6">We've sent a security code to your phone to ensure it's really you.</MudText>
                
                <div style="max-width: 300px; margin: 0 auto;">
                    <MudTextField @bind-Value="otpModel.OtpCode" Label="6-digit Code" Variant="Variant.Outlined" MaxLength="6" Placeholder="123456" Style="text-align: center; font-size: 24px; letter-spacing: 4px;" />
                    <MudText Typo="Typo.caption" Color="Color.Info" Class="mt-2 d-block">Mock code: 123456</MudText>
                </div>

                <div class="mt-8 d-flex justify-center gap-4">
                    <MudButton Variant="Variant.Text" Color="Color.Primary" OnClick="() => _activeStepIndex = 0">Back</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ProcessIdentity" Disabled="@isSubmitting" Class="rounded-pill px-8 py-2">
                        @if (isSubmitting) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2"/> }
                        Verify Identity
                    </MudButton>
                </div>
            </div>
        </MudStep>

        <!-- STEP 3: MANAGED PAYMENTS (EBAY UI STYLE) -->
        <MudStep Title="Payments">
            <div class="ebay-payment-modal">
                <div class="d-flex justify-space-between align-center mb-6">
                    <MudText Typo="Typo.h5" Style="font-weight: 700;">Add payment method</MudText>
                </div>

                <MudText Typo="Typo.body2" Class="mb-4 text-secondary">eBay needs to know where to send your payouts (money you earn from selling).</MudText>

                <MudRadioGroup @bind-Value="_paymentType" T="string" Class="d-flex flex-column gap-3">
                    <div class="payment-option @(_paymentType == "Bank" ? "selected" : "")" @onclick='(() => _paymentType = "Bank")'>
                        <div class="d-flex align-center p-4">
                            <MudRadio Value='@("Bank")' Color="Color.Primary" />
                            <MudIcon Icon="@Icons.Material.Filled.AccountBalance" Class="mx-3" />
                            <div>
                                <MudText Typo="Typo.body1" Style="font-weight: 600;">Bank account (Direct Payouts)</MudText>
                                <MudText Typo="Typo.caption">Get paid directly to your checking account.</MudText>
                            </div>
                        </div>
                        @if (_paymentType == "Bank")
                        {
                            <div class="bank-form px-12 pb-4">
                                <MudTextField @bind-Value="bankModel.BankName" Label="Bank Name" Variant="Variant.Text" Dense="true" />
                                <MudTextField @bind-Value="bankModel.BankAccountNumber" Label="Account Number" Variant="Variant.Text" Dense="true" Class="mt-2" />
                                <MudTextField @bind-Value="bankModel.BankAccountHolderName" Label="Account Holder Name" Variant="Variant.Text" Dense="true" Class="mt-2" />
                            </div>
                        }
                    </div>

                    <div class="payment-option @(_paymentType == "Card" ? "selected" : "")" @onclick='(() => _paymentType = "Card")'>
                        <div class="d-flex align-center p-4">
                            <MudRadio Value='@("Card")' Color="Color.Primary" />
                            <MudIcon Icon="@Icons.Material.Filled.CreditCard" Class="mx-3" />
                            <div>
                                <MudText Typo="Typo.body1" Style="font-weight: 600;">Credit or debit card</MudText>
                                <MudText Typo="Typo.caption">Use for selling fees or as a backup payout method.</MudText>
                            </div>
                        </div>
                    </div>
                </MudRadioGroup>

                <div class="mt-8 d-flex justify-end gap-3">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="() => _activeStepIndex = 1" Class="rounded-pill">Back</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ProcessPayments" Disabled="@(isSubmitting || string.IsNullOrEmpty(bankModel.BankAccountNumber))" Class="rounded-pill px-8">
                        Continue
                    </MudButton>
                </div>
            </div>
        </MudStep>

        <!-- STEP 4: VERIFY DEPOSITS & FINISH -->
        <MudStep Title="Go Live">
            <div class="step-content text-center">
                @if (!isBankVerified)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Timer" Color="Color.Warning" Style="font-size: 64px;" Class="mb-4" />
                    <MudText Typo="Typo.h5" Class="mb-2">Verifying your bank account</MudText>
                    <MudText Typo="Typo.body1" Class="text-secondary mb-6">eBay has sent 2 small amounts to your bank. Check your statement and enter them below to finish. (Mock: Try $0.12 and $0.34)</MudText>

                    @if (_remainingAttempts > 0 && _remainingAttempts < 3)
                    {
                        <MudAlert Severity="Severity.Warning" Class="mb-4" Dense="true">You have @_remainingAttempts attempts remaining. Please check carefully.</MudAlert>
                    }

                    <div class="d-flex justify-center gap-4 mb-8" style="max-width: 400px; margin: 0 auto;">
                        <MudNumericField @bind-Value="microDepositModel.Amount1" Label="Amount 1" Variant="Variant.Outlined" Format="N2" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
                        <MudNumericField @bind-Value="microDepositModel.Amount2" Label="Amount 2" Variant="Variant.Outlined" Format="N2" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
                    </div>

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="ProcessMicroDeposit" Disabled="@(isSubmitting || _remainingAttempts == 0)" Class="rounded-pill px-10 py-3">
                        Verify and Finish
                    </MudButton>

                    @if (_remainingAttempts == 0)
                    {
                        <MudText Color="Color.Error" Class="mt-4">Too many failed attempts. Please contact eBay support to reset.</MudText>
                    }
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Style="font-size: 80px;" Class="mb-4" />
                    <MudText Typo="Typo.h4" Style="font-weight: 800;" Class="mb-2">Congratulations!</MudText>
                    <MudText Typo="Typo.h6" Class="mb-6">Your eBay seller account is fully set up.</MudText>
                    
                    <div class="summary-box p-4 mb-8" style="background: var(--bg-secondary); border-radius: 12px; text-align: left;">
                        <div class="d-flex align-center mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Done" Color="Color.Success" Size="Size.Small" Class="mr-2" />
                            <MudText>Identity Verified</MudText>
                        </div>
                        <div class="d-flex align-center mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Done" Color="Color.Success" Size="Size.Small" Class="mr-2" />
                            <MudText>Payment Account Linked (Managed Payments)</MudText>
                        </div>
                        <div class="d-flex align-center">
                            <MudIcon Icon="@Icons.Material.Filled.Done" Color="Color.Success" Size="Size.Small" Class="mr-2" />
                            <MudText>Business Policies: Shipping, Return, & Payment Initialized</MudText>
                        </div>
                    </div>

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick='(() => NavigationManager.NavigateTo("/"))' Class="rounded-pill px-12 py-3" Style="font-size: 18px;">
                        Go to Dashboard
                    </MudButton>
                }
            </div>
        </MudStep>
    </MudStepper>
    }
</div>

<style>
    .ebay-stepper {
        background-color: white !important;
        border-radius: 16px;
        box-shadow: 0 4px 24px rgba(0,0,0,0.06);
        padding: 24px;
        border: 1px solid #e0e0e0;
    }
    .step-content {
        padding: 24px 0;
    }
    .ebay-payment-modal {
        background: white;
        padding: 24px;
    }
    .payment-option {
        border: 1px solid #e0e0e0;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.2s;
    }
    .payment-option:hover {
        border-color: var(--mud-palette-primary);
        background-color: #f8f9ff;
    }
    .payment-option.selected {
        border-color: var(--mud-palette-primary);
        border-width: 2px;
        background-color: #f8f9ff;
    }
    .rounded-pill {
        border-radius: 50px !important;
    }
</style>

@code {
    private MudStepper _stepper = null!;
    private int _activeStepIndex = 0;
    private CreateShopRequest shopModel = new();
    private VerifyShopOtpRequest otpModel = new();
    private LinkBankAccountRequest bankModel = new();
    private VerifyMicroDepositRequest microDepositModel = new();

    private string _paymentType = "Bank";
    private bool isSubmitting = false;
    private bool isBankVerified = false;
    private bool isInitialLoading = true;
    private int _remainingAttempts = 3;

    protected override async Task OnInitializedAsync()
    {
        try {
            var status = await ShopService.GetOnboardingStatusAsync();
            if (status != null) {
                _remainingAttempts = 3 - status.BankVerificationAttempts;
                if (status.IsVerified) {
                    isBankVerified = true;
                    _activeStepIndex = 3; // Go to last step (Success)
                }
                else if (status.BankVerificationStatus == "Pending") {
                    _activeStepIndex = 3; // Go to Verify Micro-deposit
                }
                else if (status.IsIdentityVerified) {
                    _activeStepIndex = 2; // Go to Payments
                }
                else {
                    _activeStepIndex = 1; // Go to Identity
                }
            }
        } catch (Exception) {
            // Probably no shop created yet, stay at Step 0
            _activeStepIndex = 0;
        } finally {
            isInitialLoading = false;
        }
    }

    private async Task ProcessShopInfo()
    {
        isSubmitting = true;
        try {
            await ShopService.CreateShopAsync(shopModel);
            _activeStepIndex = 1;
        } catch (Exception ex) {
            Snackbar.Add(ex.Message, Severity.Error);
        } finally {
            isSubmitting = false;
        }
    }

    private async Task ProcessIdentity()
    {
        isSubmitting = true;
        try {
            await ShopService.VerifyOtpAsync(otpModel);
            _activeStepIndex = 2;
        } catch (Exception ex) {
            Snackbar.Add(ex.Message, Severity.Error);
        } finally {
            isSubmitting = false;
        }
    }

    private async Task ProcessPayments()
    {
        if (_paymentType != "Bank") {
            Snackbar.Add("Feature not available in demo. Please use Bank Account.", Severity.Info);
            return;
        }

        isSubmitting = true;
        try {
            await ShopService.LinkBankAccountAsync(bankModel);
            _activeStepIndex = 3;
        } catch (Exception ex) {
            Snackbar.Add(ex.Message, Severity.Error);
        } finally {
            isSubmitting = false;
        }
    }

    private async Task ProcessMicroDeposit()
    {
        isSubmitting = true;
        try {
            await ShopService.VerifyMicroDepositAsync(microDepositModel);
            isBankVerified = true;
            StateHasChanged();
            
            await AuthService.RefreshTokenAsync();
            Snackbar.Add("Seller account verified successfully!", Severity.Success);
        } catch (Exception ex) {
            Snackbar.Add(ex.Message, Severity.Error);
            try {
                var status = await ShopService.GetOnboardingStatusAsync();
                _remainingAttempts = 3 - status.BankVerificationAttempts;
            } catch {}
        } finally {
            isSubmitting = false;
        }
    }
}
