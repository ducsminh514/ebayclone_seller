@page "/seller/payments"
@using EbayClone.Frontend.Services
@inject SellerService SellerService
@inject NavigationManager Navigation

<div class="seller-hub-container">
    <div class="seller-hub-header">
        <h1>Payments & Wallet</h1>
        <div class="header-actions">
            <button class="finance-action-btn" @onclick="RefreshData">Refresh</button>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="loading-overlay">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (financeData != null)
    {
        <div class="finance-overview">
            <div class="finance-card">
                <h3>Available Balance</h3>
                <div class="balance-amount balance-available">
                    @financeData.AvailableBalance.ToString("N0") <span style="font-size: 16px">@financeData.Currency</span>
                </div>
                <p class="text-muted small">Ready for payout</p>
                <button class="finance-action-btn">Withdraw funds</button>
            </div>

            <div class="finance-card">
                <h3>Pending (Escrow)</h3>
                <div class="balance-amount balance-pending">
                    @financeData.PendingBalance.ToString("N0") <span style="font-size: 16px">@financeData.Currency</span>
                </div>
                <p class="text-muted small">Funds held until order completion</p>
                <a href="/seller/orders" class="small text-decoration-none">View pending orders</a>
            </div>
        </div>

        <div class="seller-hub-table-wrapper">
            <div class="action-bar" style="border-bottom: 1px solid #eee;">
                <div class="action-left">
                    <h2 style="font-size: 18px; margin: 0; font-weight: 600;">Recent Transactions</h2>
                </div>
            </div>

            <table class="seller-hub-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Description</th>
                        <th>Status</th>
                        <th class="text-end">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @if (financeData.RecentTransactions != null && financeData.RecentTransactions.Any())
                    {
                        foreach (var tx in financeData.RecentTransactions)
                        {
                            <tr>
                                <td class="transaction-date">@tx.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                <td>
                                    <span class="badge @GetBadgeClass(tx.Type)">@tx.Type</span>
                                </td>
                                <td>
                                    <div class="transaction-description">@tx.Description</div>
                                    <div class="small text-muted">ID: @tx.ReferenceId</div>
                                </td>
                                <td>
                                    <span class="badge @(tx.Status == "COMPLETED" ? "status-active" : "status-scheduled")">@tx.Status</span>
                                </td>
                                <td class="text-end @(tx.Amount >= 0 ? "amount-positive" : "amount-negative")">
                                    @(tx.Amount >= 0 ? "+" : "")@tx.Amount.ToString("N0") @financeData.Currency
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <img src="https://ir.ebaystatic.com/cr/v/c1/s_hub/no_transactions.png" style="width: 80px; opacity: 0.5;" alt="No transactions" />
                                <p class="mt-3 text-muted">No transactions found for the selected period.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-warning mt-4">
            <h4>No Wallet Found</h4>
            <p>It seems your seller wallet is not initialized. Please complete your registration.</p>
            <button class="btn btn-primary" @onclick='() => Navigation.NavigateTo("/onboarding")'>Go to Onboarding</button>
        </div>
    }
</div>

@code {
    private SellerFinanceDto? financeData;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await RefreshData();
    }

    private async Task RefreshData()
    {
        isLoading = true;
        financeData = await SellerService.GetFinanceAsync();
        isLoading = false;
    }

    private string GetBadgeClass(string type)
    {
        return type switch
        {
            "FEE" => "bg-danger bg-opacity-10 text-danger",
            "ESCROW_HOLD" => "bg-primary bg-opacity-10 text-primary",
            "ESCROW_RELEASE" => "bg-success bg-opacity-10 text-success",
            _ => "bg-secondary bg-opacity-10 text-secondary"
        };
    }

    private string GetStatusClass(string status)
    {
        return status == "COMPLETED" ? "status-active" : "status-scheduled";
    }
}
