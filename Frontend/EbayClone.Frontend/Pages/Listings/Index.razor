@page "/listings"
@using EbayClone.Domain.Entities
@using EbayClone.Frontend.Services
@inject ProductService ProductService
@inject NavigationManager NavigationManager

<div class="seller-hub-container">
    <div class="seller-hub-header">
        <h1 class="seller-hub-title">Manage active listings</h1>
    </div>

    @* Search & Filter Section *@
    <div class="search-container">
        <div class="search-title">
            <i class="bi bi-search"></i> Search
        </div>
        <div class="filter-grid">
            <div class="filter-item">
                <label>Product variation ID</label>
                <input type="text" class="ebay-select" placeholder="Enter ID" @bind="searchId" />
            </div>
            <div class="filter-item">
                <label>Category</label>
                <select class="ebay-select">
                    <option>All categories</option>
                </select>
            </div>
            <div class="filter-item">
                <label>Status</label>
                <select class="ebay-select" @onchange="OnStatusChanged">
                    <option value="ACTIVE">Active (@(products?.Count(p => p.Status == "ACTIVE") ?? 0))</option>
                    <option value="DRAFT">Draft (@(products?.Count(p => p.Status == "DRAFT") ?? 0))</option>
                    <option value="SCHEDULED">Scheduled (@(products?.Count(p => p.Status == "SCHEDULED") ?? 0))</option>
                    <option value="HIDDEN">Hidden (@(products?.Count(p => p.Status == "HIDDEN") ?? 0))</option>
                </select>
            </div>
        </div>
        <div class="action-bar" style="margin-top: 20px;">
            <button class="btn-ebay-primary" @onclick='() => NavigationManager.NavigateTo("/listings/create")'>Search</button>
            <a href="#" style="font-size: 13px; color: var(--seller-hub-link); margin-left: 15px;">Advanced search</a>
            <span style="border-left: 1px solid #ccc; margin: 0 10px; height: 15px;"></span>
            <a href="#" style="font-size: 13px; color: var(--seller-hub-link);" @onclick="() => searchId = null">Clear all</a>
        </div>
    </div>

    @* Results Information *@
    <div class="mb-2 d-flex align-items-center">
        <span class="fw-bold" style="font-size: 16px;">Results: @FilteredProducts.Count()</span>
    </div>

    @* Action Buttons Above Table *@
    <div class="action-bar">
        <button class="btn-ebay-primary" @onclick='() => NavigationManager.NavigateTo("/listings/create")'>
            Create listing <i class="bi bi-chevron-down ms-1"></i>
        </button>
        <button class="btn-ebay-secondary">Edit <i class="bi bi-chevron-down ms-1"></i></button>
        <button class="btn-ebay-secondary">Automation rules <i class="bi bi-chevron-down ms-1"></i></button>
        <button class="btn-ebay-secondary">Actions <i class="bi bi-chevron-down ms-1"></i></button>
        <button class="btn-ebay-secondary">Sell similar</button>
    </div>

    @* Table Content *@
    <div class="seller-hub-table-wrapper">
        @if (isLoading)
        {
            <div class="p-5 text-center">
                <div class="spinner-border text-primary" role="status"></div>
                <div class="mt-2 text-muted">Loading your listings...</div>
            </div>
        }
        else if (!FilteredProducts.Any())
        {
            <div class="p-5 text-center text-muted">
                <i class="bi bi-inbox" style="font-size: 48px;"></i>
                <h5 class="mt-3">No listings found matching your criteria.</h5>
            </div>
        }
        else
        {
            <table class="seller-hub-table">
                <thead>
                    <tr>
                        <th style="width: 40px;"><input type="checkbox" /></th>
                        <th>Actions</th>
                        <th>Photo</th>
                        <th style="width: 40%;">Title</th>
                        <th>SKU</th>
                        <th>Format</th>
                        <th>Price</th>
                        <th>Quantity</th>
                        <th>Watchers</th>
                        <th>Views</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in FilteredProducts)
                    {
                        <tr>
                            <td><input type="checkbox" /></td>
                            <td>
                                <a href="javascript:void(0)" class="text-primary fw-bold" @onclick='() => NavigationManager.NavigateTo($"/listings/edit/{p.Id}")'>
                                    Edit <i class="bi bi-chevron-down"></i>
                                </a>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(p.PrimaryImageUrl))
                                {
                                    <img src="@p.PrimaryImageUrl" alt="@p.Name" class="product-img" />
                                }
                                else
                                {
                                    <div class="product-img d-flex align-items-center justify-content-center bg-light text-muted">📷</div>
                                }
                            </td>
                            <td>
                                <div class="product-info">
                                    <h4><a href="#">@p.Name</a></h4>
                                    <div class="text-muted small">Brand: @p.Brand</div>
                                </div>
                            </td>
                            <td><span class="sku">@(string.IsNullOrEmpty(p.ReferenceId) ? "Add" : p.ReferenceId)</span></td>
                            <td>Fixed price</td>
                            <td>
                                <div class="price-text">@((p.BasePrice ?? 0).ToString("C0", new System.Globalization.CultureInfo("vi-VN")))</div>
                                <div class="small text-muted">Buy It Now</div>
                            </td>
                            <td>@(p.Variants?.Sum(v => v.Quantity) ?? 0)</td>
                            <td>0</td>
                            <td>0</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@code {
    private string? searchId;
    private IEnumerable<Product>? products;
    private bool isLoading = true;
    private string? errorMessage;
    private string? successMessage;
    private string currentTab = "ACTIVE";
    private Guid? updatingStatusProductId = null;
    private Guid? deletingProductId = null;

    private IEnumerable<Product> FilteredProducts
    {
        get
        {
            if (products == null) return new List<Product>();

            var query = products.AsEnumerable();

            // Filter by search ID if provided
            if (!string.IsNullOrEmpty(searchId))
            {
                query = query.Where(p => p.Id.ToString().Contains(searchId, StringComparison.OrdinalIgnoreCase) || 
                                       (p.ReferenceId != null && p.ReferenceId.Contains(searchId, StringComparison.OrdinalIgnoreCase)));
            }

            // Filter by Status (Tab)
            query = query.Where(p => p.Status == currentTab);

            return query;
        }
    }

    private void OnStatusChanged(ChangeEventArgs e)
    {
        currentTab = e.Value?.ToString() ?? "ACTIVE";
    }

    private void ChangeTab(string tab)
    {
        currentTab = tab;
    }

    private async Task ChangeProductStatus(Product product, string newStatus)
    {
        updatingStatusProductId = product.Id;
        errorMessage = null;
        StateHasChanged();

        try
        {
            await ProductService.UpdateProductStatusAsync(product.Id, newStatus);
            products = await ProductService.GetMyProductsAsync();
            successMessage = $"Đã chuyển '{product.Name}' sang trạng thái {newStatus}.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi khi cập nhật trạng thái: {ex.Message}";
        }
        finally
        {
            updatingStatusProductId = null;
        }
    }

    private async Task SoftDeleteProduct(Product product)
    {
        deletingProductId = product.Id;
        errorMessage = null;
        StateHasChanged();

        try
        {
            await ProductService.SoftDeleteProductAsync(product.Id);
            products = await ProductService.GetMyProductsAsync();
            successMessage = $"Đã xóa sản phẩm '{product.Name}' thành công.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi xóa sản phẩm: {ex.Message}";
        }
        finally
        {
            deletingProductId = null;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            products = await ProductService.GetMyProductsAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}
