@page "/listings/create"
@using EbayClone.Application.DTOs.Products
@using EbayClone.Application.DTOs.Policies
@using EbayClone.Frontend.Services
@inject ProductService ProductService
@inject PolicyService PolicyService
@inject CategoryService CategoryService
@inject NavigationManager NavigationManager

<div class="seller-hub-container">
    <div class="seller-hub-header d-flex justify-content-between align-items-center">
        <div>
            <h1 class="seller-hub-title">@(request.Id > 0 ? "Review your listing" : "Create a listing")</h1>
            <p class="text-muted mt-1">Provide as many details as possible to help buyers find your item.</p>
        </div>
        <div class="d-flex gap-2">
            <button type="button" class="btn-ebay-secondary" @onclick='() => NavigationManager.NavigateTo("/listings")'>Cancel</button>
            <button type="submit" form="listingForm" class="btn-ebay-primary" disabled="@isSubmitting">
                @(isSubmitting ? "Processing..." : (request.Id > 0 ? "Revise listing" : "List it"))
            </button>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger mb-4">
            <i class="bi bi-x-circle-fill me-2"></i> @errorMessage
        </div>
    }

    <EditForm id="listingForm" Model="request" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        
        <fieldset disabled="@isSubmitting">
            <!-- Listing Details -->
            <div class="summary-card mb-4">
                <h2 class="order-section-title">Listing details</h2>
                
                <div class="mb-4">
                    <label class="fw-600 mb-2">Title <span class="text-danger">*</span></label>
                    <InputText @bind-Value="request.Name" class="ebay-input" placeholder="Brand, Model, Size, Color, etc." maxlength="80" />
                    <ValidationMessage For="@(() => request.Name)" />
                </div>

                <div class="row g-4 mb-4">
                    <div class="col-md-6">
                        <label class="fw-600 mb-2">Brand</label>
                        <InputText @bind-Value="request.Brand" class="ebay-input" placeholder="e.g. Apple, Samsung" />
                    </div>
                    <div class="col-md-6">
                        <label class="fw-600 mb-2">Category <span class="text-danger">*</span></label>
                        <InputSelect @bind-Value="request.CategoryId" class="ebay-input bg-white">
                            <option value="">Select a category...</option>
                            @foreach (var c in categories)
                            {
                                <option value="@c.Id">@c.Name</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => request.CategoryId)" />
                    </div>
                </div>

                <div class="mb-0">
                    <label class="fw-600 mb-2">Description</label>
                    <InputTextArea @bind-Value="request.Description" class="ebay-input" style="height: 200px; padding: 15px;" placeholder="Describe your item in detail..." />
                </div>
            </div>

            <!-- Photos -->
            <div class="summary-card mb-4">
                <h2 class="order-section-title">Photos</h2>
                <p class="text-muted">Add a primary image link and up to 5 extra photos.</p>
                
                <div class="mb-4">
                    <label class="fw-600 mb-2">Primary Image URL</label>
                    <InputText @bind-Value="request.PrimaryImageUrl" class="ebay-input" placeholder="https://example.com/image.jpg" />
                    @if (!string.IsNullOrEmpty(request.PrimaryImageUrl))
                    {
                        <div class="mt-3">
                            <img src="@request.PrimaryImageUrl" class="img-thumbnail" style="max-height: 150px;" />
                        </div>
                    }
                </div>

                <div class="mb-0">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <label class="fw-600 mb-0">Extra Images (@extraImageUrls.Count / 5)</label>
                        <button type="button" class="btn-ebay-secondary btn-sm" @onclick="AddImageUrl" disabled="@(extraImageUrls.Count >= 5)">+ Add photo URL</button>
                    </div>
                    
                    <div class="row g-3">
                        @for (int i = 0; i < extraImageUrls.Count; i++)
                        {
                            var idx = i;
                            <div class="col-md-6">
                                <div class="input-group">
                                    <input type="text" class="ebay-input flex-grow-1" placeholder="https://..." value="@extraImageUrls[idx]" @onchange="(e) => UpdateImageUrl(idx, e.Value?.ToString())" />
                                    <button type="button" class="btn btn-outline-danger" @onclick="() => RemoveImageUrl(idx)" style="border-radius: 0 4px 4px 0;"><i class="bi bi-trash"></i></button>
                                </div>
                                @if (!string.IsNullOrEmpty(extraImageUrls[idx]))
                                {
                                    <img src="@extraImageUrls[idx]" class="mt-2 img-thumbnail" style="max-height: 100px;" />
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Business Policies -->
            <div class="summary-card mb-4">
                <h2 class="order-section-title">Business policies</h2>
                <div class="row g-4">
                    <div class="col-md-6">
                        <label class="fw-600 mb-2">Shipping policy</label>
                        <InputSelect @bind-Value="request.ShippingPolicyId" class="ebay-input bg-white">
                            <option value="">Select a policy...</option>
                            @foreach (var p in shippingPolicies)
                            {
                                <option value="@p.Id">@p.Name</option>
                            }
                        </InputSelect>
                    </div>
                    <div class="col-md-6">
                        <label class="fw-600 mb-2">Return policy</label>
                        <InputSelect @bind-Value="request.ReturnPolicyId" class="ebay-input bg-white">
                            <option value="">Select a policy...</option>
                            @foreach (var p in returnPolicies)
                            {
                                <option value="@p.Id">@p.Name</option>
                            }
                        </InputSelect>
                    </div>
                </div>
            </div>

            <!-- Variants (SKUs) -->
            <div class="summary-card mb-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="order-section-title mb-0">Inventory & Variations</h2>
                    <button type="button" class="btn-ebay-secondary btn-sm" @onclick="AddVariant" disabled="@(request.Variants.Count >= 50)">+ Add variation</button>
                </div>

                @if (!request.Variants.Any())
                {
                    <p class="text-center py-4 text-muted border rounded">No variations added yet.</p>
                }

                @foreach (var variant in request.Variants)
                {
                    <div class="variant-item-ebay mb-4 p-4 border rounded bg-light">
                        <div class="row g-4 mb-4">
                            <div class="col-md-3">
                                <label class="fw-600 mb-2">SKU code *</label>
                                <InputText @bind-Value="variant.SkuCode" class="ebay-input" />
                            </div>
                            <div class="col-md-3">
                                <label class="fw-600 mb-2">Price (₫) *</label>
                                <InputNumber @bind-Value="variant.Price" class="ebay-input" />
                            </div>
                            <div class="col-md-3">
                                <label class="fw-600 mb-2">Quantity *</label>
                                <InputNumber @bind-Value="variant.Quantity" class="ebay-input" />
                            </div>
                            <div class="col-md-3">
                                <label class="fw-600 mb-2">Weight (g)</label>
                                <InputNumber @bind-Value="variant.WeightGram" class="ebay-input" />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="fw-600 mb-2">Image URL</label>
                            <InputText @bind-Value="variant.ImageUrl" class="ebay-input" placeholder="https://..." />
                        </div>

                        <div class="mb-3">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-600">Dynamic Attributes (e.g. Color, Size)</span>
                                <button type="button" class="btn-ebay-secondary btn-sm" @onclick="() => AddAttribute(variant)" 
                                        disabled="@(variantAttributesMap.ContainsKey(variant) && variantAttributesMap[variant].Count >= 5)">+ Add attribute</button>
                            </div>

                            @if (variantAttributesMap.ContainsKey(variant))
                            {
                                @foreach (var attr in variantAttributesMap[variant])
                                {
                                    <div class="d-flex gap-2 mb-2">
                                        <input type="text" class="ebay-input bg-white" placeholder="Name (e.g. Color)" @bind="attr.Key" />
                                        <input type="text" class="ebay-input bg-white" placeholder="Value (e.g. Red)" @bind="attr.Value" />
                                        <button type="button" class="btn btn-outline-danger" @onclick="() => RemoveAttribute(variant, attr)"><i class="bi bi-trash"></i></button>
                                    </div>
                                }
                            }
                        </div>

                        <div class="text-end">
                            <button type="button" class="btn btn-sm btn-link text-danger text-decoration-none" @onclick="() => RemoveVariant(variant)">Remove variation</button>
                        </div>
                    </div>
                }
            </div>

            <!-- Action Footer -->
            <div class="d-flex gap-3 mb-5">
                <button type="submit" class="btn-ebay-secondary flex-fill py-3" @onclick="() => publishOnCreate = false">
                    @if(isSubmitting && !publishOnCreate) { <span class="spinner-border spinner-border-sm me-2"></span> }
                    Save as draft
                </button>
                <button type="submit" class="btn-ebay-primary flex-fill py-3" @onclick="() => publishOnCreate = true">
                    @if(isSubmitting && publishOnCreate) { <span class="spinner-border spinner-border-sm me-2"></span> }
                    List it now
                </button>
            </div>
        </fieldset>
    </EditForm>
</div>

@code {
    private CreateListingRequest request = new CreateListingRequest();
    private List<ShippingPolicyDto> shippingPolicies = new();
    private List<ReturnPolicyDto> returnPolicies = new();
    private List<CategoryDto> categories = new();
    private string? errorMessage;
    private bool isSubmitting = false;
    private bool publishOnCreate = false;
    private List<string> extraImageUrls = new();

    // Helper class to bind dictionary keys and values easily in UI
    public class AttributePair
    {
        public string Key { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }

    private Dictionary<CreateVariantRequest, List<AttributePair>> variantAttributesMap = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var cats = await CategoryService.GetCategoriesAsync();
            categories = cats.ToList();

            var sp = await PolicyService.GetShippingPoliciesAsync();
            shippingPolicies = sp.ToList();

            var rp = await PolicyService.GetReturnPoliciesAsync();
            returnPolicies = rp.ToList();

            // Khởi tạo sẵn 1 biến thể mặc định
            AddVariant();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void AddVariant()
    {
        if (request.Variants.Count >= 50) return;
        var newVariant = new CreateVariantRequest();
        request.Variants.Add(newVariant);
        variantAttributesMap[newVariant] = new List<AttributePair>();
    }

    private void RemoveVariant(CreateVariantRequest variant)
    {
        request.Variants.Remove(variant);
        variantAttributesMap.Remove(variant);
    }

    private void AddAttribute(CreateVariantRequest variant)
    {
        if (variantAttributesMap.ContainsKey(variant) && variantAttributesMap[variant].Count < 5)
        {
            variantAttributesMap[variant].Add(new AttributePair());
        }
    }

    private void RemoveAttribute(CreateVariantRequest variant, AttributePair attr)
    {
        if (variantAttributesMap.ContainsKey(variant))
        {
            variantAttributesMap[variant].Remove(attr);
        }
    }

    private async Task HandleSubmit()
    {
        errorMessage = null;
        isSubmitting = true;

        try
        {
            // Rebuild Attributes Dictionary from Map
            foreach (var variant in request.Variants)
            {
                variant.Attributes.Clear();
                if (variantAttributesMap.ContainsKey(variant))
                {
                    foreach (var attr in variantAttributesMap[variant])
                    {
                        if (!string.IsNullOrWhiteSpace(attr.Key) && !string.IsNullOrWhiteSpace(attr.Value))
                        {
                            variant.Attributes[attr.Key] = attr.Value;
                        }
                    }
                }
            }

            // Gom ảnh phụ
            request.ImageUrls = extraImageUrls.Where(u => !string.IsNullOrWhiteSpace(u)).ToList();

            var productId = await ProductService.CreateListingAsync(request);
            
            // Nếu Publish: đổi status sang ACTIVE ngay
            if (publishOnCreate)
            {
                await ProductService.UpdateProductStatusAsync(productId, "ACTIVE");
            }
            
            NavigationManager.NavigateTo("/listings");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    private void AddImageUrl()
    {
        if (extraImageUrls.Count < 5)
            extraImageUrls.Add("");
    }

    private void RemoveImageUrl(int index)
    {
        if (index >= 0 && index < extraImageUrls.Count)
            extraImageUrls.RemoveAt(index);
    }

    private void UpdateImageUrl(int index, string? val)
    {
        if (index >= 0 && index < extraImageUrls.Count)
            extraImageUrls[index] = val ?? "";
    }
}
