@page "/listings/create"
@attribute [Authorize]
@using EbayClone.Shared.DTOs.Products
@using EbayClone.Shared.DTOs.Policies
@using EbayClone.Frontend.Services
@using Microsoft.AspNetCore.Components.Forms
@inject ProductService ProductService
@inject PolicyService PolicyService
@inject CategoryService CategoryService
@inject FileUploadService FileUploadService
@inject NavigationManager NavigationManager



<div class="container mt-4">
    <div class="d-flex align-items-center justify-content-between mb-2">
        <h2 class="mb-0">Create Listing</h2>
        <a href="/listings/start" class="btn btn-sm btn-outline-secondary" style="border-radius: 20px;">
            ← Start over
        </a>
    </div>
    @if (!string.IsNullOrEmpty(selectedCategoryFullPath))
    {
        <div style="font-size: 13px; color: #555; margin-bottom: 4px;">
            📂 Category: <strong>@selectedCategoryFullPath</strong>
            <button type="button" class="btn btn-link btn-sm p-0 ms-2" style="font-size: 12px;"
                    @onclick="GoToStartListingToChangeCategory">Change</button>
        </div>
    }
    <hr />

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <EditForm Model="request" OnValidSubmit="HandleSubmit">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <fieldset disabled="@isSubmitting">

        <div class="ebay-card">
            <h4 class="ebay-card-title">Thông tin cơ bản</h4>
            <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <label class="form-label mb-0">Tẽn Sản Phẩm (Title) <span class="text-danger">*</span></label>
                    <span class="text-muted" style="font-size: 12px;"
                          title="eBay cho phép tối đa 80 ký tự">
                        <span class="@(request.Name.Length > 70 ? (request.Name.Length >= 80 ? "text-danger fw-bold" : "text-warning fw-bold") : "")">@request.Name.Length</span>/80
                    </span>
                </div>
                <InputText class="form-control ebay-input" @bind-Value="request.Name" maxlength="80"
                           placeholder="Viết tiêu đề rõ ràng, 75-80 ký tự để SEO tốt nhất" />
                <ValidationMessage For="() => request.Name" />
            </div>
            <div class="mb-3">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <label class="form-label mb-0">Phụ đề (Subtitle) <span class="text-muted" style="font-size: 12px;">— Tùy chọn, có phí đăng thêm</span></label>
                    <span class="text-muted" style="font-size: 12px;">
                        <span class="@((request.Subtitle?.Length ?? 0) > 45 ? ((request.Subtitle?.Length ?? 0) >= 55 ? "text-danger fw-bold" : "text-warning fw-bold") : "")">@(request.Subtitle?.Length ?? 0)</span>/55
                    </span>
                </div>
                <InputText class="form-control ebay-input" @bind-Value="request.Subtitle" maxlength="55"
                           placeholder="Xuất hiện dưới Title trong search results (không ảnh hưởng SEO Cassini)" />
                <ValidationMessage For="() => request.Subtitle" />
            </div>
            <div class="mb-3">
                <label class="form-label">Brand</label>
                <InputText class="form-control ebay-input" @bind-Value="request.Brand" placeholder="e.g. Apple, Samsung, Nike" />
            </div>
            <div class="mb-3">
                <label class="form-label">UPC / EAN / ISBN / MPN
                    <span class="text-muted" style="font-size: 11px;">— Giúp tăng visibility trên eBay & Google Shopping</span>
                </label>
                <input type="text" class="form-control ebay-input" @bind="upcCode"
                       placeholder="Enter product identifier (optional but recommended)" />
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <InputTextArea class="form-control ebay-input" @bind-Value="request.Description" rows="3" />
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Category *</label>
                    @if (!string.IsNullOrEmpty(selectedCategoryFullPath))
                    {
                        @* Hiển thị breadcrumb readonly — đã được chọn từ StartListing *@
                        <div style="padding: 8px 12px; background: #f0f7ff; border: 1px solid #c2dff7; border-radius: 8px; font-size: 13px;">
                            <i class="bi bi-folder2-open text-primary me-1"></i>
                            <strong>@selectedCategoryFullPath</strong>
                        </div>
                    }
                    else
                    {
                        @* Fallback dropdown nếu truy cập trực tiếp không qua StartListing *@
                        <InputSelect class="form-select ebay-input" @bind-Value="request.CategoryId"
                                     @bind-Value:after="OnCategoryChanged">
                            <option value="">-- Select Category --</option>
                            @foreach (var c in categories)
                            {
                                var prefix = c.ParentId.HasValue ? "   └ " : "";
                                <option value="@c.Id">@prefix@c.Name</option>
                            }
                        </InputSelect>
                        <div style="font-size: 11px; color: #999; margin-top: 4px;">
                            💡 <a href="/listings/start" style="color: #1a6bbf;">Use the listing wizard</a> to get AI category suggestions
                        </div>
                    }
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Tình trạng sản phẩm *</label>
                    <InputSelect class="form-select ebay-input" @bind-Value="request.Condition">
                        @* ── Nhóm Hàng Mới ── *@
                        <optgroup label="── Hàng Mới (New) ──">
                            <option value="New">New — Mới hoàn toàn, nguyên hộp</option>
                            <option value="New with tags">New with tags — Mới, còn tag gốc</option>
                            <option value="New without tags">New without tags — Mới, không còn tag</option>
                            <option value="New with imperfections">New with imperfections — Mới nhưng có khuyết điểm nhỏ</option>
                            <option value="Open Box">Open Box — Hộp đã mở, hàng vẫn mới</option>
                        </optgroup>
                        @* ── Nhóm Tân Trang ── *@
                        <optgroup label="── Tân Trang (Refurbished) ──">
                            <option value="Certified Refurbished">Certified Refurbished — Tân trang bởi nhà SX, như mới</option>
                            <option value="Excellent Refurbished">Excellent Refurbished — Như mới, bảo hành 1 năm</option>
                            <option value="Very Good Refurbished">Very Good Refurbished — Hao mòn tối thiểu, BH 1 năm</option>
                            <option value="Good Refurbished">Good Refurbished — Hao mòn vừa, BH 1 năm</option>
                            <option value="Seller Refurbished">Seller Refurbished — Người bán tự tân trang</option>
                        </optgroup>
                        @* ── Nhóm Đã Qua Sử Dụng ── *@
                        <optgroup label="── Đã Qua Sử Dụng (Used/Pre-owned) ──">
                            <option value="Used">Used — Đã sử dụng, còn hoạt động tốt</option>
                            <option value="Pre-owned - Excellent">Pre-owned Excellent — Như mới, ít dấu hao mòn</option>
                            <option value="Pre-owned - Good">Pre-owned Good — Hao mòn nhẹ (Feb 2025)</option>
                            <option value="Pre-owned - Fair">Pre-owned Fair — Hao mòn rõ rệt (Feb 2025)</option>
                        </optgroup>
                        @* ── Nhóm Khác ── *@
                        <optgroup label="── Khác ──">
                            <option value="For Parts or Not Working">For Parts or Not Working — Hỏng, bán phụ tùng</option>
                        </optgroup>
                    </InputSelect>
                </div>
            </div>
            @if (request.Condition != "New")
            {
                <div class="mb-3">
                    <label class="form-label">Mô tả tình trạng (vết xước, thiếu phụ kiện...)</label>
                    <InputTextArea class="form-control ebay-input" @bind-Value="request.ConditionDescription" rows="2" placeholder="Mô tả chi tiết tình trạng sản phẩm để người mua hiểu rõ..." />
                </div>
            }
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label class="form-label">Hình thức bán</label>
                    <InputSelect class="form-select ebay-input" @bind-Value="request.ListingFormat">
                        <option value="FIXED_PRICE">Giá cố định (Fixed Price)</option>
                        <option value="AUCTION">Đấu giá (Auction)</option>
                    </InputSelect>
                    @if (request.ListingFormat == "AUCTION" && request.Variants.Count > 1)
                    {
                        <div class="text-danger mt-1" style="font-size: 12px;">⚠️ Auction chỉ hỗ trợ 1 biến thể. Vui lòng xóa bớt.</div>
                    }
                </div>
                <div class="col-md-4 mb-3">
                    <label class="form-label">Subtitle (phụ đề SEO)</label>
                    <InputText class="form-control ebay-input" @bind-Value="request.Subtitle" placeholder="Hiển thị dưới tiêu đề trong kết quả tìm kiếm" />
                </div>
                <div class="col-md-4 mb-3 d-flex align-items-end">
                    <div class="form-check">
                        <InputCheckbox class="form-check-input" @bind-Value="request.AllowOffers" />
                        <label class="form-check-label">Cho phép đặt giá (Best Offer)</label>
                    </div>
                </div>
            </div>

            @if (request.AllowOffers)
            {
                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Tự chấp nhận offer ≥ (₫)</label>
                        <InputNumber class="form-control ebay-input" @bind-Value="request.AutoAcceptPrice" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Tự từ chối offer &lt; (₫)</label>
                        <InputNumber class="form-control ebay-input" @bind-Value="request.AutoDeclinePrice" />
                    </div>
                </div>
            }

            @if (suggestedAttributes.Any())
            {
                <div class="mb-3" style="background: #f0f7ff; border: 1px solid #c2dff7; border-radius: 8px; padding: 12px;">
                    <div class="fw-bold mb-2" style="font-size: 13px; color: #1a6bbf;">
                        💡 Gợi ý thuộc tính cho danh mục này:
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var hint in suggestedAttributes)
                        {
                            <button type="button"
                                    class="badge rounded-pill @(usedHints.Contains(hint) ? "bg-primary" : "bg-light border text-dark")"
                                    style="font-size: 12px; padding: 5px 10px; cursor: pointer;"
                                    @onclick="() => ApplyHintToVariants(hint)">
                                @(usedHints.Contains(hint) ? "✔ " : "+ ")@hint
                            </button>
                        }
                    </div>
                    <div class="text-muted mt-1" style="font-size: 11px;">Bấm vào một gợi ý để tự động thêm vào thuộc tính các biến thể.</div>
                </div>
            }
        </div>

        @* ─────────────── ITEM SPECIFICS (A5) ─────────────── *@
        @if (categoryItemSpecifics.Any())
        {
            <div class="ebay-card">
                <h4 class="ebay-card-title">📋 Thông Tin Chi Tiết (Item Specifics)</h4>
                <div class="text-muted mb-3" style="font-size: 12px;">Các trường đánh dấu <span class="text-danger fw-bold">*</span> là bắt buộc trước khi đăng bán.</div>
                
                @foreach (var spec in categoryItemSpecifics.OrderBy(s => s.SortOrder))
                {
                    var existing = itemSpecificsValues.FirstOrDefault(v => v.Name == spec.Name);
                    var isRequired = spec.Requirement == "REQUIRED";
                    var badgeClass = spec.Requirement switch
                    {
                        "REQUIRED" => "bg-danger",
                        "RECOMMENDED" => "bg-warning text-dark",
                        _ => "bg-secondary"
                    };
                    
                    <div class="mb-2 row align-items-center">
                        <div class="col-md-3">
                            <label class="form-label mb-0">
                                @spec.Name
                                @if (isRequired) { <span class="text-danger">*</span> }
                                <span class="badge @badgeClass ms-1" style="font-size: 10px;">@spec.Requirement</span>
                            </label>
                        </div>
                        <div class="col-md-9">
                            @if (!string.IsNullOrEmpty(spec.SuggestedValues))
                            {
                                var suggestions = spec.SuggestedValues.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                                <select class="form-select form-select-sm ebay-input" 
                                        value="@(existing != null ? existing.Value : string.Empty)"
                                        @onchange="(e) => SetItemSpecificValue(spec.Name, e.Value?.ToString())">
                                    <option value="">-- Chọn --</option>
                                    @foreach (var sug in suggestions)
                                    {
                                        <option value="@sug">@sug</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <input type="text" class="form-control form-control-sm ebay-input" 
                                       placeholder="Nhập giá trị..."
                                       value="@(existing != null ? existing.Value : string.Empty)"
                                       @onchange="(e) => SetItemSpecificValue(spec.Name, e.Value?.ToString())" />
                            }
                        </div>
                    </div>
                }
            </div>
        }

        @* ─────────────── ẢNH SẢN PHẨM ─────────────── *@
        <div class="ebay-card">
            <h4 class="ebay-card-title">Ảnh Sản Phẩm</h4>

            @* Ảnh bìa *@
            <div class="mb-4">
                <label class="form-label fw-bold">Ảnh Bìa (Primary Image) <span class="text-danger">*</span></label>
                <div class="upload-area @(isDraggingPrimary ? "dragging" : "")"
                     style="border: 2px dashed var(--border-color); border-radius: 10px; padding: 20px; text-align: center; background: #fafafa; position: relative; cursor: pointer;"
                     @ondragover:preventDefault @ondragover="() => isDraggingPrimary = true"
                     @ondragleave="() => isDraggingPrimary = false"
                     @ondrop:preventDefault>
                    @if (!string.IsNullOrEmpty(request.PrimaryImageUrl))
                    {
                        <div style="position: relative; display: inline-block;">
                            <img src="@request.PrimaryImageUrl" alt="Ảnh bìa" style="max-height: 180px; max-width: 100%; border-radius: 8px; object-fit: contain;" />
                            <button type="button" class="btn btn-sm btn-danger" style="position: absolute; top: -8px; right: -8px; width: 24px; height: 24px; padding: 0; border-radius: 50%; font-size: 12px;"
                                    @onclick="() => request.PrimaryImageUrl = null">✕</button>
                        </div>
                        <div class="mt-2 text-muted" style="font-size: 12px;">✅ Đã có ảnh bìa. Bấm ✕ để xóa và chọn ảnh khác.</div>
                    }
                    @if (isUploadingPrimary)
                    {
                        <div class="upload-loading-overlay" style="position: absolute; inset: 0; background: rgba(255,255,255,0.8); display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 3;">
                            <div class="spinner-border text-primary" role="status"></div>
                            <div class="text-muted mt-2">Đang tải ảnh lên...</div>
                        </div>
                    }

                    <InputFile OnChange="UploadPrimaryImage" accept="image/*" 
                               style="@($"position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; z-index: 2; display: {(isUploadingPrimary ? "none" : "block")}")" />
                    
                    @if (string.IsNullOrEmpty(request.PrimaryImageUrl))
                    {
                        <div class="my-2" style="display: @(isUploadingPrimary ? "none" : "block")">
                            <span style="font-size: 36px;">📷</span>
                            <div class="mt-2 fw-bold">Kéo thả ảnh vào đây hoặc</div>
                            <div class="text-muted" style="font-size: 12px;">JPG, PNG, WEBP — Tối đa 10MB</div>
                        </div>
                    }
                </div>
            </div>

            @* Ảnh phụ *@
            <div class="mb-2">
                <label class="form-label fw-bold">(Ảnh Phụ (tối đa 12) <span class="text-muted" style="font-size:11px;">-- eBay cho phép 24 ảnh</span></label>
                <div class="d-flex flex-wrap gap-2 align-items-center">
                    @for (int i = 0; i < extraImageUrls.Count; i++)
                    {
                        var idx = i;
                        <div style="position: relative; width: 90px; height: 90px;">
                            <img src="@extraImageUrls[idx]" alt="Ảnh phụ @(idx+1)"
                                 style="width: 90px; height: 90px; object-fit: cover; border-radius: 8px; border: 1px solid var(--border-color);" />
                            <button type="button" class="btn btn-sm btn-danger"
                                    style="position: absolute; top: -6px; right: -6px; width: 20px; height: 20px; padding: 0; border-radius: 50%; font-size: 10px;"
                                    @onclick="() => extraImageUrls.RemoveAt(idx)">✕</button>
                        </div>
                    }

                    @if (extraImageUrls.Count < 12)
                    {
                        <div style="width: 90px; height: 90px; border: 2px dashed #ccc; border-radius: 8px; display: flex; align-items: center; justify-content: center; position: relative; cursor: pointer; background: #fafafa;">
                            @if (isUploadingExtra)
                            {
                                <div class="spinner-border spinner-border-sm text-primary"></div>
                            }

                            @* Luôn giữ InputFile *@
                            <span style="font-size: 24px; color: #aaa; display: @(isUploadingExtra ? "none" : "block")">+</span>
                            <InputFile OnChange="UploadExtraImage" accept="image/*" 
                                       style="@($"position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; display: {(isUploadingExtra ? "none" : "block")}")" />
                        </div>
                    }
                </div>
                <small class="text-muted">Bấm ô + để thêm ảnh từ máy tính</small>
            </div>
        </div>

        <div class="ebay-card">
            <h4 class="ebay-card-title">Chính sách Bán Hàng</h4>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Shipping Policy</label>
                    <InputSelect class="form-select ebay-input" @bind-Value="request.ShippingPolicyId">
                        <option value="">-- Chọn Shipping Policy --</option>
                        @foreach (var p in shippingPolicies)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </InputSelect>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Return Policy</label>
                    <InputSelect class="form-select" @bind-Value="request.ReturnPolicyId">
                        <option value="">-- Chọn Return Policy --</option>
                        @foreach (var p in returnPolicies)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </InputSelect>
                </div>
            </div>
            <div class="row">
                <div class="col-md-12 mb-3">
                    <label class="form-label">Payment Policy</label>
                    <InputSelect class="form-select ebay-input" @bind-Value="request.PaymentPolicyId">
                        <option value="">-- Chọn Payment Policy (bỏ trống = dùng Default) --</option>
                        @foreach (var p in paymentPolicies)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </InputSelect>
                </div>
            </div>
        </div>

        @* ─────────────── BIẾN THỂ / SKU ─────────────── *@
        <div class="ebay-card">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4 class="ebay-card-title mb-0">Biến thể Sản Phẩm (SKUs)</h4>
                <div>
                    <span class="text-muted me-2">Số lượng: @request.Variants.Count / 250</span>
                    <button type="button" class="ebay-btn-outline btn-sm" @onclick="AddVariant" 
                            disabled="@(request.Variants.Count >= 250 || (request.ListingFormat == "AUCTION" && request.Variants.Count >= 1))">
                        + Thêm Biến Thể
                    </button>
                </div>
            </div>
            
            @foreach (var variant in request.Variants)
            {
                <div class="border p-3 mb-3 bg-light" style="border-radius: var(--border-radius-sm); border-color: var(--border-color) !important;">
                    <div class="row g-2 align-items-start">
                        @* Ảnh biến thể *@
                        <div class="col-md-1">
                            <label class="form-label" style="font-size: 12px;">Ảnh</label>
                            <div style="width: 60px; height: 60px; border: 2px dashed #ccc; border-radius: 8px; display: flex; align-items: center; justify-content: center; position: relative; background: #fff; cursor: pointer; overflow: hidden;">
                                @if (!string.IsNullOrEmpty(variant.ImageUrl))
                                {
                                    <img src="@variant.ImageUrl" alt="Ảnh biến thể"
                                         style="width: 100%; height: 100%; object-fit: cover;" />
                                    <div style="position: absolute; bottom: 0; left: 0; right: 0; background: rgba(0,0,0,0.4); text-align: center; cursor: pointer; font-size: 10px; color: white; padding: 2px;"
                                         @onclick="() => variant.ImageUrl = null">Xóa</div>
                                }
                                @if (uploadingVariants.Contains(variant))
                                {
                                    <div class="spinner-border spinner-border-sm text-primary"></div>
                                }
                                
                                @* Luôn giữ InputFile *@
                                <div style="display: @(uploadingVariants.Contains(variant) ? "none" : "flex"); align-items: center; justify-content: center; width: 100%; height: 100%;">
                                    <span style="font-size: 20px; color: #aaa;">📷</span>
                                    <InputFile OnChange="(e) => UploadVariantImage(e, variant)" accept="image/*"
                                               style="position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;" />
                                </div>
                            </div>
                        </div>

                        <div class="col-md-2">
                            <label class="form-label">Mã SKU *</label>
                            <InputText class="form-control" @bind-Value="variant.SkuCode" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Giá (VND) *</label>
                            <InputNumber class="form-control" @bind-Value="variant.Price" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Kho hàng *</label>
                            <InputNumber class="form-control" @bind-Value="variant.Quantity" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Khối lượng (gram)</label>
                            <InputNumber class="form-control" @bind-Value="variant.WeightGram" />
                        </div>
                    </div>

                    <div class="mt-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h6 class="fw-bold text-secondary mb-0">Thuộc tính động (VD: Color - Red)</h6>
                            @if (variantAttributesMap.ContainsKey(variant))
                            {
                                <span class="text-muted" style="font-size: 13px;">@variantAttributesMap[variant].Count / 5</span>
                            }
                        </div>
                        <button type="button" class="btn btn-sm btn-info mb-2 text-white" 
                                @onclick="() => AddAttribute(variant)" 
                                disabled="@(variantAttributesMap.ContainsKey(variant) && variantAttributesMap[variant].Count >= 5)">
                            + Thêm Thuộc Tính
                        </button>
                        
                        @if(variantAttributesMap.ContainsKey(variant))
                        {
                            @foreach (var attr in variantAttributesMap[variant])
                            {
                                <div class="d-flex mb-2 gap-2">
                                    <input type="text" class="form-control ebay-input" placeholder="Tên (VD: Màu sắc)" @bind="attr.Key" />
                                    <input type="text" class="form-control ebay-input" placeholder="Giá trị (VD: Đỏ)" @bind="attr.Value" />
                                    <button type="button" class="btn btn-danger" @onclick="() => RemoveAttribute(variant, attr)">Xóa</button>
                                </div>
                            }
                        }
                    </div>
                    <div class="text-end mt-2">
                        <button type="button" class="btn btn-sm btn-danger" @onclick="() => RemoveVariant(variant)">Xóa Biến Thể Này</button>
                    </div>
                </div>
            }
        </div>

        <div class="ebay-card">
            <h4 class="ebay-card-title">⏰ Hẹn Giờ Đăng Bán (Schedule)</h4>
            <div class="mb-2 text-muted" style="font-size: 13px;">Bỏ trống nếu muốn đăng ngay. Chọn ngày giờ để sản phẩm tự động xuất hiện vào lúc đó.</div>
            <div class="d-flex align-items-center gap-3">
                <input type="datetime-local" class="form-control ebay-input"
                       style="max-width: 300px;"
                       value="@(request.ScheduledAt.HasValue ? request.ScheduledAt.Value.LocalDateTime.ToString("yyyy-MM-ddTHH:mm") : "")"
                       @onchange="OnScheduledAtChanged" />
                @if (request.ScheduledAt.HasValue)
                {
                    <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => request.ScheduledAt = null">
                        ✕ Xóa hẹn giờ
                    </button>
                    <span class="badge bg-info text-dark">⏰ Sẽ đăng lúc @request.ScheduledAt.Value.LocalDateTime.ToString("HH:mm dd/MM/yyyy")</span>
                }
            </div>
        </div>

        <div class="d-flex gap-3 mt-3 mb-5">
            <button type="submit" class="ebay-btn-outline btn-lg flex-fill" style="padding: 12px; font-size: 15px;" @onclick="() => SetSubmitMode(0)">
                @if(isSubmitting && submitMode==0) { <span class="spinner-border spinner-border-sm me-2"></span><span>Đang lưu...</span> } else { <span>💾 Lưu Nháp (DRAFT)</span> }
            </button>
            @if (request.ScheduledAt.HasValue)
            {
                <button type="submit" class="btn btn-lg btn-info text-white flex-fill" style="padding: 12px; font-size: 15px;" @onclick="() => SetSubmitMode(2)">
                    @if(isSubmitting && submitMode==2) { <span class="spinner-border spinner-border-sm me-2"></span><span>Đang lưu hẹn...</span> } else { <span>⏰ Hẹn Giờ Đăng</span> }
                </button>
            }
            <button type="submit" class="ebay-btn-primary btn-lg flex-fill" style="padding: 12px; font-size: 15px;" @onclick="() => SetSubmitMode(1)">
                @if(isSubmitting && submitMode==1) { <span class="spinner-border spinner-border-sm me-2"></span><span>Đang đăng bán...</span> } else { <span>🚀 Đăng Bán Ngay (ACTIVE)</span> }
            </button>
        </div>
        </fieldset>
    </EditForm>
</div>


@code {
    private CreateListingRequest request = new CreateListingRequest();
    private List<ShippingPolicyDto> shippingPolicies = new();
    private List<ReturnPolicyDto> returnPolicies = new();
    private List<PaymentPolicyDto> paymentPolicies = new();
    private List<CategoryDto> categories = new();
    private string? errorMessage;
    private bool isSubmitting = false;
    private int submitMode = 0; // 0=DRAFT, 1=ACTIVE, 2=SCHEDULED
    private bool publishOnCreate => submitMode == 1; // compat

    // Gợi ý thuộc tính theo danh mục
    private List<string> suggestedAttributes = new();
    private HashSet<string> usedHints = new();

    // [A5] Item Specifics dynamic form state
    private List<CategoryItemSpecificDto> categoryItemSpecifics = new();
    private List<ItemSpecificInput> itemSpecificsValues = new();

    private async Task OnCategoryChanged()
    {
        var selectedCat = categories.FirstOrDefault(c => c.Id == request.CategoryId);
        suggestedAttributes = selectedCat?.SuggestedAttributes ?? new();
        usedHints.Clear();

        // [A5] Load Item Specifics cho category đã chọn
        categoryItemSpecifics = new();
        itemSpecificsValues = new();
        if (request.CategoryId != Guid.Empty)
        {
            try
            {
                var specs = await CategoryService.GetItemSpecificsByCategoryIdAsync(request.CategoryId);
                categoryItemSpecifics = specs.ToList();
                // Pre-populate empty values cho REQUIRED + RECOMMENDED
                foreach (var spec in categoryItemSpecifics)
                {
                    itemSpecificsValues.Add(new ItemSpecificInput { Name = spec.Name, Value = "" });
                }
            }
            catch { /* silent — category mới không có specifics là bình thường */ }
        }
    }

    private void SetItemSpecificValue(string name, string value)
    {
        var existing = itemSpecificsValues.FirstOrDefault(v => v.Name == name);
        if (existing != null)
            existing.Value = value;
        else
            itemSpecificsValues.Add(new ItemSpecificInput { Name = name, Value = value });
    }

    // Bấm chip gợi ý → toggle thêm/xóa key đó vào tất cả biến thể
    private void ApplyHintToVariants(string hint)
    {
        bool alreadyUsed = usedHints.Contains(hint);
        foreach (var variant in request.Variants)
        {
            if (!variantAttributesMap.ContainsKey(variant)) continue;
            var attrs = variantAttributesMap[variant];
            if (alreadyUsed)
            {
                attrs.RemoveAll(a => a.Key == hint);
            }
            else
            {
                if (!attrs.Any(a => a.Key == hint) && attrs.Count < 5)
                    attrs.Add(new AttributePair { Key = hint, Value = "" });
            }
        }
        if (alreadyUsed) usedHints.Remove(hint);
        else usedHints.Add(hint);
    }


    // Ảnh sản phẩm phụ
    private List<string> extraImageUrls = new();

    // Trạng thái upload
    private bool isUploadingPrimary = false;
    private bool isUploadingExtra = false;
    private bool isDraggingPrimary = false;
    private HashSet<CreateVariantRequest> uploadingVariants = new();

    // Helper class để bind dictionary attributes
    public class AttributePair
    {
        public string Key { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
    }

    private Dictionary<CreateVariantRequest, List<AttributePair>> variantAttributesMap = new();

    // Query params từ StartListing wizard
    [SupplyParameterFromQuery(Name = "categoryId")] public Guid? InitCategoryId { get; set; }
    [SupplyParameterFromQuery(Name = "condition")] public string? InitCondition { get; set; }
    [SupplyParameterFromQuery(Name = "conditionDesc")] public string? InitConditionDescription { get; set; }

    private string selectedCategoryFullPath = string.Empty; // breadcrumb hiển thị
    private string upcCode = string.Empty; // UPC/EAN/ISBN/MPN field

    protected override async Task OnInitializedAsync()
    {
        await LoadPageDataAsync();
    }

    private async Task LoadPageDataAsync()
    {
        try
        {
            var cats = await CategoryService.GetCategoriesAsync();
            categories = cats.ToList();

            var sp = await PolicyService.GetShippingPoliciesAsync();
            shippingPolicies = sp.ToList();

            var rp = await PolicyService.GetReturnPoliciesAsync();
            returnPolicies = rp.ToList();

            var pp = await PolicyService.GetPaymentPoliciesAsync();
            paymentPolicies = pp.ToList();

            // Nhận categoryId từ query params (từ StartListing wizard)
            if (InitCategoryId.HasValue && InitCategoryId != Guid.Empty)
            {
                request.CategoryId = InitCategoryId.Value;
                await OnCategoryChanged();

                // Build breadcrumb path từ categories đã load
                var selectedCat = categories.FirstOrDefault(c => c.Id == request.CategoryId);
                if (selectedCat != null)
                {
                    var parent = categories.FirstOrDefault(c => c.Id == selectedCat.ParentId);
                    selectedCategoryFullPath = parent != null
                        ? $"{parent.Name} > {selectedCat.Name}"
                        : selectedCat.Name;
                }
            }

            // Nhận condition từ query params
            if (!string.IsNullOrEmpty(InitCondition))
                request.Condition = Uri.UnescapeDataString(InitCondition);

            if (!string.IsNullOrEmpty(InitConditionDescription))
                request.ConditionDescription = Uri.UnescapeDataString(InitConditionDescription);

            // Khởi tạo sẵn 1 biến thể mặc định
            AddVariant();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
    }

    private void GoToStartListingToChangeCategory()
    {
        NavigationManager.NavigateTo("/listings/start");
    }

    // ─── HẸN GIỜ ĐĂNG BÁN ───

    private void SetSubmitMode(int mode) => submitMode = mode;

    private void OnScheduledAtChanged(ChangeEventArgs e)
    {
        if (DateTime.TryParse(e.Value?.ToString(), out var dt))
            // Dùng Local timezone của máy client thay vì hardcode UTC+7
            // DateTimeOffset.Local sẽ tự lấy timezone của hệ điều hành người dùng
            request.ScheduledAt = new DateTimeOffset(DateTime.SpecifyKind(dt, DateTimeKind.Local));
        else
            request.ScheduledAt = null;
    }

    // ─── UPLOAD ẢNH SẢN PHẨM ───

    private async Task UploadPrimaryImage(InputFileChangeEventArgs e)
    {
        isUploadingPrimary = true;
        errorMessage = null;
        StateHasChanged();
        try
        {
            var url = await FileUploadService.UploadImageAsync(e.File);
            request.PrimaryImageUrl = url;
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi upload ảnh bìa: {ex.Message}";
        }
        finally
        {
            isUploadingPrimary = false;
        }
    }

    private async Task UploadExtraImage(InputFileChangeEventArgs e)
    {
        if (extraImageUrls.Count >= 12) return;
        isUploadingExtra = true;
        errorMessage = null;
        StateHasChanged();
        try
        {
            var url = await FileUploadService.UploadImageAsync(e.File);
            extraImageUrls.Add(url);
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi upload ảnh phụ: {ex.Message}";
        }
        finally
        {
            isUploadingExtra = false;
        }
    }

    // ─── UPLOAD ẢNH BIẾN THỂ ───

    private async Task UploadVariantImage(InputFileChangeEventArgs e, CreateVariantRequest variant)
    {
        uploadingVariants.Add(variant);
        errorMessage = null;
        StateHasChanged();
        try
        {
            var url = await FileUploadService.UploadImageAsync(e.File);
            variant.ImageUrl = url;
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi upload ảnh biến thể: {ex.Message}";
        }
        finally
        {
            uploadingVariants.Remove(variant);
        }
    }

    // ─── QUẢN LÝ BIẾN THỂ ───

    private void AddVariant()
    {
        if (request.Variants.Count >= 250) return;
        if (request.ListingFormat == "AUCTION" && request.Variants.Count >= 1) return;
        var newVariant = new CreateVariantRequest();
        request.Variants.Add(newVariant);
        variantAttributesMap[newVariant] = new List<AttributePair>();
    }

    private void RemoveVariant(CreateVariantRequest variant)
    {
        request.Variants.Remove(variant);
        variantAttributesMap.Remove(variant);
        uploadingVariants.Remove(variant);
    }

    private void AddAttribute(CreateVariantRequest variant)
    {
        if (variantAttributesMap.ContainsKey(variant) && variantAttributesMap[variant].Count < 5)
        {
            variantAttributesMap[variant].Add(new AttributePair());
        }
    }

    private void RemoveAttribute(CreateVariantRequest variant, AttributePair attr)
    {
        if (variantAttributesMap.ContainsKey(variant))
        {
            variantAttributesMap[variant].Remove(attr);
        }
    }

    // ─── SUBMIT ───

    private async Task HandleSubmit()
    {
        errorMessage = null;
        isSubmitting = true;

        try
        {
            // Rebuild Attributes Dictionary from Map
            foreach (var variant in request.Variants)
            {
                variant.Attributes.Clear();
                if (variantAttributesMap.ContainsKey(variant))
                {
                    foreach (var attr in variantAttributesMap[variant])
                    {
                        if (!string.IsNullOrWhiteSpace(attr.Key) && !string.IsNullOrWhiteSpace(attr.Value))
                        {
                            variant.Attributes[attr.Key] = attr.Value;
                        }
                    }
                }
            }

            // Gom ảnh phụ
            request.ImageUrls = extraImageUrls.Where(u => !string.IsNullOrWhiteSpace(u)).ToList();

            // [A5] Sync Item Specifics values → request
            request.ItemSpecifics = itemSpecificsValues
                .Where(v => !string.IsNullOrWhiteSpace(v.Value))
                .ToList();

            // UPC/EAN/ISBN/MPN → thêm vào Item Specifics nếu có
            if (!string.IsNullOrWhiteSpace(upcCode))
            {
                if (!request.ItemSpecifics.Any(s => s.Name is "UPC" or "EAN" or "ISBN" or "MPN"))
                    request.ItemSpecifics.Add(new ItemSpecificInput { Name = "UPC", Value = upcCode.Trim() });
            }

            var productId = await ProductService.CreateListingAsync(request);
            
            // submitMode: 0=DRAFT (mặc định từ backend), 1=ACTIVE, 2=SCHEDULED (đã handled trong usecase)
            if (submitMode == 1) // Publish ngay
            {
                await ProductService.UpdateProductStatusAsync(productId, "ACTIVE");
            }
            // submitMode == 2: ScheduledAt đã được gửi kèm, backend tự set SCHEDULED
            
            NavigationManager.NavigateTo("/listings");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
