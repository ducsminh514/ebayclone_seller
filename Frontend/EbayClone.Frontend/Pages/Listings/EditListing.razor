@page "/listings/edit/{Id:guid}"
@using EbayClone.Shared.DTOs.Products
@using EbayClone.Shared.DTOs.Policies
@using EbayClone.Frontend.Services
@inject ProductService ProductService
@inject PolicyService PolicyService
@inject CategoryService CategoryService
@inject FileUploadService FileUploadService
@inject NavigationManager NavigationManager
@using Microsoft.AspNetCore.Components.Forms

<div class="container mt-4">
    <h2>Sửa Thông Tin Sản Phẩm</h2>
    <hr />

    @if (isLoading)
    {
        <div class="p-4 text-center">Đang tải dữ liệu sản phẩm...</div>
    }
    else if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }
    else
    {
        <EditForm Model="fullRequest" OnValidSubmit="HandleSubmit">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <fieldset disabled="@isSubmitting">
                <div class="ebay-card">
                    <h4 class="ebay-card-title">Thông tin cơ bản (Master Data)</h4>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Ảnh bìa (Primary Image) *</label>
                        <div class="ebay-upload-box" style="width: 200px; height: 200px; position: relative; border: 2px dashed #0052ff; border-radius: 12px; overflow: hidden; display: flex; align-items: center; justify-content: center; background: #f8f9ff;">
                            @if (!string.IsNullOrEmpty(fullRequest.PrimaryImageUrl))
                            {
                                <img src="@fullRequest.PrimaryImageUrl" class="w-100 h-100" style="object-fit: cover;" />
                                <div class="upload-overlay" style="position: absolute; inset: 0; background: rgba(0,0,0,0.3); opacity: 0; transition: 0.3s; display: flex; align-items: center; justify-content: center;">
                                    <span class="text-white fw-bold">Thay đổi ảnh</span>
                                </div>
                            }

                            @if (isUploadingPrimary)
                            {
                                <div class="upload-loading-overlay" style="position: absolute; inset: 0; background: rgba(255,255,255,0.8); display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 3;">
                                    <div class="spinner-border spinner-border-sm text-primary"></div>
                                    <div class="text-muted mt-2" style="font-size: 11px;">Đang tải...</div>
                                </div>
                            }

                            @* Luôn giữ InputFile trong DOM để tránh lỗi _blazorFilesById*@
                            <InputFile OnChange="UploadPrimaryImage" accept="image/*" 
                                       style="@($"position: absolute; inset: 0; opacity: 0; cursor: pointer; z-index: 2; display: {(isUploadingPrimary ? "none" : "block")}")" />
                            
                            @if (string.IsNullOrEmpty(fullRequest.PrimaryImageUrl))
                            {
                                <div class="text-center" style="display: @(isUploadingPrimary ? "none" : "block")">
                                    <span style="font-size: 32px;">📷</span>
                                    <div class="text-muted mt-1" style="font-size: 12px;">Bấm để chọn</div>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Ảnh phụ (Tối đa 5)</label>
                        <div class="d-flex flex-wrap gap-2">
                            @for (int i = 0; i < extraImageUrls.Count; i++)
                            {
                                var idx = i;
                                <div style="position: relative; width: 80px; height: 80px;">
                                    <img src="@extraImageUrls[idx]" style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px; border: 1px solid #ddd;" />
                                    <button type="button" class="btn btn-sm btn-danger p-0" style="position: absolute; top: -5px; right: -5px; width: 18px; height: 18px; border-radius: 50%;" @onclick="() => extraImageUrls.RemoveAt(idx)">✕</button>
                                </div>
                            }
                            @if (extraImageUrls.Count < 5)
                            {
                                <div style="width: 80px; height: 80px; border: 2px dashed #ccc; border-radius: 8px; display: flex; align-items: center; justify-content: center; position: relative;">
                                    @if (isUploadingExtra)
                                    {
                                        <div class="spinner-border spinner-border-sm text-primary"></div>
                                    }
                                    
                                    @* Luôn giữ InputFile *@
                                    <span class="text-secondary" style="display: @(isUploadingExtra ? "none" : "block")">+</span>
                                    <InputFile OnChange="UploadExtraImage" accept="image/*" 
                                               style="@($"position: absolute; inset: 0; opacity: 0; cursor: pointer; display: {(isUploadingExtra ? "none" : "block")}")" />
                                </div>
                            }
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên sản phẩm *</label>
                        <InputText class="form-control ebay-input" @bind-Value="fullRequest.Name" placeholder="Ví dụ: iPhone 15 Pro Max 256GB Gold" />
                        <ValidationMessage For="@(() => fullRequest.Name)" />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mô tả chi tiết</label>
                        <InputTextArea class="form-control ebay-input" @bind-Value="fullRequest.Description" rows="5" placeholder="Mô tả các tính năng, tình trạng sản phẩm..." />
                    </div>

                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">Thương hiệu</label>
                            <InputText class="form-control ebay-input" @bind-Value="fullRequest.Brand" placeholder="Ví dụ: Apple, Samsung..." />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">Danh mục *</label>
                            <InputSelect class="form-select ebay-input" @bind-Value="fullRequest.CategoryId">
                                <option value="">-- Chọn danh mục --</option>
                                @foreach (var cat in categories)
                                {
                                    var prefix = cat.ParentId.HasValue ? "   └ " : "";
                                    <option value="@cat.Id">@prefix@cat.Name</option>
                                }
                            </InputSelect>
                            <ValidationMessage For="@(() => fullRequest.CategoryId)" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">Tình trạng *</label>
                            <InputSelect class="form-select ebay-input" @bind-Value="fullRequest.Condition">
                                <option value="New">Mới (New)</option>
                                <option value="New Other">Mới khác (New Other)</option>
                                <option value="Open Box">Đã khui hộp (Open Box)</option>
                                <option value="Seller Refurbished">Đã tân trang (Refurbished)</option>
                                <option value="Used">Đã qua sử dụng (Used)</option>
                                <option value="For Parts">Dùng linh kiện (For Parts)</option>
                            </InputSelect>
                        </div>
                    </div>
                    @if (fullRequest.Condition != "New")
                    {
                        <div class="mb-3">
                            <label class="form-label">Mô tả tình trạng (vết xước, thiếu phụ kiện...)</label>
                            <InputTextArea class="form-control ebay-input" @bind-Value="fullRequest.ConditionDescription" rows="2" placeholder="Mô tả chi tiết tình trạng sản phẩm..." />
                        </div>
                    }
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">Hình thức bán</label>
                            <InputSelect class="form-select ebay-input" @bind-Value="fullRequest.ListingFormat">
                                <option value="FIXED_PRICE">Giá cố định (Fixed Price)</option>
                                <option value="AUCTION">Đấu giá (Auction)</option>
                            </InputSelect>
                            @if (fullRequest.ListingFormat == "AUCTION" && fullRequest.Variants.Count > 1)
                            {
                                <div class="text-danger mt-1" style="font-size: 12px;">⚠️ Auction chỉ cho phép đúng 1 biến thể. Hiện có @fullRequest.Variants.Count — hãy xóa bớt trước khi lưu.</div>
                            }
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label fw-bold">Subtitle (phụ đề SEO)</label>
                            <InputText class="form-control ebay-input" @bind-Value="fullRequest.Subtitle" placeholder="Phụ đề hiển thị trong kết quả tìm kiếm" />
                        </div>
                        <div class="col-md-4 mb-3 d-flex align-items-end">
                            <div class="form-check">
                                <InputCheckbox class="form-check-input" @bind-Value="fullRequest.AllowOffers" />
                                <label class="form-check-label">Cho phép đặt giá (Best Offer)</label>
                            </div>
                        </div>
                    </div>

                    @if (fullRequest.AllowOffers)
                    {
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Tự chấp nhận offer ≥ (₫)</label>
                                <InputNumber class="form-control ebay-input" @bind-Value="fullRequest.AutoAcceptPrice" />
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Tự từ chối offer &lt; (₫)</label>
                                <InputNumber class="form-control ebay-input" @bind-Value="fullRequest.AutoDeclinePrice" />
                            </div>
                        </div>
                    }
                </div>

                @* ─── ITEM SPECIFICS (GAP-2) ─── *@
                @if (categoryItemSpecifics.Any())
                {
                    <div class="ebay-card">
                        <h4 class="ebay-card-title">📋 Thông Tin Chi Tiết (Item Specifics)</h4>
                        <div class="text-muted mb-3" style="font-size: 12px;">Các trường đánh dấu <span class="text-danger fw-bold">*</span> là bắt buộc trước khi đăng bán.</div>
                        
                        @foreach (var spec in categoryItemSpecifics.OrderBy(s => s.SortOrder))
                        {
                            var existing = fullRequest.ItemSpecifics?.FirstOrDefault(v => v.Name == spec.Name);
                            var isRequired = spec.Requirement == "REQUIRED";
                            var badgeClass = spec.Requirement switch
                            {
                                "REQUIRED" => "bg-danger",
                                "RECOMMENDED" => "bg-warning text-dark",
                                _ => "bg-secondary"
                            };
                            
                            <div class="mb-2 row align-items-center">
                                <div class="col-md-3">
                                    <label class="form-label mb-0">
                                        @spec.Name
                                        @if (isRequired) { <span class="text-danger">*</span> }
                                        <span class="badge @badgeClass ms-1" style="font-size: 10px;">@spec.Requirement</span>
                                    </label>
                                </div>
                                <div class="col-md-9">
                                    @if (!string.IsNullOrEmpty(spec.SuggestedValues))
                                    {
                                        var suggestions = spec.SuggestedValues.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);
                                        <select class="form-select form-select-sm ebay-input" 
                                                value="@(existing != null ? existing.Value : string.Empty)"
                                                @onchange="(e) => SetItemSpecificValue(spec.Name, e.Value?.ToString())">
                                            <option value="">-- Chọn --</option>
                                            @foreach (var sug in suggestions)
                                            {
                                                <option value="@sug">@sug</option>
                                            }
                                        </select>
                                    }
                                    else
                                    {
                                        <input type="text" class="form-control form-control-sm ebay-input" 
                                               placeholder="Nhập giá trị..."
                                               value="@(existing != null ? existing.Value : string.Empty)"
                                               @onchange="(e) => SetItemSpecificValue(spec.Name, e.Value?.ToString())" />
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }

                <div class="ebay-card">
                    <h4 class="ebay-card-title">Chính sách Bán Hàng & Trạng Thái</h4>
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Shipping Policy</label>
                            <InputSelect class="form-select ebay-input" @bind-Value="fullRequest.ShippingPolicyId">
                                <option value="">-- Chọn Shipping Policy --</option>
                                @foreach (var p in shippingPolicies)
                                {
                                    <option value="@p.Id">@p.Name</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Return Policy</label>
                            <InputSelect class="form-select" @bind-Value="fullRequest.ReturnPolicyId">
                                <option value="">-- Chọn Return Policy --</option>
                                @foreach (var p in returnPolicies)
                                {
                                    <option value="@p.Id">@p.Name</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Payment Policy</label>
                            <InputSelect class="form-select ebay-input" @bind-Value="fullRequest.PaymentPolicyId">
                                <option value="">-- Chọn Payment Policy (bỏ trống = dùng Default) --</option>
                                @foreach (var p in paymentPolicies)
                                {
                                    <option value="@p.Id">@p.Name</option>
                                }
                            </InputSelect>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Trạng Thái Hiển Thị</label>
                            <InputSelect class="form-select" @bind-Value="fullRequest.Status">
                                <option value="DRAFT">DRAFT (Bản Nháp)</option>
                                <option value="ACTIVE">ACTIVE (Mở Bán)</option>
                                <option value="SCHEDULED">SCHEDULED (Hẹn Giờ)</option>
                                <option value="HIDDEN">HIDDEN (Ẩn)</option>
                                <option value="ENDED">ENDED (Kết Thúc)</option>
                                @if (fullRequest.Status == "OUT_OF_STOCK")
                                {
                                    <option value="OUT_OF_STOCK" disabled>OUT_OF_STOCK (Tự động - Hết hàng)</option>
                                }
                            </InputSelect>
                            @if (fullRequest.Status == "OUT_OF_STOCK")
                            {
                                <div class="text-warning mt-1" style="font-size: 12px;">⚠️ Trạng thái này tự động khi tất cả biến thể hết hàng. Nhập kho để chuyển về ACTIVE.</div>
                            }
                            @if (fullRequest.Status == "ENDED")
                            {
                                <div class="text-danger mt-1" style="font-size: 12px;">🛑 Listing đã kết thúc. Không thể chỉnh sửa hoặc mở lại. Hãy tạo listing mới (relist).</div>
                            }
                        </div>
                    </div>
                </div>

                <div class="ebay-card">
                    <h4 class="ebay-card-title">📦 Quản lý Biến thể (Variants)</h4>
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead>
                                <tr>
                                    <th>Phân loại (Attributes)</th>
                                    <th>SKU Code</th>
                                    <th>Giá Bán (₫)</th>
                                    <th>Kho hàng</th>
                                    <th>Khối lượng (g)</th>
                                    <th>Ảnh</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var v in fullRequest.Variants)
                                {
                                    <tr>
                                        <td>
                                            @foreach (var attr in v.Attributes)
                                            {
                                                <div class="badge bg-light text-dark me-1 border">@attr.Key: @attr.Value</div>
                                            }
                                        </td>
                                        <td>
                                            <input type="text" class="form-control form-control-sm" @bind="v.SkuCode" />
                                        </td>
                                        <td>
                                            <input type="number" class="form-control form-control-sm" @bind="v.Price" step="1000" />
                                        </td>
                                        <td>
                                            <input type="number" class="form-control form-control-sm" @bind="v.Quantity" min="0" />
                                        </td>
                                        <td>
                                            <input type="number" class="form-control form-control-sm" @bind="v.WeightGram" min="1" placeholder="gram" />
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(v.ImageUrl))
                                            {
                                                <div style="position: relative; display: inline-block;">
                                                    <img src="@v.ImageUrl" style="width: 45px; height: 45px; object-fit: cover; border-radius: 4px;" />
                                                    <button type="button" class="btn btn-sm btn-danger p-0" style="position: absolute; top: -5px; right: -5px; width: 14px; height: 14px; border-radius: 50%; font-size: 8px;" @onclick="() => v.ImageUrl = null">✕</button>
                                                </div>
                                            }
                                            else
                                            {
                                                <div style="width: 45px; height: 45px; border: 1px dashed #aaa; border-radius: 4px; display: flex; align-items: center; justify-content: center; position: relative;">
                                                    @if (uploadingVariants.Contains(v))
                                                    {
                                                        <div class="spinner-border spinner-border-sm text-primary"></div>
                                                    }
                                                    
                                                    @* Luôn giữ InputFile *@
                                                    <div style="@($"display: {(uploadingVariants.Contains(v) ? "none" : "flex")}; align-items: center; justify-content: center; width: 100%; height: 100%;")">
                                                        <span style="font-size: 12px; color: #888;">+ 📷</span>
                                                        <InputFile OnChange="(e) => UploadVariantImage(e, v)" accept="image/*" style="position: absolute; inset: 0; opacity: 0; cursor: pointer;" />
                                                    </div>
                                                </div>
                                            }
                                        </td>
                                        <td>
                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => fullRequest.Variants.Remove(v)">Xóa</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                </div>

                @* ─── FORM THÊM BIẾN THỂ MỚI ─── *@
                <div class="mt-3 border-top pt-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted" style="font-size: 13px;">
                            Tổng: @fullRequest.Variants.Count / 250 biến thể
                        </span>
                        <button type="button" class="ebay-btn-outline btn-sm" 
                                @onclick="ToggleAddVariantForm"
                                disabled="@(fullRequest.Variants.Count >= 250 || (fullRequest.ListingFormat == "AUCTION" && fullRequest.Variants.Count >= 1))">
                            @(showAddVariantForm ? "✕ Đóng" : "+ Thêm Biến Thể Mới")
                        </button>
                    </div>

                    @if (showAddVariantForm)
                    {
                        <div class="border p-3 bg-light" style="border-radius: 8px; border-color: var(--primary-color) !important; border-width: 2px !important;">
                            <h6 class="fw-bold mb-3" style="color: var(--primary-color);">📝 Nhập thông tin biến thể mới</h6>
                            <div class="row g-2">
                                <div class="col-md-3">
                                    <label class="form-label" style="font-size: 12px;">Mã SKU *</label>
                                    <input type="text" class="form-control form-control-sm" @bind="newVariant.SkuCode" placeholder="VD: SHIRT-RED-M" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 12px;">Giá (₫) *</label>
                                    <input type="number" class="form-control form-control-sm" @bind="newVariant.Price" step="1000" min="100" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 12px;">Kho hàng *</label>
                                    <input type="number" class="form-control form-control-sm" @bind="newVariant.Quantity" min="0" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label" style="font-size: 12px;">Khối lượng (g)</label>
                                    <input type="number" class="form-control form-control-sm" @bind="newVariant.WeightGram" min="1" placeholder="gram" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label" style="font-size: 12px;">Ảnh</label>
                                    <div class="d-flex align-items-center gap-2">
                                        @if (!string.IsNullOrEmpty(newVariant.ImageUrl))
                                        {
                                            <img src="@newVariant.ImageUrl" style="width: 36px; height: 36px; object-fit: cover; border-radius: 4px;" />
                                            <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => newVariant.ImageUrl = null">✕</button>
                                        }
                                        else
                                        {
                                            <div style="width: 36px; height: 36px; border: 1px dashed #aaa; border-radius: 4px; position: relative; display: flex; align-items: center; justify-content: center;">
                                                @if (isUploadingNewVariantImage)
                                                {
                                                    <div class="spinner-border spinner-border-sm text-primary"></div>
                                                }
                                                else
                                                {
                                                    <span style="font-size: 12px; color: #888;">📷</span>
                                                    <InputFile OnChange="UploadNewVariantImage" accept="image/*" style="position: absolute; inset: 0; opacity: 0; cursor: pointer;" />
                                                }
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>

                            @* Thuộc tính cho variant mới *@
                            <div class="mt-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <h6 class="fw-bold text-secondary mb-0" style="font-size: 13px;">Thuộc tính (VD: Color - Red)</h6>
                                    <div>
                                        <span class="text-muted me-2" style="font-size: 12px;">@newVariantAttributes.Count / 5</span>
                                        <button type="button" class="btn btn-sm btn-info text-white" 
                                                @onclick="AddNewVariantAttribute" 
                                                disabled="@(newVariantAttributes.Count >= 5)">
                                            + Thuộc tính
                                        </button>
                                    </div>
                                </div>
                                @foreach (var attr in newVariantAttributes)
                                {
                                    <div class="d-flex mb-2 gap-2">
                                        <input type="text" class="form-control form-control-sm" placeholder="Tên (VD: Màu)" @bind="attr.Key" />
                                        <input type="text" class="form-control form-control-sm" placeholder="Giá trị (VD: Đỏ)" @bind="attr.Value" />
                                        <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => newVariantAttributes.Remove(attr)">✕</button>
                                    </div>
                                }
                            </div>

                            <div class="d-flex gap-2 mt-3">
                                <button type="button" class="btn btn-sm btn-success" @onclick="ConfirmAddVariant">
                                    ✓ Thêm vào danh sách
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="ToggleAddVariantForm">
                                    Hủy
                                </button>
                            </div>

                            @if (!string.IsNullOrEmpty(addVariantError))
                            {
                                <div class="alert alert-danger mt-2 mb-0 py-1" style="font-size: 12px;">@addVariantError</div>
                            }
                        </div>
                    }
                </div>
                </div>

                <div class="d-flex mb-5 gap-3">
                    <button type="button" class="btn btn-outline-secondary btn-lg w-50" @onclick='() => NavigationManager.NavigateTo("/listings")'>
                        Hủy Bỏ
                    </button>
                    <button type="submit" class="ebay-btn-primary btn-lg w-50">
                        @if (isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span><span>Đang lưu...</span>
                        }
                        else
                        {
                            <span>Lưu thay đổi</span>
                        }
                    </button>
                </div>
            </fieldset>
        </EditForm>
    }
</div>

@using System.Text.Json
@code {
    [Parameter]
    public Guid Id { get; set; }

    private UpdateFullProductRequest fullRequest = new();
    private List<ShippingPolicyDto> shippingPolicies = new();
    private List<ReturnPolicyDto> returnPolicies = new();
    private List<PaymentPolicyDto> paymentPolicies = new();
    private List<CategoryDto> categories = new();
    private List<CategoryItemSpecificDto> categoryItemSpecifics = new();
    
    private bool isLoading = true;
    private bool isSubmitting = false;
    private string? errorMessage;

    private List<string> extraImageUrls = new();
    private bool isUploadingPrimary = false;
    private bool isUploadingExtra = false;
    private HashSet<UpdateVariantDto> uploadingVariants = new();

    // ─── State cho form thêm biến thể mới ───
    private bool showAddVariantForm = false;
    private UpdateVariantDto newVariant = new();
    private List<AttributePair> newVariantAttributes = new();
    private string? addVariantError;
    private bool isUploadingNewVariantImage = false;

    private class AttributePair
    {
        public string Key { get; set; } = "";
        public string Value { get; set; } = "";
    }

    private void ToggleAddVariantForm()
    {
        showAddVariantForm = !showAddVariantForm;
        if (showAddVariantForm)
        {
            newVariant = new UpdateVariantDto();
            newVariantAttributes = new List<AttributePair>();
            addVariantError = null;
        }
    }

    private void AddNewVariantAttribute()
    {
        if (newVariantAttributes.Count < 5)
            newVariantAttributes.Add(new AttributePair());
    }

    private void ConfirmAddVariant()
    {
        addVariantError = null;

        // Validate
        if (string.IsNullOrWhiteSpace(newVariant.SkuCode))
        { addVariantError = "Mã SKU là bắt buộc."; return; }

        if (newVariant.Price <= 0)
        { addVariantError = "Giá phải lớn hơn 0."; return; }

        if (newVariant.Quantity < 0)
        { addVariantError = "Kho hàng không được âm."; return; }

        // Check SKU trùng với variant hiện có
        if (fullRequest.Variants.Any(v => v.SkuCode.Equals(newVariant.SkuCode, StringComparison.OrdinalIgnoreCase)))
        { addVariantError = $"SKU '{newVariant.SkuCode}' đã tồn tại trong danh sách."; return; }

        // Validate attributes
        var validAttrs = newVariantAttributes
            .Where(a => !string.IsNullOrWhiteSpace(a.Key) && !string.IsNullOrWhiteSpace(a.Value))
            .ToList();
        
        if (!validAttrs.Any())
        { addVariantError = "Cần ít nhất 1 thuộc tính (VD: Color - Red)."; return; }

        var dupKeys = validAttrs.GroupBy(a => a.Key, StringComparer.OrdinalIgnoreCase)
                                .Where(g => g.Count() > 1)
                                .Select(g => g.Key)
                                .ToList();
        if (dupKeys.Any())
        { addVariantError = $"Tên thuộc tính bị trùng: {string.Join(", ", dupKeys)}"; return; }

        // Build variant DTO (Id = null → BE sẽ tạo mới)
        var variantToAdd = new UpdateVariantDto
        {
            Id = null, // Signal cho BE: tạo mới
            SkuCode = newVariant.SkuCode,
            Price = newVariant.Price,
            Quantity = newVariant.Quantity,
            WeightGram = newVariant.WeightGram,
            ImageUrl = newVariant.ImageUrl,
            Attributes = validAttrs.ToDictionary(a => a.Key, a => a.Value)
        };

        fullRequest.Variants.Add(variantToAdd);

        // Reset form
        newVariant = new UpdateVariantDto();
        newVariantAttributes = new List<AttributePair>();
        showAddVariantForm = false;
        addVariantError = null;
    }

    private async Task UploadNewVariantImage(InputFileChangeEventArgs e)
    {
        isUploadingNewVariantImage = true;
        StateHasChanged();
        try
        {
            var url = await FileUploadService.UploadImageAsync(e.File);
            newVariant.ImageUrl = url;
        }
        catch (Exception ex)
        {
            addVariantError = $"Lỗi upload ảnh: {ex.Message}";
        }
        finally
        {
            isUploadingNewVariantImage = false;
        }
    }

    private void SetItemSpecificValue(string name, string? value)
    {
        fullRequest.ItemSpecifics ??= new List<ItemSpecificInput>();
        var existing = fullRequest.ItemSpecifics.FirstOrDefault(s => s.Name == name);
        if (existing != null)
        {
            if (string.IsNullOrWhiteSpace(value))
                fullRequest.ItemSpecifics.Remove(existing);
            else
                existing.Value = value;
        }
        else if (!string.IsNullOrWhiteSpace(value))
        {
            fullRequest.ItemSpecifics.Add(new ItemSpecificInput { Name = name, Value = value });
        }
    }

    private async Task UploadPrimaryImage(InputFileChangeEventArgs e)
    {
        try
        {
            isUploadingPrimary = true;
            StateHasChanged();
            var url = await FileUploadService.UploadImageAsync(e.File);
            fullRequest.PrimaryImageUrl = url;
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi upload ảnh chính: {ex.Message}";
        }
        finally
        {
            isUploadingPrimary = false;
            StateHasChanged();
        }
    }

    private async Task UploadExtraImage(InputFileChangeEventArgs e)
    {
        try
        {
            isUploadingExtra = true;
            StateHasChanged();
            var url = await FileUploadService.UploadImageAsync(e.File);
            extraImageUrls.Add(url);
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi upload ảnh phụ: {ex.Message}";
        }
        finally
        {
            isUploadingExtra = false;
            StateHasChanged();
        }
    }

    private async Task UploadVariantImage(InputFileChangeEventArgs e, UpdateVariantDto v)
    {
        try
        {
            uploadingVariants.Add(v);
            StateHasChanged();
            var url = await FileUploadService.UploadImageAsync(e.File);
            v.ImageUrl = url;
        }
        catch (Exception ex)
        {
            errorMessage = $"Lỗi upload ảnh biến thể: {ex.Message}";
        }
        finally
        {
            uploadingVariants.Remove(v);
            StateHasChanged();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;

            // Load Metadata
            var cats = await CategoryService.GetCategoriesAsync();
            categories = cats.ToList();

            var sp = await PolicyService.GetShippingPoliciesAsync();
            shippingPolicies = sp.ToList();

            var rp = await PolicyService.GetReturnPoliciesAsync();
            returnPolicies = rp.ToList();

            var pp = await PolicyService.GetPaymentPoliciesAsync();
            paymentPolicies = pp.ToList();

            // Load Master Data của Product để Fill vào Form
            var product = await ProductService.GetProductByIdAsync(Id);
            if (product == null)
            {
                errorMessage = "Không tìm thấy dữ liệu sản phẩm này.";
            }
            else
            {
                fullRequest.Name = product.Name;
                fullRequest.Description = product.Description;
                fullRequest.Brand = product.Brand;
                fullRequest.CategoryId = product.CategoryId;
                fullRequest.ShippingPolicyId = product.ShippingPolicyId;
                fullRequest.ReturnPolicyId = product.ReturnPolicyId;
                fullRequest.PaymentPolicyId = product.PaymentPolicyId;
                fullRequest.Status = product.Status;
                fullRequest.PrimaryImageUrl = product.PrimaryImageUrl;
                fullRequest.RowVersion = product.RowVersion;

                // [A2] Load Condition
                fullRequest.Condition = product.Condition;
                fullRequest.ConditionDescription = product.ConditionDescription;

                // [A3] Load ListingFormat + Offers
                fullRequest.ListingFormat = product.ListingFormat;
                fullRequest.AllowOffers = product.AllowOffers;
                fullRequest.AutoAcceptPrice = product.AutoAcceptPrice;
                fullRequest.AutoDeclinePrice = product.AutoDeclinePrice;
                fullRequest.Subtitle = product.Subtitle;

                if (!string.IsNullOrEmpty(product.ImageUrls))
                {
                    extraImageUrls = JsonSerializer.Deserialize<List<string>>(product.ImageUrls) ?? new();
                }

                // Load Variants để sửa
                if (product.Variants != null)
                {
                    fullRequest.Variants = product.Variants.Select(v => new UpdateVariantDto {
                        Id = v.Id,
                        SkuCode = v.SkuCode,
                        Price = v.Price,
                        Quantity = v.Quantity,
                        WeightGram = v.WeightGram,
                        ImageUrl = v.ImageUrl,
                        Attributes = JsonSerializer.Deserialize<Dictionary<string, string>>(v.Attributes ?? "{}") ?? new()
                    }).ToList();
                }

                // [A5] Load existing Item Specifics
                if (product.ItemSpecifics != null && product.ItemSpecifics.Any())
                {
                    fullRequest.ItemSpecifics = product.ItemSpecifics.Select(s => new ItemSpecificInput
                    {
                        Name = s.Name,
                        Value = s.Value
                    }).ToList();
                }
                else
                {
                    fullRequest.ItemSpecifics = new List<ItemSpecificInput>();
                }

                // [GAP-2] Load category item specifics cho dynamic form
                if (product.CategoryId != Guid.Empty)
                {
                    try
                    {
                        categoryItemSpecifics = (await CategoryService.GetItemSpecificsByCategoryIdAsync(product.CategoryId)).ToList();
                    }
                    catch { /* Category may not have item specifics */ }
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task HandleSubmit()
    {
        errorMessage = null;
        isSubmitting = true;

        try
        {
            // Sync extra images
            fullRequest.ImageUrls = extraImageUrls;

            // [GAP-2] Sync Item Specifics from form
            // Merge: giữ existing values + cập nhật từ form
            // (fullRequest.ItemSpecifics đã được bind trực tiếp qua SetItemSpecificValue)

            // Gọi 1 API duy nhất để cập nhật toàn bộ (Atomic)
            await ProductService.UpdateFullProductAsync(Id, fullRequest);
            
            // Thành công -> Điều hướng về trang danh sách kho
            NavigationManager.NavigateTo("/listings");
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isSubmitting = false;
        }
    }
}
