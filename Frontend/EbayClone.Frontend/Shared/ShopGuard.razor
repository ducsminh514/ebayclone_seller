@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthStateProvider
@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable

@ChildContent

@code {
    [Parameter] public RenderFragment ChildContent { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
        await CheckAccessAsync(NavigationManager.Uri);
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        await CheckAccessAsync(e.Location);
        StateHasChanged();
    }

    private async Task CheckAccessAsync(string url)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;

        var uri = new Uri(url);
        var currentPath = uri.AbsolutePath.ToLowerInvariant();

        // Route công khai - không cần auth
        if (currentPath == "/login" || currentPath == "/register" || currentPath.StartsWith("/verify-email"))
            return;

        // User CHƯA đăng nhập → redirect về /login
        if (user.Identity?.IsAuthenticated != true)
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        // User ĐÃ đăng nhập → kiểm tra onboarding status
        var hasShopStr = user.FindFirst("HasShop")?.Value;
        var isVerifiedStr = user.FindFirst("IsVerified")?.Value;
        bool hasShop = bool.TryParse(hasShopStr, out bool hs) && hs;
        bool isVerified = bool.TryParse(isVerifiedStr, out bool iv) && iv;

        if (!hasShop || !isVerified)
        {
            // Chưa có shop HOẶC có shop nhưng chưa hoàn thành onboarding → ÉP vô /onboarding
            if (currentPath != "/onboarding")
            {
                NavigationManager.NavigateTo("/onboarding");
            }
        }
        else
        {
            // Shop đã verified hoàn tất → không cho vào /onboarding nữa
            if (currentPath == "/onboarding")
            {
                NavigationManager.NavigateTo("/");
            }
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
